package com.cs.bcjis.dialog.service.impl;

import java.util.Map;

import org.springframework.stereotype.Repository;

import com.cs.bcjis.comm.BcjisCommAbstractDAO;

@Repository("dialogPledgeInfoDAO")
public class DialogPledgeInfoDAO extends BcjisCommAbstractDAO {
    @SuppressWarnings("rawtypes")
    public void insertPledgeInfo(Map map) {
        insert("DialogPledgeInfo.insertPledgeInfo", map);
    }

    @SuppressWarnings("rawtypes")
    public void updatePledgeInfo(Map map) {
        update("DialogPledgeInfo.updatePledgeInfo", map);
    }
}
