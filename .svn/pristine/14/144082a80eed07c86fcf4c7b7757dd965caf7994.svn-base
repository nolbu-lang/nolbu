@font-face {
    font-family: 'Nanum Gothic';
    font-weight: 300;
    font-style: normal;
    src: url('./font/NanumGothic-Regular.eot');
    src: url('./font/NanumGothic-Regular.eot?#iefix') format('embedded-opentype'),
         url('./font/NanumGothic-Regular.woff2') format('woff2'),
         url('./font/NanumGothic-Regular.woff') format('woff'),
         url('./font/NanumGothic-Regular.ttf') format('truetype'),
         url('./font/NanumGothic-Regular.svg#NanumGothicRegular') format('svg');
}
@font-face {
    font-family: 'Nanum Gothic';
    font-weight: 500;
    font-style: normal;
    src: url('./font/NanumGothic-Bold.eot');
    src: url('./font/NanumGothic-Bold.eot?#iefix') format('embedded-opentype'),
         url('./font/NanumGothic-Bold.woff2') format('woff2'),
         url('./font/NanumGothic-Bold.woff') format('woff'),
         url('./font/NanumGothic-Bold.ttf') format('truetype'),
         url('./font/NanumGothic-Bold.svg#NanumGothicBold') format('svg');
}
@font-face {
    font-family: 'Nanum Gothic';
    font-weight: 700;
    font-style: normal;
    src: url('./font/NanumGothic-ExtraBold.eot');
    src: url('./font/NanumGothic-ExtraBold.eot?#iefix') format('embedded-opentype'),
         url('./font/NanumGothic-ExtraBold.woff2') format('woff2'),
         url('./font/NanumGothic-ExtraBold.woff') format('woff'),
         url('./font/NanumGothic-ExtraBold.ttf') format('truetype'),
         url('./font/NanumGothic-ExtraBold.svg#NanumGothicExtraBold') format('svg');
}

html, body, .ui-widget, .ui-widget input, .ui-widget select, .ui-widget textarea, .ui-widget button, .btnClass, .btnDisabledClass, option{font-family: 'Nanum Gothic'; font-weight:300;}
select, option{line-height:normal; }
option{height:auto; font-family:'Nanum Gothic' !important; font-size:12px;}
.ui-jqgrid tr.jqgrow td{font-weight:300;}
a:-webkit-any-link{text-decoration:none;}

/*·ąŔĚľĆżô°řĹë*/
.ui-layout-pane{border:1px solid #d7e8f7; height:100%;}
.ui-layout-resizer{background: #d7e8f7;}
.ui-layout-toggler{background-color: #4986f4; border: 0;}
#mainBody .ui-corner-all, .ui-dialog .ui-corner-all{overflow:hidden;}
/*#mainTabs01{overflow-y:auto;} ľîÁß°ŁÇĎ°Ô Ŕß¸®´Â ąŮ´Úľî¶±ÇĎÁö*/
div#mainCenter{height:64% !important;}/*ąŮ´ÚŔß¸˛ąćÁö ŔÓ˝Ă*/

/*Ĺ×ŔĚşí°řĹë*/
.ui-th-ltr, .ui-jqgrid .ui-jqgrid-htable th.ui-th-ltr{background: none; color:#fff;}
.nondiv table tbody tr{border-left: none; border-top: none;}
.nondiv table tbody tr:last-child, .nondiv table tbody tr:last-child td{border-bottom:none !important;}
.ui-jqgrid tr.ui-row-ltr td:last-child{border-right:none;}
.ui-jqgrid tr.ui-row-ltr:last-child td{border-bottom:none;}

.ui-jqgrid tr.jqgrow td{padding:3px 10px;}
.ui-jqgrid tr.jqgrow td a img{padding-right:6px;}
table .ui-state-hover,
table .ui-widget-content .ui-state-hover,
table .ui-widget-header .ui-state-hover,
table .ui-state-focus,
table .ui-widget-content .ui-state-focus,
table .ui-widget-header .ui-state-focus {
	border-left:none; border-right:1px solid #aaa; border-top:none;
}

/*ąöĆ°°řĹë*/
.ui-widget-content a.btnClass{background: #4986f4; text-shadow: none; box-shadow: none; color: #fff; border: 1px solid #4986f4; padding: 4px 8px 4px 8px; border-radius: 5px;}
.btnDisabledClass{padding: 4px 8px 4px 8px; border-radius: 5px;}
.ui-dialog .ui-dialog-buttonpane button{background: #4986f4; color: #fff; border:none;}
.ui-draggable .ui-dialog-titlebar button.ui-dialog-titlebar-close{border-top:none; border-left:none;}/*ĆËľ÷Ă˘´Ý±âąöĆ°*/

/*ÁÂĂř¸Ţ´ş*/
#wrap > .ui-layout-pane-west{background: #d7e8f7;}
#wrap > .ui-layout-pane-west .ui-jqgrid{border:none; border-radius:4px; overflow:hidden;}
#wrap > .ui-layout-pane-west .ui-jqgrid tr.ui-row-ltr td{border-right-width:0px;}
.ui-jqgrid-labels{background: #4986f4 !important; background-image: none;}
#wrap > .ui-layout-pane-west .ui-th-ltr{padding: 7px 3px 6px 0px; background:url(/images/design/img_left_titlebg.png) no-repeat center center #fff; border:none;}
.ui-state-highlight, .ui-widget-content .ui-state-highlight, .ui-widget-header .ui-state-highlight{background: #4986f4; color: #fff; border: 1px solid #4986f4; border-right: 1px solid #aaa; border-top:none;}
#wrap > .ui-layout-pane-west .ui-state-highlight .ui-icon{background-image: url(/images/design/ui-icons_2e83ff_256x240_white.png);}

/*żěĂřĹÇ*/
#mainTabs01{margin: 0; padding: 0;}
.ui-tabs .ui-tabs-nav{background: #4986f4; border: none; padding:5px 5px 0 5px; min-width:calc(100% - 10px);}
.ui-tabs .ui-tabs-nav li{border: none; margin: 1px 5px 0 0; padding: 0;}
.ui-tabs .tab_slide_box .ui-tabs-nav li:last-child{margin-right:20px;}

/*żěĂřÄÁĹŮĂ÷*/
#mainBody .ui-jqgrid .ui-jqgrid-htable th div{padding:5px 0;}
#mainCenter .ui-th-ltr, #mainCenter .ui-jqgrid .ui-jqgrid-htable th.ui-th-ltr{height:40px; line-height: 20px;}
.ui-widget-header{background: #4986f4; color: #fff; border: none; padding: 5px 10px; border-radius: 4px 4px 0 0;}
.ui-state-hover, .ui-widget-content .ui-state-hover, .ui-widget-header .ui-state-hover, .ui-state-focus, .ui-widget-content .ui-state-focus, .ui-widget-header .ui-state-focus{border-right: 1px solid #dadada; border-left:none; border-top:none;}
#mainCenter div.btn select{padding: 3px 8px 4px 8px; border-radius: 4px; border: 1px solid #aaa;}
#mainCenter .ui-state-highlight, #mainCenter .ui-widget-content .ui-state-highlight, #mainCenter .ui-widget-header .ui-state-highlight{background:#d7e8f7; color:#222; border: 1px solid #d7e8f7; border-right: 1px solid #aaa; border-bottom: 1px solid #aaa; border-top:none;}

/*żÂ¸® Äż˝şĹŇ*/
.btn_classify{border: none; border-radius: 5px; padding:4px 8px 4px 22px; display:inline-block; cursor:pointer; background: url(/images/design/ico_btn_tableinfo.png) no-repeat 10px center #f26c4f; color:#fff; border: 1px solid #f26c4f;}

/*żą»ę˝É»çÁ¶Ľ­ - Á¶Č¸ ´©°ˇ Ĺ×ŔĚşíŔ» żÖ ŔÎ¶óŔÎżˇĽ­ 11px·Î ŔâľĆµ×łĹ°íżä*/
#mainBody #mainCenter .ui-jqgrid .ui-jqgrid-view,
#mainBody #mainCenter .ui-jqgrid .ui-jqgrid-hdiv,
#mainBody #mainCenter .ui-jqgrid .ui-jqgrid-bdiv,
#gbox_BUDGET_SELECT_NEW_GRD
{width:100% !important; height:auto !important;}