<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://www.ibatis.com/dtd/sql-map-2.dtd">

<sqlMap namespace="ReportWrite0F0">

    <typeAlias alias="egovMap" type="egovframework.rte.psl.dataaccess.util.EgovMap"/>
    
    <select id="ReportWrite0F0.selectReport0F0List" parameterClass="Map" resultClass="egovMap" >
        /*ReportWrite0F0.selectReport0F0List*/
        SELECT T.ROW_NUM AS ROW_NUM
        	 , T.DGRCOMPO_ID AS DGRCOMPO_ID
             , T.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
             , T.DGR_LEVEL AS DGR_LEVEL
             , T.FIS_YEAR AS FIS_YEAR
             , T.BGT_DGR AS BGT_DGR
             , T.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
             , T.TE_MNG_MOK_NM AS TE_MNG_MOK_NM
             , T.TE_MNG_MOK_CD_NM AS TE_MNG_MOK_CD_NM
             , T.DBIZ_NM
             , T.REPORT_MSTR AS REPORT_MSTR
             , T.REPORT_CD AS REPORT_CD
             , T.REPORT_DETL_CD AS REPORT_DETL_CD
             , T.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
             , T.COMPO_LEVEL AS COMPO_LEVEL
             , T.REFLECT_FG AS REFLECT_FG
             , T.DEMAND_CONT AS DEMAND_CONT
             , T.EXAM_CONT AS EXAM_CONT
             , T.EXAM_CONT AS EXAM_CONT_VIEW
             , T.REPORT_SORT_SEQ AS REPORT_SORT_SEQ
             , T.REPORT_SORT_SEQ AS REPORT_SORT_SEQ_VIEW
             , #indiAttr# AS INDI_ATTR
             , T.PRE_BGT_AMT
             , T.DEMAND_DIFF_AMT
             , T.DIFF_AMT 
             , T.PRE_AMT
             , CAST((T.TOT_FRSC_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT0
             , CAST((T.TOT_FRSC_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT1
             , CAST((T.TOT_FRSC_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT2
             , CAST((T.TOT_FRSC_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT3
             , CAST((T.TOT_FRSC_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT4
             , CAST((T.TOT_FRSC_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT5
             , CAST((T.TOT_FRSC_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT6
             , CAST((T.PRE_INV_FRSC_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT0
             , CAST((T.PRE_INV_FRSC_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT1
             , CAST((T.PRE_INV_FRSC_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT2
             , CAST((T.PRE_INV_FRSC_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT3
             , CAST((T.PRE_INV_FRSC_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT4
             , CAST((T.PRE_INV_FRSC_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT5
             , CAST((T.PRE_INV_FRSC_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT6
             , TRIM(T.COMP_GROUND) AS DGRCOMPO_NM
             , T.OFFICE_NM || '-' || T.DEPT_NM || '-' || T.REPORT_DETL_NM || '-' || T.DBIZ_NM AS UP_DGRCOMPO_NM
             , T.OFFICE_NM AS OFFICE_NM
             , T.DEPT_NM AS DEPT_NM
             , T.REPORT_DETL_NM AS REPORT_DETL_NM
             , T.DBIZ_NM AS DBIZ_NM
             , T.UP_DGRCOMPO_ID AS PARENT
             , CASE WHEN T.CHILD_CNT > 0  THEN 'false'
                    ELSE 'true'
               END AS IS_LEAF
             , 'true' AS EXPANDED
             , 'true' AS LOADED
             , T.DGR_LEVEL AS "LEVEL"
             , CAST((T.PRE_BGT_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_BGT_AMT
             , CAST((T.DEMAND_DIFF_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DEMAND_DIFF_AMT
             , CAST((T.DIFF_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT
             , CAST((T.PRE_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_AMT
             , T.FRSCES
          FROM (SELECT A.ROW_NUM AS ROW_NUM
          			 , A.DGRCOMPO_ID AS DGRCOMPO_ID
                     , A.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
                     , A.DGR_LEVEL AS DGR_LEVEL
                     , A.FIS_YEAR AS FIS_YEAR
                     , A.BGT_DGR AS BGT_DGR
                     , A.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
                     , DECODE(A.TE_MNG_MOK_CD, NULL, '', '00000', '', SUBSTR(A.TE_MNG_MOK_CD, 1, 3) || '-' || SUBSTR(A.TE_MNG_MOK_CD, 4)) AS TE_MNG_MOK_CD_NM
                     , A.REPORT_MSTR AS REPORT_MSTR
                     , A.REPORT_CD AS REPORT_CD
                     , A.REPORT_DETL_CD AS REPORT_DETL_CD
                     , A.OFFICE_CD AS OFFICE_CD
                     , A.DEPT_CD AS DEPT_CD
                     , A.DBIZ_CD AS DBIZ_CD
                     , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                     , A.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
                     , A.COMPO_LEVEL AS COMPO_LEVEL
                     , A.COMP_GROUND AS COMP_GROUND
                     , A.SORT_SEQ AS SORT_SEQ
                     , A.REFLECT_FG AS REFLECT_FG
                     , A.DEMAND_CONT AS DEMAND_CONT
                     , A.EXAM_CONT AS EXAM_CONT
                     , A.REPORT_SORT_SEQ AS REPORT_SORT_SEQ
                     , A.TOT_FRSC_AMT1 + A.TOT_FRSC_AMT2 + A.TOT_FRSC_AMT3 + A.TOT_FRSC_AMT4 + A.TOT_FRSC_AMT5 + A.TOT_FRSC_AMT6 AS TOT_FRSC_AMT0
                     , A.TOT_FRSC_AMT1 AS TOT_FRSC_AMT1
                     , A.TOT_FRSC_AMT2 AS TOT_FRSC_AMT2
                     , A.TOT_FRSC_AMT3 AS TOT_FRSC_AMT3
                     , A.TOT_FRSC_AMT4 AS TOT_FRSC_AMT4
                     , A.TOT_FRSC_AMT5 AS TOT_FRSC_AMT5
                     , A.TOT_FRSC_AMT6 AS TOT_FRSC_AMT6
                     , A.PRE_INV_FRSC_AMT1 + A.PRE_INV_FRSC_AMT2 + A.PRE_INV_FRSC_AMT3 + A.PRE_INV_FRSC_AMT4 + A.PRE_INV_FRSC_AMT5 + A.PRE_INV_FRSC_AMT6 AS PRE_INV_FRSC_AMT0
                     , A.PRE_INV_FRSC_AMT1 AS PRE_INV_FRSC_AMT1
                     , A.PRE_INV_FRSC_AMT2 AS PRE_INV_FRSC_AMT2
                     , A.PRE_INV_FRSC_AMT3 AS PRE_INV_FRSC_AMT3
                     , A.PRE_INV_FRSC_AMT4 AS PRE_INV_FRSC_AMT4
                     , A.PRE_INV_FRSC_AMT5 AS PRE_INV_FRSC_AMT5
                     , A.PRE_INV_FRSC_AMT6 AS PRE_INV_FRSC_AMT6
                     , A.OFFICE_RANK AS OFFICE_RANK
                     , A.OFFICE_NM AS OFFICE_NM
                     , A.DEPT_RANK AS DEPT_RANK
                     , A.DEPT_NM AS DEPT_NM
                     , A.PBIZ_RANK AS PBIZ_RANK
                     , A.PBIZ_CD AS PBIZ_CD
                     , A.UBIZ_RANK AS UBIZ_RANK
                     , A.UBIZ_CD AS UBIZ_CD
                     , A.DBIZ_RANK AS DBIZ_RANK
                     , A.DBIZ_NM AS DBIZ_NM
                     , A.PRE_BGT_AMT
                     , A.DEMAND_DIFF_AMT
                     , A.DIFF_AMT
                     , A.PRE_AMT
                     , NVL((SELECT Z.DETL_CD_NM FROM TB_COMMCDDETL Z WHERE Z.CL_CD = 'RP002' AND Z.DETL_CD = A.REPORT_DETL_CD AND ROWNUM = 1), '') AS REPORT_DETL_NM
                     , DECODE(A.TE_MNG_MOK_CD, NULL, '', '00000', '', SUBSTR(A.TE_MNG_MOK_CD, 1, 3) || '-' || SUBSTR(A.TE_MNG_MOK_CD, 4)) ||' ' || 
                       NVL((SELECT Z.TE_MNG_MOK_NM FROM TB_DGRTEMNGMOK Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.TE_MNG_MOK_CD = A.TE_MNG_MOK_CD AND ROWNUM = 1), '') AS TE_MNG_MOK_NM
                     , NVL((SELECT COUNT(*) FROM TB_DGRCOMPO Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.UP_TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID), 0) AS CHILD_CNT
                     , NVL((SELECT GROUP_CONCAT(ZZ.FRSC SEPARATOR ', ')
                              FROM (SELECT DECODE(SUBSTR(MAX(Z2.FRSC_FG_NM), 0, 1), '자', '시', SUBSTR(MAX(Z2.FRSC_FG_NM), 0, 1)) || ':' || TRIM(TO_CHAR(CAST(((NVL(SUM(Z1.PRE_DEF_FRSC_AMT), 0) + NVL(SUM(Z1.ADJ_DEF_FRSC_AMT), 0))/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)), '999,999,999,999,999,999,999')) AS FRSC
                                         , NVL(SUM(Z1.PRE_DEF_FRSC_AMT), 0) + NVL(SUM(Z1.ADJ_DEF_FRSC_AMT), 0) AS FRSC_AMT
                                      FROM TB_DGRCOMPOFRSC Z1
                                         , TB_YEARFRSC Z2
                                     WHERE 1 = 1
                                       AND Z2.FIS_YEAR = Z1.FIS_YEAR
                                       AND Z2.FRSC_FG_CD = Z1.FRSC_FG_CD
                                       AND Z1.FIS_YEAR = A.FIS_YEAR 
                                       AND Z1.BGT_DGR = A.BGT_DGR 
                                       AND Z1.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID
                                     GROUP BY Z2.FIS_YEAR
                                            , Z2.FRSC_FG_CD
                                   ) ZZ
                             WHERE 1 = 1
                               AND ZZ.FRSC_AMT <![CDATA[<>]]> 0
                           )
                       , '') AS FRSCES
                  FROM (SELECT ROWNUM AS ROW_NUM
                  			 , A.TE_BGT_COMPO_ID AS DGRCOMPO_ID
                             , A.UP_TE_BGT_COMPO_ID AS UP_DGRCOMPO_ID
                             , A.COMPO_LEVEL - 1 AS DGR_LEVEL
                             , A.FIS_YEAR AS FIS_YEAR
                             , A.BGT_DGR AS BGT_DGR
                             , A.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
                             , A.REPORT_MSTR AS REPORT_MSTR
                             , A.REPORT_CD AS REPORT_CD
                             , A.REPORT_DETL_CD AS REPORT_DETL_CD
                             , A.DEPT_CD AS DEPT_CD
                             , A.DBIZ_CD AS DBIZ_CD
                             , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                             , A.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
                             , A.COMPO_LEVEL AS COMPO_LEVEL
                             , A.COMP_GROUND AS COMP_GROUND
                             , A.SORT_SEQ AS SORT_SEQ
                             , NVL(F.REFLECT_FG, '') AS REFLECT_FG
                             , NVL(F.DEMAND_CONT, '') AS DEMAND_CONT
                             , NVL(F.EXAM_CONT, '') AS EXAM_CONT 
                             , NVL(F.REPORT_SORT_SEQ, '') AS REPORT_SORT_SEQ
                             , NVL(E.TOT_FRSC_AMT1, 0) AS TOT_FRSC_AMT1
                             , NVL(E.TOT_FRSC_AMT2, 0) AS TOT_FRSC_AMT2
                             , NVL(E.TOT_FRSC_AMT3, 0) AS TOT_FRSC_AMT3
                             , NVL(E.TOT_FRSC_AMT4, 0) AS TOT_FRSC_AMT4
                             , NVL(E.TOT_FRSC_AMT5, 0) AS TOT_FRSC_AMT5
                             , NVL(E.TOT_FRSC_AMT6, 0) AS TOT_FRSC_AMT6
                             , NVL(E.PRE_INV_FRSC_AMT1, 0) AS PRE_INV_FRSC_AMT1
                             , NVL(E.PRE_INV_FRSC_AMT2, 0) AS PRE_INV_FRSC_AMT2
                             , NVL(E.PRE_INV_FRSC_AMT3, 0) AS PRE_INV_FRSC_AMT3
                             , NVL(E.PRE_INV_FRSC_AMT4, 0) AS PRE_INV_FRSC_AMT4
                             , NVL(E.PRE_INV_FRSC_AMT5, 0) AS PRE_INV_FRSC_AMT5
                             , NVL(E.PRE_INV_FRSC_AMT6, 0) AS PRE_INV_FRSC_AMT6
                             , A.OFFICE_RANK AS OFFICE_RANK
                             , A.OFFICE_CD AS OFFICE_CD
                             , A.OFFICE_NM AS OFFICE_NM
                             , A.DEPT_RANK AS DEPT_RANK
                             , A.DEPT_NM AS DEPT_NM
                             , A.PBIZ_RANK AS PBIZ_RANK
                             , A.PBIZ_CD AS PBIZ_CD
                             , A.UBIZ_RANK AS UBIZ_RANK
                             , A.UBIZ_CD AS UBIZ_CD
                             , A.DBIZ_RANK AS DBIZ_RANK
                             , A.DBIZ_NM AS DBIZ_NM
                             , A.PRE_BGT_AMT
                             , A.DEMAND_DIFF_AMT
                             , A.DIFF_AMT
                             , A.PRE_AMT
                          FROM (SELECT A.FIS_YEAR AS FIS_YEAR
                                             , A.BGT_DGR AS BGT_DGR
                                             , MIN(B.OFFICE_RANK) AS OFFICE_RANK
                                             , MIN(B.OFFICE_CD) AS OFFICE_CD
                                             , MIN(B.OFFICE_NM) AS OFFICE_NM
                                             , MIN(B.DEPT_RANK) AS DEPT_RANK
                                             , A.DEPT_CD AS DEPT_CD
                                             , E.REPORT_MSTR AS REPORT_MSTR
                                             , E.REPORT_CD AS REPORT_CD
                                             , E.REPORT_DETL_CD AS REPORT_DETL_CD
                                             , MIN(B.DEPT_NM) AS DEPT_NM
                                             , MIN(C.PBIZ_RANK) AS PBIZ_RANK
                                             , MIN(C.PBIZ_CD) AS PBIZ_CD
                                             , MIN(C.UBIZ_RANK) AS UBIZ_RANK
                                             , MIN(C.UBIZ_CD) AS UBIZ_CD
                                             , MIN(C.DBIZ_RANK) AS DBIZ_RANK
                                             , A.DBIZ_CD AS DBIZ_CD
                                             , MIN(C.DBIZ_NM) AS DBIZ_NM
                                             , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                                             , A.TE_BGT_COMPO_ID
                                             , A.UP_TE_BGT_COMPO_ID
                                             , A.TE_BGT_COMPO_SEQ
                                             , A.COMPO_LEVEL
                                             , A.COMP_GROUND
                                             , A.SORT_SEQ
                                             , A.PRE_BGT_AMT
                                             , A.DEMAND_DIFF_AMT
                                             , A.DIFF_AMT
                                             , A.PRE_AMT
                                          FROM TB_DGRCOMPO A
                                             , TB_DGRDEPT B
                                             , TB_DGRBIZ C
                                             , TB_REPORT E
                                         WHERE 1 = 1
                                         <isEqual prepend="" property="userDeptYn" compareValue="Y">
                                           AND EXISTS (SELECT 1
                                                         FROM TB_USERDEPT Z
                                                        WHERE Z.USER_ID = #userId#
                                                          AND Z.DEPT_CD = B.DEPT_CD
                                                          AND Z.USE_YN = 'Y'
                                                          AND ROWNUM = 1
                                                      )
                                         </isEqual>
                                           AND C.FIS_YEAR = A.FIS_YEAR
                                           AND C.BGT_DGR = A.BGT_DGR
                                           AND C.DBIZ_CD = A.DBIZ_CD
                                         <isNotEmpty prepend="" property="fisFgMstCd">
		                                   AND C.FIS_FG_MST_CD = #fisFgMstCd#
		                                 </isNotEmpty>
                                         <isNotEmpty prepend="" property="fisFgCd">
                                           AND C.FIS_FG_CD = #fisFgCd#
                                         </isNotEmpty>
                                           AND B.FIS_YEAR = A.FIS_YEAR
                                           AND B.BGT_DGR = A.BGT_DGR
                                           AND B.DEPT_CD = A.DEPT_CD
                                           AND A.FIS_YEAR = E.FIS_YEAR
                                           AND A.BGT_DGR = E.BGT_DGR
                                           AND A.TE_BGT_COMPO_ID = E.TE_BGT_COMPO_ID
                                           AND A.COMPO_LEVEL = '1'
                                           AND (A.CNG_TYPE IS NULL OR A.CNG_TYPE = 'CH02' OR (A.CNG_TYPE = 'CH01' AND A.GRP_LVL != '2'))
                                         <isNotEmpty prepend="" property="indiAttr">
                                           AND E.INDI_ATTR LIKE '%' || #indiAttr# || '%'
                                         </isNotEmpty>
                                         <isEmpty prepend="" property="indiAttr">
						                   AND E.INDI_ATTR != ''
						                 </isEmpty>
                                           AND E.FIS_YEAR = #fisYear#
                                           AND E.BGT_DGR = #bgtDgr#
                                         <isNotEmpty prepend="" property="officeCd">
                                           AND B.OFFICE_CD = #officeCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="deptRankFr">
                                           AND B.DEPT_RANK <![CDATA[>=]]> #deptRankFr#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="deptRankTo">
                                           AND B.DEPT_RANK <![CDATA[<=]]> #deptRankTo#
                                         </isNotEmpty>
                                         GROUP BY A.FIS_YEAR
                                                , A.BGT_DGR
                                                , A.DEPT_CD
                                                , E.REPORT_CD
                                                , E.REPORT_DETL_CD
                                                , A.DBIZ_CD
                                                , A.TE_MNG_MOK_CD
                                       ) A
                         LEFT OUTER JOIN TB_REPORT020 E
							ON E.REPORT_CD = A.REPORT_CD
							AND E.REPORT_DETL_CD = A.REPORT_DETL_CD
							AND E.FIS_YEAR = A.FIS_YEAR
							AND E.BGT_DGR = A.BGT_DGR
							AND E.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID
                         LEFT OUTER JOIN TB_REPORT_ATTR F
							ON F.REPORT_CD = A.REPORT_CD
							AND F.REPORT_DETL_CD = A.REPORT_DETL_CD
							AND F.FIS_YEAR = A.FIS_YEAR
							AND F.BGT_DGR = A.BGT_DGR
							AND F.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID
							AND F.INDI_ATTR = #indiAttr#
                         
                       ) A
                       WHERE 1=1
                        <isNotEqual property="selectAll" compareValue="Y" prepend="">
                           AND A.ROW_NUM BETWEEN NVL(#start#, 0) AND NVL(#rowNum#, 0) + NVL(#start#, 0) -1
                         </isNotEqual>
               ) T
         WHERE 1 = 1
         ORDER BY T.FIS_YEAR 
                , NVL(T.BGT_DGR, 0)
                , NVL(T.OFFICE_RANK, 0)
                , NVL(T.OFFICE_CD, '0000')
                , NVL(T.REPORT_DETL_CD, '000')
                , CASE WHEN NVL(T.REPORT_SORT_SEQ, '') = '' THEN NVL(T.DEPT_RANK, 0) || '_' || NVL(T.DEPT_CD, '0000000') || '_' || 
                                                                 NVL(T.PBIZ_RANK, 0) || '_' || NVL(T.PBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.UBIZ_RANK, 0) || '_' || NVL(T.UBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.DBIZ_RANK, 0) || '_' || NVL(T.DBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.TE_MNG_MOK_CD, '00000')
                       ELSE '0_0000000_0_0000000000000000_0_0000000000000000_0_0000000000000000_00000'
                  END
                , CASE WHEN NVL(T.REPORT_SORT_SEQ, '') = '' THEN NVL(T.SORT_SEQ, 0)
                       ELSE CAST(NVL(T.REPORT_SORT_SEQ, '') AS NUMERIC(19, 0) )
                  END
    </select>
     
    <select id="ReportWrite0F0.selectReport0F0ListCnt" parameterClass="Map" resultClass="Integer" >
        /*ReportWrite0F0.selectReport0F0ListCnt*/
        SELECT COUNT(A.TE_MNG_MOK_CD) AS CNT
          FROM (SELECT A.FIS_YEAR
                     , A.BGT_DGR AS BGT_DGR
                     , A.DEPT_CD AS DEPT_CD
                     , A.DBIZ_CD AS DBIZ_CD
                     , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                  FROM TB_DGRCOMPO A
                     , TB_DGRDEPT B
                     , TB_DGRBIZ C
                     , TB_REPORT E
                 WHERE 1 = 1
                 <isEqual prepend="" property="userDeptYn" compareValue="Y">
                   AND EXISTS (SELECT 1
                                 FROM TB_USERDEPT Z
                                WHERE Z.USER_ID = #userId#
                                  AND Z.DEPT_CD = B.DEPT_CD
                                  AND Z.USE_YN = 'Y'
                                  AND ROWNUM = 1
                              )
                 </isEqual>
                   AND C.FIS_YEAR = A.FIS_YEAR
                   AND C.BGT_DGR = A.BGT_DGR
                   AND C.DBIZ_CD = A.DBIZ_CD
                 <isNotEmpty prepend="" property="fisFgMstCd">
                   AND C.FIS_FG_MST_CD = #fisFgMstCd#
                 </isNotEmpty>
                 <isNotEmpty prepend="" property="fisFgCd">
                    AND C.FIS_FG_CD = #fisFgCd#
                 </isNotEmpty>
                    AND B.FIS_YEAR = A.FIS_YEAR
                    AND B.BGT_DGR = A.BGT_DGR
                    AND B.DEPT_CD = A.DEPT_CD
                    AND A.FIS_YEAR = E.FIS_YEAR
                    AND A.BGT_DGR = E.BGT_DGR
                    AND A.TE_BGT_COMPO_ID = E.TE_BGT_COMPO_ID
                 <isNotEmpty prepend="" property="indiAttr">
                    AND E.INDI_ATTR LIKE '%' || #indiAttr# || '%'
                 </isNotEmpty>
                 <isEmpty prepend="" property="indiAttr">
				    AND E.INDI_ATTR != ''
				 </isEmpty>
                    AND E.FIS_YEAR = #fisYear#
                    AND E.BGT_DGR = #bgtDgr#
                 <isNotEmpty prepend="" property="officeCd">
                    AND B.OFFICE_CD = #officeCd#
                 </isNotEmpty>
                 <isNotEmpty prepend="" property="deptRankFr">
                    AND B.DEPT_RANK <![CDATA[>=]]> #deptRankFr#
                 </isNotEmpty>
                 <isNotEmpty prepend="" property="deptRankTo">
                   AND B.DEPT_RANK <![CDATA[<=]]> #deptRankTo#
                 </isNotEmpty>
                 GROUP BY A.FIS_YEAR
                        , A.BGT_DGR
                        , A.DEPT_CD
                        , E.REPORT_CD
                        , E.REPORT_DETL_CD
                        , A.DBIZ_CD
                        , A.TE_MNG_MOK_CD
               ) A
    </select>
    
    <select id="ReportWrite0F0.selectReportAttrCnt" parameterClass="Map" resultClass="Integer" >
    	SELECT COUNT(*)
    	  FROM TB_REPORT_ATTR
    	 WHERE REPORT_CD = #reportCd# 
    	   AND REPORT_DETL_CD = #reportDetlCd#
    	   AND FIS_YEAR = #fisYear#
    	   AND BGT_DGR = #bgtDgr#
    	   AND TE_BGT_COMPO_ID = #teBgtCompoId#
    	   <isNotEmpty prepend="AND" property="indiAttr">
          	INDI_ATTR = #indiAttr#
          </isNotEmpty>
    </select>
    
    <insert id="ReportWrite0F0.insertReportAttr" parameterClass="Map" >
        /*ReportWrite0F0.insertReportAttr*/
        INSERT 
          INTO TB_REPORT_ATTR(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , TE_BGT_COMPO_ID
             , INDI_ATTR
             , REFLECT_FG
             , DEMAND_CONT
             , EXAM_CONT
             , REPORT_SORT_SEQ
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        VALUES (#reportCd#
             , #reportDetlCd#
             , #fisYear#
             , #bgtDgr#
             , #teBgtCompoId#
             , #indiAttr#
             , #reflectFg#
             , #demandCont#
             , #examCont#
             , #reportSortSeq#
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP)
    </insert>
    
    <insert id="ReportWrite0F0.insertReportAttrSel" parameterClass="Map" >
        /*ReportWrite0F0.insertReportAttrSel*/
        INSERT 
          INTO TB_REPORT_ATTR(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , TE_BGT_COMPO_ID
             , INDI_ATTR
             , REFLECT_FG
             , DEMAND_CONT
             , EXAM_CONT
             <isNotEmpty prepend="," property="reportSortSeq">
             REPORT_SORT_SEQ
             </isNotEmpty>
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        VALUES (#reportCd#
             , #reportDetlCd#
             , #fisYear#
             , #bgtDgr#
             , #teBgtCompoId#
             , #indiAttr#
             , CASE WHEN #reportCd# IN ('010', '020', '030') THEN 
             	(SELECT REFLECT_FG FROM TB_REPORT$reportCd$ WHERE FIS_YEAR = #fisYear# AND BGT_DGR = #bgtDgr# AND REPORT_CD = #reportCd# AND REPORT_DETL_CD = #reportDetlCd# AND TE_BGT_COMPO_ID = #teBgtCompoId#)
               ELSE '' END
             , CASE WHEN #reportCd# IN ('010', '020', '030') THEN 
             	(SELECT DEMAND_CONT FROM TB_REPORT$reportCd$ WHERE FIS_YEAR = #fisYear# AND BGT_DGR = #bgtDgr# AND REPORT_CD = #reportCd# AND REPORT_DETL_CD = #reportDetlCd# AND TE_BGT_COMPO_ID = #teBgtCompoId#)
               ELSE '' END
             , CASE WHEN #reportCd# IN ('010', '020', '030') THEN 
             	(SELECT EXAM_CONT FROM TB_REPORT$reportCd$ WHERE FIS_YEAR = #fisYear# AND BGT_DGR = #bgtDgr# AND REPORT_CD = #reportCd# AND REPORT_DETL_CD = #reportDetlCd# AND TE_BGT_COMPO_ID = #teBgtCompoId#)
               ELSE '' END
             <isNotEmpty prepend="," property="reportSortSeq">
             #reportSortSeq#
             </isNotEmpty>
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP)
    </insert>
    
    <update id="ReportWrite0F0.updateReportAttr" parameterClass="Map" >
        /*ReportWrite0F0.updateReportAttr*/
        UPDATE TB_REPORT_ATTR
           SET REFLECT_FG		=	#reflectFg#
             , DEMAND_CONT		=	#demandCont#
             , EXAM_CONT		=	#examCont#
             , REPORT_SORT_SEQ	=	#reportSortSeq#
             , MODI_ID 			= #userId#
             , MODI_DATE 		= SYSTIMESTAMP
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
           AND INDI_ATTR = #indiAttr#
    </update> 
    
    <update id="ReportWrite0F0.updateReportAttrSel" parameterClass="Map" >
        /*ReportWrite0F0.updateReportAttrSel*/
        UPDATE TB_REPORT_ATTR
           SET REFLECT_FG		=	CASE WHEN #reportCd# IN ('010', '020', '030') THEN 
						             	(SELECT REFLECT_FG FROM TB_REPORT$reportCd$ WHERE FIS_YEAR = #fisYear# AND BGT_DGR = #bgtDgr# AND REPORT_CD = #reportCd# AND REPORT_DETL_CD = #reportDetlCd# AND TE_BGT_COMPO_ID = #teBgtCompoId#)
						               ELSE '' END
             , DEMAND_CONT		=	CASE WHEN #reportCd# IN ('010', '020', '030') THEN 
						             	(SELECT DEMAND_CONT FROM TB_REPORT$reportCd$ WHERE FIS_YEAR = #fisYear# AND BGT_DGR = #bgtDgr# AND REPORT_CD = #reportCd# AND REPORT_DETL_CD = #reportDetlCd# AND TE_BGT_COMPO_ID = #teBgtCompoId#)
						               ELSE '' END
             , EXAM_CONT		=	CASE WHEN #reportCd# IN ('010', '020', '030') THEN 
						             	(SELECT EXAM_CONT FROM TB_REPORT$reportCd$ WHERE FIS_YEAR = #fisYear# AND BGT_DGR = #bgtDgr# AND REPORT_CD = #reportCd# AND REPORT_DETL_CD = #reportDetlCd# AND TE_BGT_COMPO_ID = #teBgtCompoId#)
						               ELSE '' END
			 <isNotEmpty prepend="," property="reportSortSeq">
             REPORT_SORT_SEQ	=	#reportSortSeq#
             </isNotEmpty>
             , MODI_ID 			= #userId#
             , MODI_DATE 		= SYSTIMESTAMP
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
           AND INDI_ATTR = #indiAttr#
    </update>
    
    <delete id="ReportWrite0F0.deleteReportAttr" parameterClass="Map" >
        /*ReportWrite0F0.deleteReportAttr*/
        DELETE
          FROM TB_REPORT_ATTR
         WHERE 1 = 1
           AND REPORT_CD = #reportCd# 
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
          <isNotEmpty prepend="AND" property="indiAttr">
          	INDI_ATTR = #indiAttr#
          </isNotEmpty>
    </delete>
    
    <select id="ReportWrite0F0.selectReport0F0ExcelList" parameterClass="Map" resultClass="egovMap" >
        /*ReportWrite0F0.selectReport0F0ExcelList*/
        SELECT T.ROW_NUM AS ROW_NUM
        	 , T.DGRCOMPO_ID AS DGRCOMPO_ID
             , T.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
             , CAST(T.DGR_LEVEL AS NUMERIC(5, 0)) AS DGR_LEVEL
             , T.REPORT_DETL_CD AS REPORT_DETL_CD
             , TRIM(CASE WHEN T.DGR_LEVEL = 0 THEN '합계'
                         WHEN T.DGR_LEVEL = 1 THEN T.OFFICE_NM
                         WHEN T.DGR_LEVEL = 2 THEN T.DEPT_NM
                         WHEN T.DGR_LEVEL = 3 THEN T.DBIZ_NM
                         WHEN T.DGR_LEVEL > 3 THEN T.COMP_GROUND
                         ELSE ''
                    END) AS DGRCOMPO_NM
             , T.FIS_YEAR AS FIS_YEAR
             , T.BGT_DGR AS BGT_DGR
             , T.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
             , T.TE_MNG_MOK_NM AS TE_MNG_MOK_NM
             , T.TE_MNG_MOK_CD_NM AS TE_MNG_MOK_CD_NM
             , T.DBIZ_NM
             , T.REPORT_MSTR AS REPORT_MSTR
             , T.REPORT_CD AS REPORT_CD
             , T.REPORT_DETL_CD AS REPORT_DETL_CD
             , T.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
             , T.COMPO_LEVEL AS COMPO_LEVEL
             , T.REFLECT_FG AS REFLECT_FG
             , DECODE(T.DGR_LEVEL, 4, T.DEMAND_CONT, '') AS DEMAND_CONT
             , DECODE(T.DGR_LEVEL, 4, T.EXAM_CONT, '') AS EXAM_CONT
             , DECODE(T.DGR_LEVEL, 4, T.EXAM_CONT, '') AS EXAM_CONT_VIEW
             , T.REPORT_SORT_SEQ AS REPORT_SORT_SEQ 
             , T.REPORT_SORT_SEQ AS REPORT_SORT_SEQ_VIEW
             , #indiAttr# AS INDI_ATTR
             , T.PRE_BGT_AMT
             , T.DEMAND_DIFF_AMT
             , T.DIFF_AMT 
             , T.PRE_AMT
             , CAST((T.TOT_FRSC_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT0
             , CAST((T.TOT_FRSC_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT1
             , CAST((T.TOT_FRSC_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT2
             , CAST((T.TOT_FRSC_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT3
             , CAST((T.TOT_FRSC_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT4
             , CAST((T.TOT_FRSC_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT5
             , CAST((T.TOT_FRSC_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS TOT_FRSC_AMT6
             , CAST((T.PRE_INV_FRSC_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT0
             , CAST((T.PRE_INV_FRSC_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT1
             , CAST((T.PRE_INV_FRSC_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT2
             , CAST((T.PRE_INV_FRSC_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT3
             , CAST((T.PRE_INV_FRSC_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT4
             , CAST((T.PRE_INV_FRSC_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT5
             , CAST((T.PRE_INV_FRSC_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_INV_FRSC_AMT6
             , T.OFFICE_NM || '-' || T.DEPT_NM || '-' || T.REPORT_DETL_NM || '-' || T.DBIZ_NM AS UP_DGRCOMPO_NM
             , T.OFFICE_NM AS OFFICE_NM
             , T.DEPT_NM AS DEPT_NM
             , T.REPORT_DETL_NM AS REPORT_DETL_NM
             , T.DBIZ_NM AS DBIZ_NM
             , T.UP_DGRCOMPO_ID AS PARENT
             , CASE WHEN T.CHILD_CNT > 0  THEN 'false'
                    ELSE 'true'
               END AS IS_LEAF
             , 'true' AS EXPANDED
             , 'true' AS LOADED
             , T.DGR_LEVEL AS "LEVEL"
             , CAST((T.PRE_BGT_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_BGT_AMT
             , CAST((T.DEMAND_DIFF_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DEMAND_DIFF_AMT
             , CAST((T.DIFF_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT
             , CAST((T.PRE_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_AMT
             , T.FRSCES
          FROM (SELECT A.ROW_NUM AS ROW_NUM
          			 , A.DGRCOMPO_ID AS DGRCOMPO_ID
                     , A.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
                     , A.DGR_LEVEL AS DGR_LEVEL
                     , A.FIS_YEAR AS FIS_YEAR
                     , A.BGT_DGR AS BGT_DGR
                     , A.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
                     , DECODE(A.TE_MNG_MOK_CD, NULL, '', '00000', '', SUBSTR(A.TE_MNG_MOK_CD, 1, 3) || '-' || SUBSTR(A.TE_MNG_MOK_CD, 4)) AS TE_MNG_MOK_CD_NM
                     , A.REPORT_MSTR AS REPORT_MSTR
                     , A.REPORT_CD AS REPORT_CD
                     , A.REPORT_DETL_CD AS REPORT_DETL_CD
                     , A.OFFICE_CD AS OFFICE_CD
                     , A.DEPT_CD AS DEPT_CD
                     , A.DBIZ_CD AS DBIZ_CD
                     , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                     , A.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
                     , A.COMPO_LEVEL AS COMPO_LEVEL
                     , A.COMP_GROUND AS COMP_GROUND
                     , A.SORT_SEQ AS SORT_SEQ
                     , A.REFLECT_FG AS REFLECT_FG
                     , A.DEMAND_CONT AS DEMAND_CONT
                     , A.EXAM_CONT AS EXAM_CONT
                     , A.REPORT_SORT_SEQ AS REPORT_SORT_SEQ
                     , A.TOT_FRSC_AMT1 + A.TOT_FRSC_AMT2 + A.TOT_FRSC_AMT3 + A.TOT_FRSC_AMT4 + A.TOT_FRSC_AMT5 + A.TOT_FRSC_AMT6 AS TOT_FRSC_AMT0
                     , A.TOT_FRSC_AMT1 AS TOT_FRSC_AMT1
                     , A.TOT_FRSC_AMT2 AS TOT_FRSC_AMT2
                     , A.TOT_FRSC_AMT3 AS TOT_FRSC_AMT3
                     , A.TOT_FRSC_AMT4 AS TOT_FRSC_AMT4
                     , A.TOT_FRSC_AMT5 AS TOT_FRSC_AMT5
                     , A.TOT_FRSC_AMT6 AS TOT_FRSC_AMT6
                     , A.PRE_INV_FRSC_AMT1 + A.PRE_INV_FRSC_AMT2 + A.PRE_INV_FRSC_AMT3 + A.PRE_INV_FRSC_AMT4 + A.PRE_INV_FRSC_AMT5 + A.PRE_INV_FRSC_AMT6 AS PRE_INV_FRSC_AMT0
                     , A.PRE_INV_FRSC_AMT1 AS PRE_INV_FRSC_AMT1
                     , A.PRE_INV_FRSC_AMT2 AS PRE_INV_FRSC_AMT2
                     , A.PRE_INV_FRSC_AMT3 AS PRE_INV_FRSC_AMT3
                     , A.PRE_INV_FRSC_AMT4 AS PRE_INV_FRSC_AMT4
                     , A.PRE_INV_FRSC_AMT5 AS PRE_INV_FRSC_AMT5
                     , A.PRE_INV_FRSC_AMT6 AS PRE_INV_FRSC_AMT6
                     , A.OFFICE_RANK AS OFFICE_RANK
                     , A.OFFICE_NM AS OFFICE_NM
                     , A.DEPT_RANK AS DEPT_RANK
                     , A.DEPT_NM AS DEPT_NM
                     , A.PBIZ_RANK AS PBIZ_RANK
                     , A.PBIZ_CD AS PBIZ_CD
                     , A.UBIZ_RANK AS UBIZ_RANK
                     , A.UBIZ_CD AS UBIZ_CD
                     , A.DBIZ_RANK AS DBIZ_RANK
                     , A.DBIZ_NM AS DBIZ_NM
                     , A.PRE_BGT_AMT
                     , A.DEMAND_DIFF_AMT
                     , A.DIFF_AMT
                     , A.PRE_AMT
                     , NVL((SELECT Z.DETL_CD_NM FROM TB_COMMCDDETL Z WHERE Z.CL_CD = 'RP002' AND Z.DETL_CD = A.REPORT_DETL_CD AND ROWNUM = 1), '') AS REPORT_DETL_NM
                     , DECODE(A.TE_MNG_MOK_CD, NULL, '', '00000', '', SUBSTR(A.TE_MNG_MOK_CD, 1, 3) || '-' || SUBSTR(A.TE_MNG_MOK_CD, 4)) ||' ' || 
                       NVL((SELECT Z.TE_MNG_MOK_NM FROM TB_DGRTEMNGMOK Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.TE_MNG_MOK_CD = A.TE_MNG_MOK_CD AND ROWNUM = 1), '') AS TE_MNG_MOK_NM
                     , NVL((SELECT COUNT(*) FROM TB_DGRCOMPO Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.UP_TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID), 0) AS CHILD_CNT
                     , NVL((SELECT GROUP_CONCAT(ZZ.FRSC SEPARATOR ', ')
                              FROM (SELECT DECODE(SUBSTR(MAX(Z2.FRSC_FG_NM), 0, 1), '자', '시', SUBSTR(MAX(Z2.FRSC_FG_NM), 0, 1)) || ':' || TRIM(TO_CHAR(CAST(((NVL(SUM(Z1.PRE_DEF_FRSC_AMT), 0) + NVL(SUM(Z1.ADJ_DEF_FRSC_AMT), 0))/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)), '999,999,999,999,999,999,999')) AS FRSC
                                         , NVL(SUM(Z1.PRE_DEF_FRSC_AMT), 0) + NVL(SUM(Z1.ADJ_DEF_FRSC_AMT), 0) AS FRSC_AMT
                                      FROM TB_DGRCOMPOFRSC Z1
                                         , TB_YEARFRSC Z2
                                     WHERE 1 = 1
                                       AND Z2.FIS_YEAR = Z1.FIS_YEAR
                                       AND Z2.FRSC_FG_CD = Z1.FRSC_FG_CD
                                       AND Z1.FIS_YEAR = A.FIS_YEAR 
                                       AND Z1.BGT_DGR = A.BGT_DGR 
                                       AND Z1.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID
                                     GROUP BY Z2.FIS_YEAR
                                            , Z2.FRSC_FG_CD
                                   ) ZZ
                             WHERE 1 = 1
                               AND ZZ.FRSC_AMT <![CDATA[<>]]> 0
                           )
                       , '') AS FRSCES
                  FROM (SELECT ROWNUM AS ROW_NUM
                  			 , T.DGRCOMPO_ID AS DGRCOMPO_ID
                             , T.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
                             , T.DGR_LEVEL AS DGR_LEVEL
                             , T.FIS_YEAR AS FIS_YEAR
                             , T.BGT_DGR AS BGT_DGR
                             , T.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
                             , T.REPORT_MSTR AS REPORT_MSTR
                             , T.REPORT_CD AS REPORT_CD
                             , T.REPORT_DETL_CD AS REPORT_DETL_CD
                             , T.DEPT_CD AS DEPT_CD
                             , T.DBIZ_CD AS DBIZ_CD
                             , T.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                             , T.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
                             , T.COMPO_LEVEL AS COMPO_LEVEL
                             , T.COMP_GROUND AS COMP_GROUND
                             , T.SORT_SEQ AS SORT_SEQ
                             , NVL(F.REFLECT_FG, '') AS REFLECT_FG
                             , NVL(F.DEMAND_CONT, '') AS DEMAND_CONT
                             , NVL(F.EXAM_CONT, '') AS EXAM_CONT 
                             , NVL(F.REPORT_SORT_SEQ, '') AS REPORT_SORT_SEQ
                             , NVL(E.TOT_FRSC_AMT1, 0) AS TOT_FRSC_AMT1
                             , NVL(E.TOT_FRSC_AMT2, 0) AS TOT_FRSC_AMT2
                             , NVL(E.TOT_FRSC_AMT3, 0) AS TOT_FRSC_AMT3
                             , NVL(E.TOT_FRSC_AMT4, 0) AS TOT_FRSC_AMT4
                             , NVL(E.TOT_FRSC_AMT5, 0) AS TOT_FRSC_AMT5
                             , NVL(E.TOT_FRSC_AMT6, 0) AS TOT_FRSC_AMT6
                             , NVL(E.PRE_INV_FRSC_AMT1, 0) AS PRE_INV_FRSC_AMT1
                             , NVL(E.PRE_INV_FRSC_AMT2, 0) AS PRE_INV_FRSC_AMT2
                             , NVL(E.PRE_INV_FRSC_AMT3, 0) AS PRE_INV_FRSC_AMT3
                             , NVL(E.PRE_INV_FRSC_AMT4, 0) AS PRE_INV_FRSC_AMT4
                             , NVL(E.PRE_INV_FRSC_AMT5, 0) AS PRE_INV_FRSC_AMT5
                             , NVL(E.PRE_INV_FRSC_AMT6, 0) AS PRE_INV_FRSC_AMT6
                             , T.OFFICE_RANK AS OFFICE_RANK
                             , T.OFFICE_CD AS OFFICE_CD
                             , T.OFFICE_NM AS OFFICE_NM
                             , T.DEPT_RANK AS DEPT_RANK
                             , T.DEPT_NM AS DEPT_NM
                             , T.PBIZ_RANK AS PBIZ_RANK
                             , T.PBIZ_CD AS PBIZ_CD
                             , T.UBIZ_RANK AS UBIZ_RANK
                             , T.UBIZ_CD AS UBIZ_CD
                             , T.DBIZ_RANK AS DBIZ_RANK 
                             , T.DBIZ_NM AS DBIZ_NM
                             , T.PRE_BGT_AMT
                             , T.DEMAND_DIFF_AMT 
                             , T.DIFF_AMT  
                             , T.PRE_AMT
                          FROM (SELECT DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 4, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || '00000000000'
                                                  , 5, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || A.TE_BGT_COMPO_ID) AS DGRCOMPO_ID
                                     , DECODE(H.CT, 1, A.FIS_YEAR || '_' || '000' || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 2, A.FIS_YEAR || '_' || '000' || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 4, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 5, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000') AS UP_DGRCOMPO_ID 
<!--                                      , DECODE(H.CT, 1, A.FIS_YEAR || '_' || '000' || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 4, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 5, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || A.UP_TE_BGT_COMPO_ID) AS UP_DGRCOMPO_ID  -->
                                     , DECODE(H.CT, 1, 0, 2, 1, 3, 2, 4, 3, 3 + A.COMPO_LEVEL) AS DGR_LEVEL
                          					 , A.FIS_YEAR AS FIS_YEAR
                                             , A.BGT_DGR AS BGT_DGR
                                             , MIN(B.OFFICE_RANK) AS OFFICE_RANK
                                             , MIN(B.OFFICE_CD) AS OFFICE_CD
                                             , MIN(B.OFFICE_NM) AS OFFICE_NM
                                             , MIN(B.DEPT_RANK) AS DEPT_RANK
                                             , A.DEPT_CD AS DEPT_CD
                                             , E.REPORT_MSTR AS REPORT_MSTR
                                             , E.REPORT_CD AS REPORT_CD
                                             , E.REPORT_DETL_CD AS REPORT_DETL_CD
                                             , MIN(B.DEPT_NM) AS DEPT_NM
                                             , MIN(C.PBIZ_RANK) AS PBIZ_RANK
                                             , MIN(C.PBIZ_CD) AS PBIZ_CD
                                             , MIN(C.UBIZ_RANK) AS UBIZ_RANK
                                             , MIN(C.UBIZ_CD) AS UBIZ_CD
                                             , MIN(C.DBIZ_RANK) AS DBIZ_RANK
                                             , A.DBIZ_CD AS DBIZ_CD
                                             , MIN(C.DBIZ_NM) AS DBIZ_NM
                                             , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                                             , A.TE_BGT_COMPO_ID
                                             , A.UP_TE_BGT_COMPO_ID
                                             , A.TE_BGT_COMPO_SEQ
                                             , A.COMPO_LEVEL
                                             , A.COMP_GROUND
                                             , A.SORT_SEQ
                                             , A.PRE_BGT_AMT
                                             , A.DEMAND_DIFF_AMT
                                             , A.DIFF_AMT
                                             , A.PRE_AMT
                                             , E.INDI_ATTR
                                          FROM TB_DGRCOMPO A
		                                     , TB_DGRDEPT B
		                                     , TB_DGRBIZ C
		                                     , TB_YEARFISFG D
		                                     , TB_REPORT E
		                                     , (SELECT ROWNUM AS CT FROM TB_COMMCD WHERE ROWNUM BETWEEN 1 AND 5) H
                                         WHERE 1 = 1
                                         <isEqual prepend="" property="userDeptYn" compareValue="Y">
                                           AND EXISTS (SELECT 1
                                                         FROM TB_USERDEPT Z
                                                        WHERE Z.USER_ID = #userId#
                                                          AND Z.DEPT_CD = B.DEPT_CD
                                                          AND Z.USE_YN = 'Y'
                                                          AND ROWNUM = 1
                                                      )
                                         </isEqual>
                                           AND D.FIS_YEAR = C.FIS_YEAR
                                   		   AND D.FIS_FG_CD = C.FIS_FG_CD
                                           AND C.FIS_YEAR = A.FIS_YEAR
                                           AND C.BGT_DGR = A.BGT_DGR
                                           AND C.DBIZ_CD = A.DBIZ_CD
                                         <isNotEmpty prepend="" property="fisFgMstCd">
		                                   AND C.FIS_FG_MST_CD = #fisFgMstCd#
		                                 </isNotEmpty>
                                         <isNotEmpty prepend="" property="fisFgCd">
                                           AND C.FIS_FG_CD = #fisFgCd#
                                         </isNotEmpty>
                                           AND B.FIS_YEAR = A.FIS_YEAR
                                           AND B.BGT_DGR = A.BGT_DGR
                                           AND B.DEPT_CD = A.DEPT_CD
                                           AND A.FIS_YEAR = E.FIS_YEAR
                                           AND A.BGT_DGR = E.BGT_DGR
                                           AND A.TE_BGT_COMPO_ID = E.TE_BGT_COMPO_ID
                                           AND A.COMPO_LEVEL = '1'
                                           AND (A.CNG_TYPE IS NULL OR A.CNG_TYPE = 'CH02' OR (A.CNG_TYPE = 'CH01' AND A.GRP_LVL != '2'))
                                         <isNotEmpty prepend="" property="indiAttr">
                                           AND E.INDI_ATTR LIKE '%' || #indiAttr# || '%'
                                         </isNotEmpty>
                                         <isEmpty prepend="" property="indiAttr">
						                   AND E.INDI_ATTR != ''
						                 </isEmpty>
                                           AND E.FIS_YEAR = #fisYear#
                                           AND E.BGT_DGR = #bgtDgr#
                                         <isNotEmpty prepend="" property="officeCd">
                                           AND B.OFFICE_CD = #officeCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="deptRankFr">
                                           AND B.DEPT_RANK <![CDATA[>=]]> #deptRankFr#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="deptRankTo">
                                           AND B.DEPT_RANK <![CDATA[<=]]> #deptRankTo#
                                         </isNotEmpty>
                                         GROUP BY DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                     , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                     , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD  || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000'
                                                     , 4, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD  || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || '00000000000'
                                                     , 5, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || B.OFFICE_CD  || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || A.TE_BGT_COMPO_ID)
                                       ) T
                         LEFT OUTER JOIN TB_REPORT020 E
							ON E.REPORT_CD = T.REPORT_CD
							AND E.REPORT_DETL_CD = T.REPORT_DETL_CD
							AND E.FIS_YEAR = T.FIS_YEAR
							AND E.BGT_DGR = T.BGT_DGR
							AND E.TE_BGT_COMPO_ID = T.TE_BGT_COMPO_ID
                         LEFT OUTER JOIN TB_REPORT_ATTR F
							ON F.REPORT_CD = T.REPORT_CD
							AND F.REPORT_DETL_CD = T.REPORT_DETL_CD
							AND F.FIS_YEAR = T.FIS_YEAR
							AND F.BGT_DGR = T.BGT_DGR
							AND F.TE_BGT_COMPO_ID = T.TE_BGT_COMPO_ID
							AND F.INDI_ATTR = T.INDI_ATTR
                         
                       ) A
                       WHERE 1=1
               ) T
         WHERE 1 = 1
         ORDER BY T.FIS_YEAR
                , NVL(T.BGT_DGR, 0)
                , NVL(T.OFFICE_RANK, 0)
                , NVL(T.OFFICE_CD, '0000')
                , NVL(T.DEPT_RANK, 0)
                , NVL(T.DEPT_CD, '0000000')
                , NVL(T.PBIZ_RANK, 0)
                , NVL(T.PBIZ_CD, '0000000000000000')
                , NVL(T.UBIZ_RANK, 0)
                , NVL(T.UBIZ_CD, '0000000000000000')
    </select> 
    
</sqlMap>
