    @SuppressWarnings("rawtypes")
    public void insertReport(String reportCd, Map map) throws Exception {
        if ("070".equals(reportCd) == true) {
            insertReport070(map);
        } else {
            insertReport(map);
        }
    }

    @SuppressWarnings("rawtypes")
    public void deleteReport(String reportCd, Map map) throws Exception {
        if ("070".equals(reportCd) == true) {
            deleteReport070(map);
        } else {
            deleteReport(map);
        }
    }

    @SuppressWarnings({ "rawtypes", "unchecked" })
    public void insertReport(Map map) throws Exception {
    	boolean detlFlag = true;
        insert("ReportComm.insertReport", map);
        String reportCd = String.valueOf(map.get("reportCd"));
        
        if(reportCd != null && Integer.parseInt(reportCd) >= 100){
        	detlFlag = false;
    	}
        
        if(detlFlag){
        	insert("ReportComm.insertReport" + map.get("reportCd"), map);
        }

        if ("020".equals(map.get("reportCd")) == true) {
            insert("ReportComm.insertReport020D", map);
        }

        try { 
            map.put("hisFg", "010");
            if(detlFlag){
            	insert("BcjisHisComm.insertTbReport" + map.get("reportCd") + "H", map);
            }
            insert("BcjisHisComm.insertTbReportH", map);
        } catch (Exception e) {
            logger.error("deleteAllReport(map)", e);
        }
    }
    
    @SuppressWarnings({ "rawtypes", "unchecked" })
    public void updateReport(Map map) throws Exception {
        
    	update("ReportComm.updateReport", map);
    }

    @SuppressWarnings({ "rawtypes", "unchecked" })
    public void deleteAllReport(Map map) throws Exception {
        try {
            map.put("hisFg", "030");
            insert("BcjisHisComm.insertTbReport010H", map);
            insert("BcjisHisComm.insertTbReport020H", map);
            insert("BcjisHisComm.insertTbReport030H", map);
            insert("BcjisHisComm.insertTbReport040H", map);
            insert("BcjisHisComm.insertTbReport050H", map);
            insert("BcjisHisComm.insertTbReport055H", map);
            insert("BcjisHisComm.insertTbReport060H", map);
            insert("BcjisHisComm.insertTbReport070H", map);
            insert("BcjisHisComm.insertTbReport080H", map);
            insert("BcjisHisComm.insertTbReport090H", map);
            insert("BcjisHisComm.insertTbReport0A0H", map);
            insert("BcjisHisComm.insertTbReport0B0H", map);
            insert("BcjisHisComm.insertTbReport0C0H", map);
            insert("BcjisHisComm.insertTbReportH", map);
        } catch (Exception e) {
            logger.error("deleteAllReport(map)", e);
        }

        delete("ReportComm.deleteReport010", map);
        delete("ReportComm.deleteReport020D", map);
        delete("ReportComm.deleteReport020", map);
        delete("ReportComm.deleteReport030", map);
        delete("ReportComm.deleteReport040", map);
        delete("ReportComm.deleteReport050", map);
        delete("ReportComm.deleteReport055", map);
        delete("ReportComm.deleteReport060", map);
        delete("ReportComm.deleteReport070", map);
        delete("ReportComm.deleteReport080", map);
        delete("ReportComm.deleteReport090", map);
        delete("ReportComm.deleteReport0A0", map);
        delete("ReportComm.deleteReport0B0", map);
        delete("ReportComm.deleteReport0C0", map);
        delete("ReportComm.deleteReport", map);
    }

    @SuppressWarnings({ "rawtypes", "unchecked" })
    public void deleteReport(Map map) throws Exception {
    	boolean delDetlFlag = true;
    	String reportCd = String.valueOf(map.get("reportCd"));
    	if(reportCd != null && Integer.parseInt(reportCd) >= 100){
    		delDetlFlag = false;
    	}
    	
        try {
            map.put("hisFg", "030");
            if(delDetlFlag){
            	insert("BcjisHisComm.insertTbReport" + map.get("reportCd") + "H", map);
                if ("010".equals(map.get("reportCd")) == true) {
                    insert("BcjisHisComm.insertTbReport0A0H", map);
                }
            }

            insert("BcjisHisComm.insertTbReportH", map);
        } catch (Exception e) {
            logger.error("deleteReport(map)", e);
        }

        if(delDetlFlag){
        	delete("ReportComm.deleteReport" + map.get("reportCd"), map);
        }
        if ("010".equals(map.get("reportCd")) == true) {
            delete("ReportComm.deleteReport0A0", map);
        }

        if ("020".equals(map.get("reportCd")) == true) {
            insert("ReportComm.deleteReport020D", map);
        }

        if ("0C0".equals(map.get("reportCd")) == true && delDetlFlag) {
            insert("ReportComm.deleteReport0C0D", map);
        }

        delete("ReportComm.deleteReport", map);
    }

