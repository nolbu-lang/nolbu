    @SuppressWarnings({ "rawtypes", "unchecked" })
    public void copyReport(Map map) throws Exception {
        try {
            map.put("hisFg", "020");
            insert("BcjisHisComm.insertTbReport" + map.get("reportCd") + "H", map);
        } catch (Exception e) {
            logger.error("deleteReport(map)", e);
        }

        update("ReportComm.copyReport" + map.get("reportCd"), map);
    }

    @SuppressWarnings("rawtypes")
    public Map<String, CellStyle> getReportStyleMap(Map param, XSSFWorkbook wb) throws Exception {
        Map<String, CellStyle> styles = new HashMap<String, CellStyle>();
        XSSFCellStyle style = null;
        XSSFFont font = null;

        List list = selectReportStyleList(param);
        Map map = null;
        for (int i = 0; i < list.size(); i++) {
            map = (Map) list.get(i);

            style = wb.createCellStyle();
            font = wb.createFont();

            ExtendedFormatRecord e = new ExtendedFormatRecord();
            e.setShrinkToFit(true);
            style.setDataFormat(e.getFormatIndex());

            font.setFontHeightInPoints(BcjisCommUtil.getShortValue(map.get("fontHeight")));
            if ("Y".equals(map.get("fontWeightYn")) == true) {
                font.setBoldweight(BcjisCommUtil.getShortValue(map.get("fontWeight")));
            }
            font.setFontName(String.valueOf(map.get("fontNm")));
            if ("Y".equals(map.get("fontColorYn")) == true) {
                font.setColor(new XSSFColor(new byte[] { BcjisCommUtil.getByteValue(map.get("fontColorR")), BcjisCommUtil.getByteValue(map.get("fontColorB")), BcjisCommUtil.getByteValue(map.get("fontColorG")) }));

            }

            style.setAlignment(BcjisCommUtil.getShortValue(map.get("alignment")));
            style.setVerticalAlignment(BcjisCommUtil.getShortValue(map.get("vAlignment")));

            if ("Y".equals(map.get("borderRightYn")) == true) {
                style.setBorderRight(BcjisCommUtil.getShortValue(map.get("borderRight")));
                style.setRightBorderColor(BcjisCommUtil.getShortValue(map.get("borderRightColor")));
            }

            if ("Y".equals(map.get("borderLeftYn")) == true) {
                style.setBorderLeft(BcjisCommUtil.getShortValue(map.get("borderLeft")));
                style.setLeftBorderColor(BcjisCommUtil.getShortValue(map.get("borderLeftColor")));
            }

            if ("Y".equals(map.get("borderTopYn")) == true) {
                style.setBorderTop(BcjisCommUtil.getShortValue(map.get("borderTop")));
                style.setTopBorderColor(BcjisCommUtil.getShortValue(map.get("borderTopColor")));
            }

            if ("Y".equals(map.get("borderBottomYn")) == true) {
                style.setBorderBottom(BcjisCommUtil.getShortValue(map.get("borderBottom")));
                style.setBottomBorderColor(BcjisCommUtil.getShortValue(map.get("borderBottomColor")));
            }

            if ("Y".equals(map.get("foreFillYn")) == true) {
                style.setFillForegroundColor(new XSSFColor(new byte[] { BcjisCommUtil.getByteValue(map.get("foreGroundColorR")), BcjisCommUtil.getByteValue(map.get("foreGroundColorB")), BcjisCommUtil.getByteValue(map.get("foreGroundColorG")) }));

                style.setFillPattern(BcjisCommUtil.getShortValue(map.get("fillPattern")));
            }

            if ("Y".equals(map.get("wrapTextYn")) == true) {
                style.setWrapText(true);
            }

            if (BcjisCommUtil.getShortValue(map.get("dataFormat")) > (short) 0) {
                style.setDataFormat(BcjisCommUtil.getShortValue(map.get("dataFormat")));

            } else if (BcjisCommUtil.isNullString(map.get("userDataFormat")) == false) {
                style.setDataFormat(wb.getCreationHelper().createDataFormat().getFormat(String.valueOf(map.get("userDataFormat"))));
            }

            style.setFont(font);
            styles.put(String.valueOf(map.get("styleNm")), style);
        }

        return styles;
    }

    @SuppressWarnings("rawtypes")
    public List selectReportColWidthList(Map map) throws Exception {
