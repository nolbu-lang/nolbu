    @SuppressWarnings("rawtypes")
    public void setReportColWidth(Map param, XSSFSheet sheet) throws Exception {
        List list = selectReportColWidthList(param);
        Map map = null;
        for (int i = 0; i < list.size(); i++) {
            map = (Map) list.get(i);

            sheet.setColumnWidth(BcjisCommUtil.getIntValue(map.get("colSeq")), BcjisCommUtil.getIntValue(map.get("colWidth")));
        }

    }

