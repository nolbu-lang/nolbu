<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://www.ibatis.com/dtd/sql-map-2.dtd">

<sqlMap namespace="ReportWrite040">

    <typeAlias alias="egovMap" type="egovframework.rte.psl.dataaccess.util.EgovMap"/>
    
    <select id="ReportWrite040.selectReport040List" parameterClass="Map" resultClass="egovMap" >
        /*ReportWrite040.selectReport040List*/
        SELECT T.DGRCOMPO_ID AS DGRCOMPO_ID
             , T.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
             , T.DGR_LEVEL AS DGR_LEVEL
             , T.FIS_YEAR AS FIS_YEAR
             , T.BGT_DGR AS BGT_DGR
             , T.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
             , T.REPORT_CD AS REPORT_CD
             , T.REPORT_DETL_CD AS REPORT_DETL_CD
             , T.GOV_SUB
             , T.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
             , T.DEMAND_COMP_FORMULAR AS DEMAND_COMP_FORMULAR
             , CAST((T.DEMAND_DIFF_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DEMAND_BGT_AMT
             , T.COMP_FORMULAR AS COMP_FORMULAR
             , CAST((T.DIFF_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS BGT_AMT
             , T.PRE_COMP_FORMULAR AS PRE_COMP_FORMULAR
             , CAST((T.PRE_BGT_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_BGT_AMT
             , T.PRE_FORMULAR AS PRE_FORMULAR
             , CAST((T.PRE_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_AMT
             , CAST(((T.DIFF_AMT - T.PRE_BGT_AMT)/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT
             , T.COMPO_LEVEL AS COMPO_LEVEL
             , T.REFLECT_FG AS REFLECT_FG
             , T.DEMAND_CONT AS DEMAND_CONT
             , T.EXAM_CONT AS EXAM_CONT
             , T.EXAM_CONT AS EXAM_CONT_VIEW
             , T.SRCH_VAL AS SRCH_VAL
             , T.SRCH_VAL AS SRCH_VAL_VIEW
             , T.FRSCES AS FRSCES
             , T.EXCEPT_CNT AS EXCEPT_CNT
             , T.COMPO_CNT AS COMPO_CNT
             , T.STAFF_CNT AS STAFF_CNT
             , T.STAFF_CNT AS STAFF_CNT_VIEW
             , T.STAFF_CURR_CNT AS STAFF_CURR_CNT
             , T.STAFF_CURR_CNT AS STAFF_CURR_CNT_VIEW
             , T.DRIVER_CNT AS DRIVER_CNT
             , T.DRIVER_CNT AS DRIVER_CNT_VIEW
             , T.ETC_CNT AS ETC_CNT
             , T.ETC_CNT AS ETC_CNT_VIEW
             , T.EXP_FG AS EXP_FG
             , T.EXP_FG AS EXP_FG_VIEW
             , TRIM(CASE WHEN T.DGR_LEVEL = 0 THEN '합계'
                         WHEN T.DGR_LEVEL = 1 THEN T.OFFICE_NM
                         WHEN T.DGR_LEVEL = 2 THEN T.DEPT_NM
                         WHEN T.DGR_LEVEL = 3 THEN T.DBIZ_NM
                         WHEN T.DGR_LEVEL > 3 THEN LAVEL_SYMBOL || T.COMP_GROUND
                         ELSE ''
                    END) AS DGRCOMPO_NM
             , T.UP_DGRCOMPO_ID AS PARENT
             , CASE WHEN T.CHILD_CNT > 0  THEN 'false'
                    ELSE 'true'
               END AS IS_LEAF
             , 'true' AS EXPANDED
             , 'true' AS LOADED
             , T.DGR_LEVEL AS "LEVEL"
          FROM (SELECT A.DGRCOMPO_ID AS DGRCOMPO_ID
                     , A.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
                     , A.DGR_LEVEL AS DGR_LEVEL
                     , A.FIS_YEAR AS FIS_YEAR
                     , A.BGT_DGR AS BGT_DGR
                     , A.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
                     , (SELECT Z.GOV_SUB FROM TB_REPORT Z WHERE Z.REPORT_CD = A.REPORT_CD AND Z.REPORT_DETL_CD = A.REPORT_DETL_CD AND Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS GOV_SUB
                     , A.REPORT_CD AS REPORT_CD
                     , A.REPORT_DETL_CD AS REPORT_DETL_CD
                     , A.OFFICE_CD AS OFFICE_CD
                     , A.DEPT_CD AS DEPT_CD
                     , A.DBIZ_CD AS DBIZ_CD
                     , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                     , A.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
                     , A.DEMAND_COMP_FORMULAR AS DEMAND_COMP_FORMULAR
                     , A.DEMAND_DIFF_AMT AS DEMAND_DIFF_AMT
                     , A.COMPO_LEVEL AS COMPO_LEVEL
                     , A.COMP_GROUND AS COMP_GROUND
                     , A.COMP_FORMULAR AS COMP_FORMULAR
                     , A.DIFF_AMT AS DIFF_AMT
                     , A.SORT_SEQ AS SORT_SEQ
                     , A.PRE_COMP_FORMULAR AS PRE_COMP_FORMULAR
                     , A.PRE_BGT_AMT AS PRE_BGT_AMT
                     , A.PRE_FORMULAR AS PRE_FORMULAR
                     , A.PRE_AMT AS PRE_AMT
                     , A.REFLECT_FG AS REFLECT_FG
                     , A.DEMAND_CONT AS DEMAND_CONT
                     , A.EXAM_CONT AS EXAM_CONT
                     , A.SRCH_VAL AS SRCH_VAL
                     , A.DRIVER_CNT + A.ETC_CNT AS EXCEPT_CNT
                     , A.STAFF_CNT - (A.DRIVER_CNT + A.ETC_CNT) AS COMPO_CNT
                     , A.STAFF_CNT AS STAFF_CNT
                     , A.STAFF_CURR_CNT AS STAFF_CURR_CNT
                     , A.DRIVER_CNT AS DRIVER_CNT
                     , A.ETC_CNT AS ETC_CNT
                     , A.EXP_FG AS EXP_FG
                     , NVL((SELECT Z.OFFICE_RANK FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.OFFICE_CD = A.OFFICE_CD AND ROWNUM = 1), 0) AS OFFICE_RANK
                     , NVL((SELECT Z.OFFICE_NM FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.OFFICE_CD = A.OFFICE_CD AND ROWNUM = 1), '') AS OFFICE_NM
                     , NVL((SELECT Z.DEPT_RANK FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DEPT_CD = A.DEPT_CD AND ROWNUM = 1), 0) AS DEPT_RANK
                     , NVL((SELECT Z.DEPT_NM FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DEPT_CD = A.DEPT_CD AND ROWNUM = 1), '') AS DEPT_NM
                     , NVL((SELECT Z.PBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS PBIZ_RANK
                     , NVL((SELECT Z.PBIZ_CD FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS PBIZ_CD
                     , NVL((SELECT Z.UBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS UBIZ_RANK
                     , NVL((SELECT Z.UBIZ_CD FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS UBIZ_CD
                     , NVL((SELECT Z.DBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS DBIZ_RANK
                     , NVL((SELECT Z.DBIZ_NM FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS DBIZ_NM
                     , NVL((SELECT COUNT(*) FROM TB_DGRCOMPO Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.UP_TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID), 0) AS CHILD_CNT
                     , NVL((SELECT Z.SYMBOL FROM TB_DGRCOMPOSYMBOL Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.COMPO_LEVEL = A.COMPO_LEVEL AND SYMBOL_LENGTH > 0), '') AS LAVEL_SYMBOL
                     , NVL((SELECT GROUP_CONCAT(ZZ.FRSC SEPARATOR '<![CDATA[<BR>]]>')
                              FROM (SELECT MAX(Z2.FRSC_FG_NM) || ':' || TRIM(TO_CHAR(CAST(((NVL(SUM(Z1.PRE_DEF_FRSC_AMT), 0) + NVL(SUM(Z1.ADJ_DEF_FRSC_AMT), 0))/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)), '999,999,999,999,999,999,999')) AS FRSC
                                         , NVL(SUM(Z1.PRE_DEF_FRSC_AMT), 0) + NVL(SUM(Z1.ADJ_DEF_FRSC_AMT), 0) AS FRSC_AMT
                                      FROM TB_DGRCOMPOFRSC Z1
                                         , TB_YEARFRSC Z2
                                     WHERE 1 = 1
                                       AND Z2.FIS_YEAR = Z1.FIS_YEAR
                                       AND Z2.FRSC_FG_CD = Z1.FRSC_FG_CD
                                       AND Z1.FIS_YEAR = A.FIS_YEAR 
                                       AND Z1.BGT_DGR = A.BGT_DGR 
                                       AND Z1.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID
                                     GROUP BY Z2.FIS_YEAR
                                            , Z2.FRSC_FG_CD
                                   ) ZZ
                             WHERE 1 = 1
                               AND ZZ.FRSC_AMT <![CDATA[<>]]> 0
                           )
                       , '') AS FRSCES
                  FROM (
                        SELECT T.*
                          FROM (SELECT DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000' 
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 4, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || '00000000000'
                                                  , 5, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || A.TE_BGT_COMPO_ID) AS DGRCOMPO_ID
                                     , DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_CD || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000' 
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 4, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 5, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || A.UP_TE_BGT_COMPO_ID) AS UP_DGRCOMPO_ID
                                     , DECODE(H.CT, 1, 0, 2, 1, 3, 2, 4, 3, 3 + A.COMPO_LEVEL) AS DGR_LEVEL
                                     , A.FIS_YEAR AS FIS_YEAR
                                     , A.BGT_DGR AS BGT_DGR
                                     , E.REPORT_CD AS REPORT_CD
                                     , E.REPORT_DETL_CD AS REPORT_DETL_CD
                                     , DECODE(H.CT, 1, '00000000000', 2, '00000000000', 3, '00000000000', 4, '00000000000', A.TE_BGT_COMPO_ID) AS TE_BGT_COMPO_ID 
                                     , DECODE(H.CT, 1, '0000', B.OFFICE_CD) AS OFFICE_CD
                                     , DECODE(H.CT, 1, '0000000', 2, '0000000', A.DEPT_CD) AS DEPT_CD
                                     , DECODE(H.CT, 1, '0000000000000000', 2, '0000000000000000', 3, '0000000000000000', C.DBIZ_CD) AS DBIZ_CD 
                                     , DECODE(H.CT, 1, '00000', 2, '00000', 3, '00000', 4, '00000', A.TE_MNG_MOK_CD) AS TE_MNG_MOK_CD 
                                     , DECODE(H.CT, 1, 0, 2, 0, 3, 0, 4, 0, A.TE_BGT_COMPO_SEQ) AS TE_BGT_COMPO_SEQ 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', A.DEMAND_COMP_FORMULAR) AS DEMAND_COMP_FORMULAR 
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DEMAND_DIFF_AMT, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DEMAND_DIFF_AMT, 0), 3, DECODE(A.COMPO_LEVEL, '1', A.DEMAND_DIFF_AMT, 0), 4, DECODE(A.COMPO_LEVEL, '1', A.DEMAND_DIFF_AMT, 0), A.DEMAND_DIFF_AMT)) AS DEMAND_DIFF_AMT
                                     , DECODE(H.CT, 1, 0, 2, 0, 3, 0, 4, 0, A.COMPO_LEVEL) AS COMPO_LEVEL 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', A.COMP_GROUND) AS COMP_GROUND 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', A.COMP_FORMULAR) AS COMP_FORMULAR 
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DIFF_AMT, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DIFF_AMT, 0), 3, DECODE(A.COMPO_LEVEL, '1', A.DIFF_AMT, 0), 4, DECODE(A.COMPO_LEVEL, '1', A.DIFF_AMT, 0), A.DIFF_AMT)) AS DIFF_AMT
                                     , DECODE(H.CT, 1, 0, 2, 0, 3, 0, 4, 0, A.SORT_SEQ) AS SORT_SEQ 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', A.PRE_COMP_FORMULAR) AS PRE_COMP_FORMULAR 
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.PRE_BGT_AMT, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.PRE_BGT_AMT, 0), 3, DECODE(A.COMPO_LEVEL, '1', A.PRE_BGT_AMT, 0), 4, DECODE(A.COMPO_LEVEL, '1', A.PRE_BGT_AMT, 0), A.PRE_BGT_AMT)) AS PRE_BGT_AMT
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', A.PRE_FORMULAR) AS PRE_FORMULAR
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.PRE_AMT, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.PRE_AMT, 0), 3, DECODE(A.COMPO_LEVEL, '1', A.PRE_AMT, 0), 4, DECODE(A.COMPO_LEVEL, '1', A.PRE_AMT, 0), A.PRE_AMT)) AS PRE_AMT
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', E.REFLECT_FG) AS REFLECT_FG 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', E.DEMAND_CONT) AS DEMAND_CONT 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', E.EXAM_CONT) AS EXAM_CONT 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', E.SRCH_VAL) AS SRCH_VAL
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CNT, 0), 2, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CNT, 0), 3, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CNT, 0), 4, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CNT, 0), E.STAFF_CNT)) AS STAFF_CNT
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CURR_CNT, 0), 2, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CURR_CNT, 0), 3, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CURR_CNT, 0), 4, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CURR_CNT, 0), E.STAFF_CURR_CNT)) AS STAFF_CURR_CNT
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', E.DRIVER_CNT, 0), 2, DECODE(A.COMPO_LEVEL, '1', E.DRIVER_CNT, 0), 3, DECODE(A.COMPO_LEVEL, '1', E.DRIVER_CNT, 0), 4, DECODE(A.COMPO_LEVEL, '1', E.DRIVER_CNT, 0), E.DRIVER_CNT)) AS DRIVER_CNT
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', E.ETC_CNT, 0), 2, DECODE(A.COMPO_LEVEL, '1', E.ETC_CNT, 0), 3, DECODE(A.COMPO_LEVEL, '1', E.ETC_CNT, 0), 4, DECODE(A.COMPO_LEVEL, '1', E.ETC_CNT, 0), E.ETC_CNT)) AS ETC_CNT
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', NVL(E.EXP_FG, '020')) AS EXP_FG
                                  FROM TB_DGRCOMPO A
                                     , TB_DGRDEPT B
                                     , TB_DGRBIZ C
                                     , TB_YEARFISFG D
                                     , TB_REPORT040 E
                                     , (SELECT ROWNUM AS CT FROM TB_COMMCD WHERE ROWNUM BETWEEN 1 AND 5) H
                                 WHERE 1 = 1
                                 <isEqual prepend="" property="userDeptYn" compareValue="Y">
                                   AND EXISTS (SELECT 1
                                                 FROM TB_USERDEPT Z
                                                WHERE Z.USER_ID = #userId#
                                                  AND Z.DEPT_CD = B.DEPT_CD
                                                  AND Z.USE_YN = 'Y'
                                                  AND ROWNUM = 1
                                              )
                                 </isEqual>
                                   AND D.FIS_YEAR = C.FIS_YEAR
                                   AND D.FIS_FG_CD = C.FIS_FG_CD
                                   AND C.FIS_YEAR = A.FIS_YEAR
                                   AND C.BGT_DGR = A.BGT_DGR
                                   AND C.DBIZ_CD = A.DBIZ_CD
                                   AND B.FIS_YEAR = A.FIS_YEAR
                                   AND B.BGT_DGR = A.BGT_DGR
                                   AND B.DEPT_CD = A.DEPT_CD
                                   AND A.FIS_YEAR = E.FIS_YEAR
                                   AND A.BGT_DGR = E.BGT_DGR
                                   AND A.TE_BGT_COMPO_ID = E.TE_BGT_COMPO_ID
                                   AND (A.CNG_TYPE IS NULL OR A.CNG_TYPE = 'CH02' OR (A.CNG_TYPE = 'CH01' AND A.GRP_LVL != '2'))
                                   AND E.REPORT_CD = #reportCd#
                                   AND E.REPORT_DETL_CD = #reportDetlCd#
                                   AND E.FIS_YEAR = #fisYear#
                                   AND E.BGT_DGR = #bgtDgr#
                                 <isNotEmpty prepend="" property="fisFgMstCd">
                                   AND D.FIS_FG_MST_CD = #fisFgMstCd#
                                 </isNotEmpty>
                                 <isNotEmpty prepend="" property="fisFgCd">
                                   AND D.FIS_FG_CD = #fisFgCd#
                                 </isNotEmpty>
                                 <isNotEmpty prepend="" property="srchVal">
                                   AND E.SRCH_VAL LIKE '%' || #srchVal# || '%'
                                 </isNotEmpty>
                                 <isNotEmpty prepend="" property="officeCd">
                                   AND B.OFFICE_CD = #officeCd#
                                 </isNotEmpty>
                                 <isNotEmpty prepend="" property="deptRankFr">
                                   AND B.DEPT_RANK <![CDATA[>=]]> #deptRankFr#
                                 </isNotEmpty>
                                 <isNotEmpty prepend="" property="deptRankTo">
                                   AND B.DEPT_RANK <![CDATA[<=]]> #deptRankTo#
                                 </isNotEmpty>
                                 <isEqual prepend="" property="frscFrCdYn" compareValue="Y">
                                   AND EXISTS (SELECT 1
                                                 FROM TB_DGRCOMPOFRSC Z
                                                WHERE 1 = 1
                                                  AND Z.FIS_YEAR = A.FIS_YEAR
                                                  AND Z.BGT_DGR = A.BGT_DGR
                                                  AND Z.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID
                                                  AND Z.ADJ_DEF_FRSC_AMT <![CDATA[<>]]> 0                                                      
                                                <isNotEmpty prepend="" property="frscFgCdFr">
                                                  AND Z.FRSC_FG_CD <![CDATA[>=]]> #frscFgCdFr#
                                                </isNotEmpty>                                                      
                                                <isNotEmpty prepend="" property="frscFgCdTo">
                                                  AND Z.FRSC_FG_CD <![CDATA[<=]]> #frscFgCdTo#
                                                </isNotEmpty>
                                              )
                                 </isEqual>
                                 GROUP BY DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000' 
                                                     , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                     , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000'
                                                     , 4, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || '00000000000'
                                                     , 5, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || A.TE_BGT_COMPO_ID)
                               ) T
                       ) A
               ) T
         WHERE 1 = 1
         ORDER BY T.FIS_YEAR
                , NVL(T.BGT_DGR, 0)
                , NVL(T.OFFICE_RANK, 0)
                , NVL(T.OFFICE_CD, '0000')
                , NVL(T.DEPT_RANK, 0)
                , NVL(T.DEPT_CD, '0000000')
                , NVL(T.PBIZ_RANK, 0)
                , NVL(T.PBIZ_CD, '0000000000000000')
                , NVL(T.UBIZ_RANK, 0)
                , NVL(T.UBIZ_CD, '0000000000000000')
                , NVL(T.DBIZ_RANK, 0)
                , NVL(T.DBIZ_CD, '0000000000000000')
                , NVL(T.SORT_SEQ, 0)
    </select>
    
    <select id="ReportWrite040.selectReport040ExcelList" parameterClass="Map" resultClass="egovMap" >
        /*ReportWrite040.selectReport040ExcelList*/
        SELECT T.DGRCOMPO_ID AS DGRCOMPO_ID
             , T.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
             , CAST(T.DGR_LEVEL AS NUMERIC(5, 0)) AS DGR_LEVEL
             , T.REPORT_DETL_CD AS REPORT_DETL_CD
             , TRIM(CASE WHEN T.DGR_LEVEL = 0 THEN '합계'
                         WHEN T.DGR_LEVEL = 1 THEN T.OFFICE_NM
                         WHEN T.DGR_LEVEL = 2 THEN T.DEPT_NM
                         WHEN T.DGR_LEVEL = 3 THEN T.DBIZ_NM
                         WHEN T.DGR_LEVEL > 3 THEN LAVEL_SYMBOL || T.COMP_GROUND
                         ELSE ''
                    END) AS DGRCOMPO_NM
             , T.DEMAND_COMP_FORMULAR AS DEMAND_COMP_FORMULAR
             , CAST((T.DEMAND_DIFF_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DEMAND_BGT_AMT
             , T.COMP_FORMULAR AS COMP_FORMULAR
             , CAST((T.DIFF_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS BGT_AMT
             , T.PRE_COMP_FORMULAR AS PRE_COMP_FORMULAR
             , CAST((T.PRE_BGT_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_BGT_AMT
             , T.PRE_FORMULAR AS PRE_FORMULAR
             , CAST((T.PRE_AMT/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS PRE_AMT
             , CAST(((T.DIFF_AMT - T.PRE_BGT_AMT)/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT
             , T.REFLECT_FG_NM AS REFLECT_FG_NM
             , T.DEMAND_CONT AS DEMAND_CONT
             , T.EXAM_CONT AS EXAM_CONT
             , T.SRCH_VAL AS SRCH_VAL
             , T.EXCEPT_CNT AS EXCEPT_CNT
             , T.COMPO_CNT AS COMPO_CNT
             , T.STAFF_CNT AS STAFF_CNT
             , T.STAFF_CURR_CNT AS STAFF_CURR_CNT
             , T.DRIVER_CNT AS DRIVER_CNT
             , T.ETC_CNT AS ETC_CNT
             , DECODE(T.DGR_LEVEL, 4, T.SRCH_VAL, '') AS SRCH_VAL
          FROM (SELECT A.DGRCOMPO_ID AS DGRCOMPO_ID
                     , A.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
                     , A.DGR_LEVEL AS DGR_LEVEL
                     , A.FIS_YEAR AS FIS_YEAR
                     , A.BGT_DGR AS BGT_DGR
                     , A.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
                     , A.REPORT_CD AS REPORT_CD
                     , A.REPORT_DETL_CD AS REPORT_DETL_CD
                     , A.OFFICE_CD AS OFFICE_CD
                     , A.DEPT_CD AS DEPT_CD
                     , A.DBIZ_CD AS DBIZ_CD
                     , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                     , A.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
                     , A.DEMAND_COMP_FORMULAR AS DEMAND_COMP_FORMULAR
                     , A.DEMAND_DIFF_AMT AS DEMAND_DIFF_AMT
                     , A.COMPO_LEVEL AS COMPO_LEVEL
                     , A.COMP_GROUND AS COMP_GROUND
                     , A.COMP_FORMULAR AS COMP_FORMULAR
                     , A.DIFF_AMT AS DIFF_AMT
                     , A.SORT_SEQ AS SORT_SEQ
                     , A.PRE_COMP_FORMULAR AS PRE_COMP_FORMULAR
                     , A.PRE_BGT_AMT AS PRE_BGT_AMT
                     , A.PRE_FORMULAR AS PRE_FORMULAR
                     , A.PRE_AMT AS PRE_AMT
                     , A.REFLECT_FG AS REFLECT_FG
                     , A.DEMAND_CONT AS DEMAND_CONT
                     , A.EXAM_CONT AS EXAM_CONT
                     , A.SRCH_VAL AS SRCH_VAL
                     , A.DRIVER_CNT + A.ETC_CNT AS EXCEPT_CNT
                     , A.STAFF_CNT - (A.DRIVER_CNT + A.ETC_CNT) AS COMPO_CNT
                     , A.STAFF_CNT AS STAFF_CNT
                     , A.STAFF_CURR_CNT AS STAFF_CURR_CNT
                     , A.DRIVER_CNT AS DRIVER_CNT
                     , A.ETC_CNT AS ETC_CNT
                     , NVL((SELECT Z.DETL_CD_NM FROM TB_COMMCDDETL Z WHERE Z.CL_CD = 'RP002' AND Z.DETL_CD = A.REPORT_DETL_CD AND ROWNUM = 1), '') AS REPORT_DETL_NM
                     , NVL((SELECT Z.DETL_CD_NM FROM TB_COMMCDDETL Z WHERE Z.CL_CD = 'RP003' AND Z.DETL_CD = A.REFLECT_FG AND ROWNUM = 1), '') AS REFLECT_FG_NM
                     , NVL((SELECT Z.OFFICE_RANK FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.OFFICE_CD = A.OFFICE_CD AND ROWNUM = 1), 0) AS OFFICE_RANK
                     , NVL((SELECT Z.OFFICE_NM FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.OFFICE_CD = A.OFFICE_CD AND ROWNUM = 1), '') AS OFFICE_NM
                     , NVL((SELECT Z.DEPT_RANK FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DEPT_CD = A.DEPT_CD AND ROWNUM = 1), 0) AS DEPT_RANK
                     , NVL((SELECT Z.DEPT_NM FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DEPT_CD = A.DEPT_CD AND ROWNUM = 1), '') AS DEPT_NM
                     , NVL((SELECT Z.PBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS PBIZ_RANK
                     , NVL((SELECT Z.PBIZ_CD FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS PBIZ_CD
                     , NVL((SELECT Z.UBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS UBIZ_RANK
                     , NVL((SELECT Z.UBIZ_CD FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS UBIZ_CD
                     , NVL((SELECT Z.DBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS DBIZ_RANK
                     , NVL((SELECT Z.DBIZ_NM FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS DBIZ_NM
                     , NVL((SELECT COUNT(*) FROM TB_DGRCOMPO Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.UP_TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID), 0) AS CHILD_CNT
                     , NVL((SELECT Z.SYMBOL FROM TB_DGRCOMPOSYMBOL Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.COMPO_LEVEL = A.COMPO_LEVEL AND SYMBOL_LENGTH > 0), '') AS LAVEL_SYMBOL
                  FROM (
                        SELECT T.*
                          FROM (SELECT DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000' 
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 4, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || '00000000000'
                                                  , 5, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || A.TE_BGT_COMPO_ID) AS DGRCOMPO_ID
                                     , DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || '000' || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000' 
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 4, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000'
                                                  , 5, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || A.UP_TE_BGT_COMPO_ID) AS UP_DGRCOMPO_ID
                                     , DECODE(H.CT, 1, 0, 2, 1, 3, 2, 4, 3, 3 + A.COMPO_LEVEL) AS DGR_LEVEL
                                     , A.FIS_YEAR AS FIS_YEAR
                                     , A.BGT_DGR AS BGT_DGR
                                     , E.REPORT_CD AS REPORT_CD
                                     , E.REPORT_DETL_CD AS REPORT_DETL_CD
                                     , DECODE(H.CT, 1, '00000000000', 2, '00000000000', 3, '00000000000', 4, '00000000000', A.TE_BGT_COMPO_ID) AS TE_BGT_COMPO_ID 
                                     , DECODE(H.CT, 1, '0000', B.OFFICE_CD) AS OFFICE_CD
                                     , DECODE(H.CT, 1, '0000000', 2, '0000000', A.DEPT_CD) AS DEPT_CD
                                     , DECODE(H.CT, 1, '0000000000000000', 2, '0000000000000000', 3, '0000000000000000', C.DBIZ_CD) AS DBIZ_CD 
                                     , DECODE(H.CT, 1, '00000', 2, '00000', 3, '00000', 4, '00000', A.TE_MNG_MOK_CD) AS TE_MNG_MOK_CD 
                                     , DECODE(H.CT, 1, 0, 2, 0, 3, 0, 4, 0, A.TE_BGT_COMPO_SEQ) AS TE_BGT_COMPO_SEQ 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', A.DEMAND_COMP_FORMULAR) AS DEMAND_COMP_FORMULAR 
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DEMAND_DIFF_AMT, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DEMAND_DIFF_AMT, 0), 3, DECODE(A.COMPO_LEVEL, '1', A.DEMAND_DIFF_AMT, 0), 4, DECODE(A.COMPO_LEVEL, '1', A.DEMAND_DIFF_AMT, 0), A.DEMAND_DIFF_AMT)) AS DEMAND_DIFF_AMT
                                     , DECODE(H.CT, 1, 0, 2, 0, 3, 0, 4, 0, A.COMPO_LEVEL) AS COMPO_LEVEL 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', A.COMP_GROUND) AS COMP_GROUND 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', A.COMP_FORMULAR) AS COMP_FORMULAR 
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DIFF_AMT, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DIFF_AMT, 0), 3, DECODE(A.COMPO_LEVEL, '1', A.DIFF_AMT, 0), 4, DECODE(A.COMPO_LEVEL, '1', A.DIFF_AMT, 0), A.DIFF_AMT)) AS DIFF_AMT
                                     , DECODE(H.CT, 1, 0, 2, 0, 3, 0, 4, 0, A.SORT_SEQ) AS SORT_SEQ 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', A.PRE_COMP_FORMULAR) AS PRE_COMP_FORMULAR 
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.PRE_BGT_AMT, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.PRE_BGT_AMT, 0), 3, DECODE(A.COMPO_LEVEL, '1', A.PRE_BGT_AMT, 0), 4, DECODE(A.COMPO_LEVEL, '1', A.PRE_BGT_AMT, 0), A.PRE_BGT_AMT)) AS PRE_BGT_AMT
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', A.PRE_FORMULAR) AS PRE_FORMULAR
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.PRE_AMT, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.PRE_AMT, 0), 3, DECODE(A.COMPO_LEVEL, '1', A.PRE_AMT, 0), 4, DECODE(A.COMPO_LEVEL, '1', A.PRE_AMT, 0), A.PRE_AMT)) AS PRE_AMT
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', E.REFLECT_FG) AS REFLECT_FG 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', E.DEMAND_CONT) AS DEMAND_CONT 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', E.EXAM_CONT) AS EXAM_CONT 
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', E.SRCH_VAL) AS SRCH_VAL
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CNT, 0), 2, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CNT, 0), 3, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CNT, 0), 4, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CNT, 0), E.STAFF_CNT)) AS STAFF_CNT
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CURR_CNT, 0), 2, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CURR_CNT, 0), 3, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CURR_CNT, 0), 4, DECODE(A.COMPO_LEVEL, '1', E.STAFF_CURR_CNT, 0), E.STAFF_CURR_CNT)) AS STAFF_CURR_CNT
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', E.DRIVER_CNT, 0), 2, DECODE(A.COMPO_LEVEL, '1', E.DRIVER_CNT, 0), 3, DECODE(A.COMPO_LEVEL, '1', E.DRIVER_CNT, 0), 4, DECODE(A.COMPO_LEVEL, '1', E.DRIVER_CNT, 0), E.DRIVER_CNT)) AS DRIVER_CNT
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', E.ETC_CNT, 0), 2, DECODE(A.COMPO_LEVEL, '1', E.ETC_CNT, 0), 3, DECODE(A.COMPO_LEVEL, '1', E.ETC_CNT, 0), 4, DECODE(A.COMPO_LEVEL, '1', E.ETC_CNT, 0), E.ETC_CNT)) AS ETC_CNT
                                     , DECODE(H.CT, 1, '', 2, '', 3, '', 4, '', NVL(E.EXP_FG, '020')) AS EXP_FG
                                  FROM TB_DGRCOMPO A
                                     , TB_DGRDEPT B
                                     , TB_DGRBIZ C
                                     , TB_YEARFISFG D
                                     , TB_REPORT040 E
                                     , (SELECT ROWNUM AS CT FROM TB_COMMCD WHERE ROWNUM BETWEEN 1 AND 5) H
                                 WHERE 1 = 1
                                 <isEqual prepend="" property="userDeptYn" compareValue="Y">
                                   AND EXISTS (SELECT 1
                                                 FROM TB_USERDEPT Z
                                                WHERE Z.USER_ID = #userId#
                                                  AND Z.DEPT_CD = B.DEPT_CD
                                                  AND Z.USE_YN = 'Y'
                                                  AND ROWNUM = 1
                                              )
                                 </isEqual>
                                   AND D.FIS_YEAR = C.FIS_YEAR
                                   AND D.FIS_FG_CD = C.FIS_FG_CD
                                   AND C.FIS_YEAR = A.FIS_YEAR
                                   AND C.BGT_DGR = A.BGT_DGR
                                   AND C.DBIZ_CD = A.DBIZ_CD
                                   AND B.FIS_YEAR = A.FIS_YEAR
                                   AND B.BGT_DGR = A.BGT_DGR
                                   AND B.DEPT_CD = A.DEPT_CD
                                   AND A.FIS_YEAR = E.FIS_YEAR
                                   AND A.BGT_DGR = E.BGT_DGR
                                   AND A.TE_BGT_COMPO_ID = E.TE_BGT_COMPO_ID
                                   AND E.REPORT_CD = #reportCd#
                                 <isNotEmpty prepend="" property="reportDetlCd">
                                   AND E.REPORT_DETL_CD = #reportDetlCd#
                                 </isNotEmpty>
                                   AND E.FIS_YEAR = #fisYear#
                                   AND E.BGT_DGR = #bgtDgr#
                                 <isNotEmpty prepend="" property="fisFgMstCd">
                                   AND D.FIS_FG_MST_CD = #fisFgMstCd#
                                 </isNotEmpty>
                                 <isNotEmpty prepend="" property="fisFgCd">
                                   AND D.FIS_FG_CD = #fisFgCd#
                                 </isNotEmpty>
                                 <isNotEmpty prepend="" property="srchVal">
                                   AND E.SRCH_VAL LIKE '%' || #srchVal# || '%'
                                 </isNotEmpty>
                                 <isNotEmpty prepend="" property="officeCd">
                                   AND B.OFFICE_CD = #officeCd#
                                 </isNotEmpty>
                                 <isNotEmpty prepend="" property="deptRankFr">
                                   AND B.DEPT_RANK <![CDATA[>=]]> #deptRankFr#
                                 </isNotEmpty>
                                 <isNotEmpty prepend="" property="deptRankTo">
                                   AND B.DEPT_RANK <![CDATA[<=]]> #deptRankTo#
                                 </isNotEmpty>
                                 <isEqual prepend="" property="frscFrCdYn" compareValue="Y">
                                   AND EXISTS (SELECT 1
                                                 FROM TB_DGRCOMPOFRSC Z
                                                WHERE 1 = 1
                                                  AND Z.FIS_YEAR = A.FIS_YEAR
                                                  AND Z.BGT_DGR = A.BGT_DGR
                                                  AND Z.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID
                                                  AND Z.ADJ_DEF_FRSC_AMT <![CDATA[<>]]> 0                                                      
                                                <isNotEmpty prepend="" property="frscFgCdFr">
                                                  AND Z.FRSC_FG_CD <![CDATA[>=]]> #frscFgCdFr#
                                                </isNotEmpty>                                                      
                                                <isNotEmpty prepend="" property="frscFgCdTo">
                                                  AND Z.FRSC_FG_CD <![CDATA[<=]]> #frscFgCdTo#
                                                </isNotEmpty>
                                              )
                                 </isEqual>
                                 GROUP BY DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || '0000' || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000' 
                                                     , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || '0000000' || '_' || '0000000000000000' || '_' || '00000000000'
                                                     , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || '0000000000000000' || '_' || '00000000000'
                                                     , 4, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || '00000000000'
                                                     , 5, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || E.REPORT_DETL_CD || '_' || B.OFFICE_CD || '_' || A.DEPT_CD || '_' || C.DBIZ_CD || '_' || A.TE_BGT_COMPO_ID)
                               ) T
                       ) A
               ) T
         WHERE 1 = 1
         ORDER BY T.FIS_YEAR
                , NVL(T.BGT_DGR, 0)
                , T.REPORT_DETL_CD
                , NVL(T.OFFICE_RANK, 0)
                , NVL(T.OFFICE_CD, '0000')
                , NVL(T.DEPT_RANK, 0)
                , NVL(T.DEPT_CD, '0000000')
                , NVL(T.PBIZ_RANK, 0)
                , NVL(T.PBIZ_CD, '0000000000000000')
                , NVL(T.UBIZ_RANK, 0)
                , NVL(T.UBIZ_CD, '0000000000000000')
                , NVL(T.DBIZ_RANK, 0)
                , NVL(T.DBIZ_CD, '0000000000000000')
                , NVL(T.TE_MNG_MOK_CD, '00000')
                , NVL(T.SORT_SEQ, 0)
    </select>
    
    <update id="ReportWrite040.updateReport040" parameterClass="Map" >
        /*ReportWrite040.updateReport040*/
        UPDATE TB_REPORT040
           SET REFLECT_FG = #reflectFg#
             , DEMAND_CONT = #demandCont#
             , EXAM_CONT = #examCont#
             , STAFF_CNT = NVL(#staffCnt#, 0)
             , STAFF_CURR_CNT = NVL(#staffCurrCnt#, 0)
             , DRIVER_CNT = NVL(#driverCnt#, 0)
             , ETC_CNT = NVL(#etcCnt#, 0)
             , EXP_FG = NVL(#expFg#, '020')
             , MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
</sqlMap>
