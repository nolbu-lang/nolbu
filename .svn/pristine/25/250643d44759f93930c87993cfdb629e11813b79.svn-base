    private static final Logger logger = Logger.getLogger(ReportWrite0F0Controller.class);
    
    @Resource(name = "reportWrite0F0Service")
    private ReportWrite0F0Service reportWrite0F0Service;

    @Resource(name = "bcjisMessageSource")
    private BcjisMessageSource bcjisMessageSource;
    
    @Resource(name = "report0F0SaveFile")
