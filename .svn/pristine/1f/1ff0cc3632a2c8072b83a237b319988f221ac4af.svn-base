<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://www.ibatis.com/dtd/sql-map-2.dtd">

<sqlMap namespace="DialogManageUserModify">

    <typeAlias alias="egovMap" type="egovframework.rte.psl.dataaccess.util.EgovMap"/>    
       
    <update id="DialogManageUserModify.updateDialogManageUser" parameterClass="Map" >
        /*DialogManageUserModify.updateDialogManageUser*/
        UPDATE TB_USER 
           SET USER_NM = #userNm#
             , PSWD = DECODE(#userPass#, NULL, PSWD, '', PSWD, #userPass#)
             , MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
         WHERE USER_ID = #modifyuserId#
    </update>
    
    <update id="DialogManageUserModify.updateDialogManageUserPowgrp" parameterClass="Map" >
        /*DialogManageUserModify.updateDialogManageUser*/
        UPDATE TB_USERPOWGRP 
           SET POW_GR_CD = #powGrCd#
             , MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
         WHERE USER_ID = #modifyuserId#
    </update>
</sqlMap>
