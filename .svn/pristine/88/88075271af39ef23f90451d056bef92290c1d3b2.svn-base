    </update>
    
    <!-- TB_REPORT070 -->
    <insert id="ReportComm.insertReport070" parameterClass="Map" >
        /*ReportComm.insertReport070*/
        INSERT 
          INTO TB_REPORT070(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , ORDER_YMD_SEQ
             , TE_BGT_COMPO_ID
             , TE_BGT_COMPO_SEQ
             , REFLECT_FG
             , DEMAND_CONT
             , EXAM_CONT
             , CONSIDER_AMT1
             , CONSIDER_AMT2
             , CONSIDER_AMT3
             , CONSIDER_AMT4
             , CONSIDER_AMT5
             , CONSIDER_AMT6
             , REPORT_SORT_SEQ
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        SELECT T.REPORT_CD
             , T.REPORT_DETL_CD
             , T.FIS_YEAR
             , T.BGT_DGR
             , CAST(#orderYmdSeq# AS INTEGER) AS ORDER_YMD_SEQ
             , T.TE_BGT_COMPO_ID
             , T.TE_BGT_COMPO_SEQ
             , T.REFLECT_FG
             , T.DEMAND_CONT
             , T.EXAM_CONT
             , T.CONSIDER_AMT1
             , T.CONSIDER_AMT2
             , T.CONSIDER_AMT3
             , T.CONSIDER_AMT4
             , T.CONSIDER_AMT5
             , T.CONSIDER_AMT6
             , T.REPORT_SORT_SEQ
             , CAST(#userId# AS VARCHAR(20)) AS REGI_ID
             , SYSTIMESTAMP
             , CAST(#userId# AS VARCHAR(20)) AS MODI_ID
             , SYSTIMESTAMP
          FROM (SELECT CAST('070' AS VARCHAR(5)) AS REPORT_CD
                     , CAST('071' AS VARCHAR(5)) AS REPORT_DETL_CD
                     , A.FIS_YEAR
                     , A.BGT_DGR
                     , -10 AS ORDER_YMD_SEQ
                     , A.TE_BGT_COMPO_ID
                     , A.TE_BGT_COMPO_SEQ
                     , '' AS REFLECT_FG
                     , '' AS DEMAND_CONT
                     , '' AS EXAM_CONT
                     , NVL(#considerAmt1#, '0') AS CONSIDER_AMT1
                     , NVL(#considerAmt2#, '0') AS CONSIDER_AMT2
                     , NVL(#considerAmt3#, '0') AS CONSIDER_AMT3
                     , NVL(#considerAmt4#, '0') AS CONSIDER_AMT4
                     , NVL(#considerAmt5#, '0') AS CONSIDER_AMT5
                     , NVL(#considerAmt6#, '0') AS CONSIDER_AMT6
                     , CAST(NVL(#reportSortSeq#, '') AS VARCHAR(10)) AS REPORT_SORT_SEQ
                  FROM TB_DGRCOMPO A
                 WHERE 1 = 1
                   AND A.FIS_YEAR = #fisYear#
                   AND A.BGT_DGR = #bgtDgr#
                   AND A.TE_BGT_COMPO_ID = #teBgtCompoId#
                UNION ALL
                SELECT CAST('070' AS VARCHAR(5)) AS REPORT_CD
                     , CAST('071' AS VARCHAR(5)) AS REPORT_DETL_CD
                     , A.FIS_YEAR
                     , A.BGT_DGR
                     , -1 AS ORDER_YMD_SEQ
                     , A.TE_BGT_COMPO_ID
                     , A.TE_BGT_COMPO_SEQ
                     , A.REFLECT_FG
                     , A.DEMAND_CONT
                     , A.EXAM_CONT
                     , NVL(#considerAmt1#, '0') AS CONSIDER_AMT1
                     , NVL(#considerAmt2#, '0') AS CONSIDER_AMT2
                     , NVL(#considerAmt3#, '0') AS CONSIDER_AMT3
                     , NVL(#considerAmt4#, '0') AS CONSIDER_AMT4
                     , NVL(#considerAmt5#, '0') AS CONSIDER_AMT5
                     , NVL(#considerAmt6#, '0') AS CONSIDER_AMT6
                     , CAST(NVL(#reportSortSeq#, '') AS VARCHAR(10)) AS REPORT_SORT_SEQ
                  FROM TB_REPORT010 A
                 WHERE 1 = 1
                   AND A.REPORT_CD = '010' 
                   AND A.REPORT_DETL_CD = '011'
                   AND A.FIS_YEAR = #fisYear#
                   AND A.BGT_DGR = #bgtDgr#
                   AND A.TE_BGT_COMPO_ID = #teBgtCompoId#
                UNION ALL
                SELECT A.REPORT_CD
                     , A.REPORT_DETL_CD
                     , A.FIS_YEAR
                     , A.BGT_DGR
                     , A.ORDER_YMD_SEQ AS ORDER_YMD_SEQ
                     , A.TE_BGT_COMPO_ID
                     , A.TE_BGT_COMPO_SEQ
                     , A.REFLECT_FG
                     , A.DEMAND_CONT
                     , A.EXAM_CONT
                     , A.CONSIDER_AMT1
                     , A.CONSIDER_AMT2
                     , A.CONSIDER_AMT3
                     , A.CONSIDER_AMT4
                     , A.CONSIDER_AMT5
                     , A.CONSIDER_AMT6
                     , A.REPORT_SORT_SEQ
                 FROM TB_REPORT070 A    
                 WHERE 1 = 1
                   AND A.REPORT_CD = #reportCd#
                   AND A.REPORT_DETL_CD = #reportDetlCd#
                   AND A.FIS_YEAR = #fisYear#
                   AND A.BGT_DGR = #bgtDgr#
                   AND A.TE_BGT_COMPO_ID = #teBgtCompoId#
               ) T
         GROUP BY T.REPORT_CD
                , T.REPORT_DETL_CD
                , T.FIS_YEAR
                , T.BGT_DGR
                , T.TE_BGT_COMPO_ID HAVING MAX(T.ORDER_YMD_SEQ)
    </insert>
    
    <insert id="ReportComm.insertReport070s" parameterClass="Map" >
        /*ReportComm.insertReport070s*/
        INSERT 
          INTO TB_REPORT(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , TE_BGT_COMPO_ID
             , TE_BGT_COMPO_SEQ
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        SELECT A.REPORT_CD
             , A.REPORT_DETL_CD
             , A.FIS_YEAR
             , A.BGT_DGR
             , A.TE_BGT_COMPO_ID
             , A.TE_BGT_COMPO_SEQ
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP
          FROM TB_REPORT070 A
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
         GROUP BY A.REPORT_CD
                , A.REPORT_DETL_CD
                , A.FIS_YEAR
                , A.BGT_DGR
                , A.TE_BGT_COMPO_ID
                , A.TE_BGT_COMPO_SEQ
    </insert>
    
    <delete id="ReportComm.deleteReport070" parameterClass="Map" >
        /*ReportComm.deleteReport070*/
        DELETE
          FROM TB_REPORT070
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
           AND ORDER_YMD_SEQ = #orderYmdSeq#
    </delete>
    
    <update id="ReportComm.copyReport070" parameterClass="Map" >
        /*ReportComm.copyReport070*/
        UPDATE TB_REPORT070
           SET (REFLECT_FG, DEMAND_CONT, EXAM_CONT
               , CONSIDER_AMT1
               , CONSIDER_AMT2
               , CONSIDER_AMT3
               , CONSIDER_AMT4
               , CONSIDER_AMT5
               , CONSIDER_AMT6
               , REPORT_SORT_SEQ)
             = (SELECT REFLECT_FG, DEMAND_CONT, EXAM_CONT
               , CONSIDER_AMT1
               , CONSIDER_AMT2
               , CONSIDER_AMT3
               , CONSIDER_AMT4
               , CONSIDER_AMT5
               , CONSIDER_AMT6
               , REPORT_SORT_SEQ
                  FROM TB_REPORT070
                 WHERE 1 = 1
                   AND REPORT_CD = #srcReportCd#
                   AND REPORT_DETL_CD = #srcReportDetlCd#
                   AND FIS_YEAR = #srcFisYear#
                   AND BGT_DGR = #srcBgtDgr#
                   AND TE_BGT_COMPO_ID = #srcTeBgtCompoId#
                   AND ORDER_YMD_SEQ = #srcOrderYmdSeq#
                 )
             , MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
