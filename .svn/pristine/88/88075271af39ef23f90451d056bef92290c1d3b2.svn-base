    <!-- TB_REPORT0B0 -->
    <insert id="ReportComm.insertReport0B0" parameterClass="Map" >
        /*ReportComm.insertReport0B0*/
        INSERT 
          INTO TB_REPORT0B0(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , TE_BGT_COMPO_ID
             , TE_BGT_COMPO_SEQ
             , REFLECT_FG
             , DEMAND_CONT
             , EXAM_CONT
             , SRCH_VAL
             , BIZ_NM
             , BIZ_AMOUNT
             , BIZ_PERIOD
             , TOT_BIZ_AMT
             , PRE_BIZ_AMT 
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        VALUES (#reportCd#
             , #reportDetlCd#
             , #fisYear#
             , #bgtDgr#
             , #teBgtCompoId#
             , #teBgtCompoSeq#
             , NVL(#reflectFg#, '')
             , NVL(#demandCont#, '')
             , NVL(#examCont#, '')
             , NVL(#srchVal#, '')
             , NVL(#bizNm#, (SELECT Z.COMP_GROUND 
                               FROM TB_DGRCOMPO Z 
                              WHERE Z.FIS_YEAR = #fisYear# 
                                AND Z.BGT_DGR = #bgtDgr# 
                                AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#
                                AND ROWNUM = 1
                             )
               )
             , NVL(#bizAmount#, '')
             , NVL(#bizPeriod#, '')
             , NVL(#totbizAmt#, 0)
             , NVL(#prebizAmt#, 0)
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP)
    </insert>
    
