    <!-- TB_REPORT080 -->
    <insert id="ReportComm.insertReport080" parameterClass="Map" >
        /*ReportComm.insertReport080*/
        INSERT 
          INTO TB_REPORT080(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , TE_BGT_COMPO_ID
             , TE_BGT_COMPO_SEQ
             , REFLECT_FG
             , DEMAND_CONT
             , EXAM_CONT
             , IMPORT_PERSON_NM
             , TOT_BIZ_AMT
             , PRE_BIZ_AMT
             , ADD_DEMAND_AMT
             , REFLECT_AMT
             , REPORT_SORT_SEQ
             , REPORT_MSTR
             , GOV_SUB
             , INDI_ATTR
             , ADVNC_PROC
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        VALUES (#reportCd#
             , #reportDetlCd#
             , #fisYear#
             , #bgtDgr#
             , #teBgtCompoId#
             , #teBgtCompoSeq#
             , NVL((SELECT Z.REFLECT_FG FROM TB_REPORT010 Z WHERE Z.REPORT_CD = '010' AND Z.REPORT_DETL_CD = '011' AND Z.FIS_YEAR = #fisYear# AND Z.BGT_DGR = #bgtDgr# AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#)
                    , NVL((SELECT MAX(Z.REFLECT_FG) FROM TB_REPORT020 Z WHERE Z.REPORT_CD = '020' AND Z.FIS_YEAR = #fisYear# AND Z.BGT_DGR = #bgtDgr# AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#)
                           , '')
               )
             , NVL((SELECT Z.DEMAND_CONT FROM TB_REPORT010 Z WHERE Z.REPORT_CD = '010' AND Z.REPORT_DETL_CD = '011' AND Z.FIS_YEAR = #fisYear# AND Z.BGT_DGR = #bgtDgr# AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#)
                    , NVL((SELECT MAX(Z.DEMAND_CONT) FROM TB_REPORT020 Z WHERE Z.REPORT_CD = '020' AND Z.FIS_YEAR = #fisYear# AND Z.BGT_DGR = #bgtDgr# AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#)
                           , '')
               )
             , NVL((SELECT Z.EXAM_CONT FROM TB_REPORT010 Z WHERE Z.REPORT_CD = '010' AND Z.REPORT_DETL_CD = '011' AND Z.FIS_YEAR = #fisYear# AND Z.BGT_DGR = #bgtDgr# AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#)
                    , NVL((SELECT MAX(Z.EXAM_CONT) FROM TB_REPORT020 Z WHERE Z.REPORT_CD = '020' AND Z.FIS_YEAR = #fisYear# AND Z.BGT_DGR = #bgtDgr# AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#)
                           , '')
               )
             , NVL(#importPersonNm#, '')
             , NVL(#totBizAmt#, 0)
             , NVL(#preBizAmt#, 0)
             , NVL(#addDemandAmt#, 0)
             , NVL(#reflectAmt#, 0)
             , NVL(#reportSortSeq#, '')
             , NVL(#reportMstr#, '')
             , NVL(#govSub#, '')
             , NVL(#indiAttr#, '')
             , NVL(#advncProc#, '')
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP)
    </insert>
    
