             , #reportDetlCd#
             , #fisYear#
             , #bgtDgr#
             , #teBgtCompoId#
             , #teBgtCompoSeq#
             , NVL((SELECT Z.REFLECT_FG FROM TB_REPORT010 Z WHERE Z.REPORT_CD = '010' AND Z.REPORT_DETL_CD = '011' AND Z.FIS_YEAR = #fisYear# AND Z.BGT_DGR = #bgtDgr# AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#), '')
             , NVL((SELECT Z.DEMAND_CONT FROM TB_REPORT010 Z WHERE Z.REPORT_CD = '010' AND Z.REPORT_DETL_CD = '011' AND Z.FIS_YEAR = #fisYear# AND Z.BGT_DGR = #bgtDgr# AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#), '')
             , NVL((SELECT Z.EXAM_CONT FROM TB_REPORT010 Z WHERE Z.REPORT_CD = '010' AND Z.REPORT_DETL_CD = '011' AND Z.FIS_YEAR = #fisYear# AND Z.BGT_DGR = #bgtDgr# AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#), '')
             , NVL(#mayorReportYn#, 'Y')
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP)
    </insert>
    
    <delete id="ReportComm.deleteReport0D0" parameterClass="Map" >
        /*ReportComm.deleteReport0D0*/
        DELETE
          FROM TB_REPORT0D0
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </delete>
    
    <update id="ReportComm.copyReport0D0" parameterClass="Map" >
        /*ReportComm.copyReport0D0*/
        UPDATE TB_REPORT0D0
           SET (REFLECT_FG, DEMAND_CONT, EXAM_CONT, MAYOR_REPORT_YN)
             = (SELECT REFLECT_FG, DEMAND_CONT, EXAM_CONT, MAYOR_REPORT_YN
                  FROM TB_REPORT0D0
                 WHERE 1 = 1
                   AND REPORT_CD = #srcReportCd#
                   AND REPORT_DETL_CD = #srcReportDetlCd#
                   AND FIS_YEAR = #srcFisYear#
                   AND BGT_DGR = #srcBgtDgr#
                   AND TE_BGT_COMPO_ID = #srcTeBgtCompoId#
                 )
             , MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
    
    <update id="ReportComm.updateSrchValReport0D0" parameterClass="Map" >
        /*ReportComm.updateSrchValReport0D0*/
        UPDATE TB_REPORT0D0
           SET SRCH_VAL = #srchVal#
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
    
    <update id="ReportComm.updateMayorReportYnReport0D0" parameterClass="Map" >
        /*ReportComm.updateMayorReportYnReport0D0*/
        UPDATE TB_REPORT0D0
           SET MAYOR_REPORT_YN = NVL(#mayorReportYn#, 'Y')
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
</sqlMap>
