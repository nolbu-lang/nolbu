<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://www.ibatis.com/dtd/sql-map-2.dtd">

<sqlMap namespace="ReportComm">

    <typeAlias alias="egovMap" type="egovframework.rte.psl.dataaccess.util.EgovMap"/>
    
    <insert id="ReportComm.insertReport" parameterClass="Map" >
        /*ReportComm.insertReport*/
        INSERT 
          INTO TB_REPORT(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , TE_BGT_COMPO_ID
             , TE_BGT_COMPO_SEQ
             , REPORT_MSTR
             , GOV_SUB
             , INDI_ATTR
             , ADVNC_PROC
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        VALUES (#reportCd#
             , #reportDetlCd#
             , #fisYear#
             , #bgtDgr#
             , #teBgtCompoId#
             , #teBgtCompoSeq#
             , NVL(#reportMstr#, '')
             , NVL(#govSub#, '')
             , NVL(#indiAttr#, '')
             , NVL(#advncProc#, '')
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP)
    </insert> 
    
    <update id="ReportComm.updateReport" parameterClass="Map" >
        /*ReportComm.updateReport*/
        UPDATE TB_REPORT
           SET MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
             , REPORT_MSTR	=	#reportMstr#
           	 , GOV_SUB		=	#govSub#
           	 , INDI_ATTR	=	#indiAttr# 
           	 , ADVNC_PROC	=	#advncProc#
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
    
    <delete id="ReportComm.deleteReport" parameterClass="Map" >
        /*ReportComm.deleteReport*/
        DELETE
          FROM TB_REPORT
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
         <isNotEmpty prepend="" property="fisYear">
           AND FIS_YEAR = #fisYear#
         </isNotEmpty>
         <isNotEmpty prepend="" property="bgtDgr">
           AND BGT_DGR = #bgtDgr#
         </isNotEmpty>
         <isNotEmpty prepend="" property="teBgtCompoId">
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
         </isNotEmpty>
    </delete>
    
    <select id="ReportComm.selectReportInfo" parameterClass="Map" resultClass="egovMap" >
        /*ReportComm.selectReportInfo*/
        SELECT A.REPORT_CD
             , A.REPORT_DETL_CD
             , A.FIS_YEAR
             , A.BGT_DGR
             , A.REPORT_NM
             , A.SHEET_NM
             , A.PRINT_PAPER_SIZE
             , A.PRINT_SCALE
             , A.RIGHT_MARGIN
             , A.LEFT_MARGIN
             , A.TOP_MARGIN
             , A.BOTTOM_MARGIN
             , A.HEADER_MARGIN
             , A.FOOTER_MARGIN
             , A.ZOOM
             , NVL((SELECT Z.BGT_COMPO_FG
                      FROM TB_BGTDGR Z
                     WHERE 1 = 1
                       AND Z.FIS_YEAR = A.FIS_YEAR
                       AND Z.BGT_DGR = A.BGT_DGR
                       AND ROWNUM = 1)
               , '') AS BGT_COMPO_FG  
             , NVL((SELECT CASE WHEN Z.BGT_COMPO_FG = '10' THEN '본예산'
                                ELSE '추경' || ADD_TIMES || '차' 
                           END AS BGT_DGR_NM
                      FROM TB_BGTDGR Z
                     WHERE 1 = 1
                       AND Z.FIS_YEAR = A.FIS_YEAR
                       AND Z.BGT_DGR = A.BGT_DGR
                       AND ROWNUM = 1)
               , '') AS BGT_DGR_NM  
          FROM TB_REPORTINFO A
         WHERE 1 = 1
           AND A.REPORT_CD = #reportCd#
           AND A.REPORT_DETL_CD = #reportDetlCd#
           AND A.FIS_YEAR = #fisYear#
           AND A.BGT_DGR = #bgtDgr#
    </select>
    
    <select id="ReportComm.selectReportColWidthList" parameterClass="Map" resultClass="egovMap" >
        /*ReportComm.selectReportColWidthList*/
        SELECT REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , COL_SEQ
             , COL_WIDTH
          FROM TB_REPORTCOLWIDTH
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
         ORDER BY COL_SEQ
    </select>
    
    <select id="ReportComm.selectReportStyleList" parameterClass="Map" resultClass="egovMap" >
        /*ReportComm.selectReportStyleList*/
        SELECT REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , STYLE_NM
             , FONT_HEIGHT
             , FONT_NM
             , FONT_WEIGHT_YN
             , FONT_WEIGHT
             , ALIGNMENT
             , V_ALIGNMENT
             , BORDER_RIGHT_YN
             , BORDER_RIGHT
             , BORDER_RIGHT_COLOR
             , BORDER_LEFT_YN
             , BORDER_LEFT
             , BORDER_LEFT_COLOR
             , BORDER_TOP_YN
             , BORDER_TOP
             , BORDER_TOP_COLOR
             , BORDER_BOTTOM_YN
             , BORDER_BOTTOM
             , BORDER_BOTTOM_COLOR
             , FORE_FILL_YN
             , FORE_GROUND_COLOR_R
             , FORE_GROUND_COLOR_B
             , FORE_GROUND_COLOR_G
             , FILL_PATTERN
             , WRAP_TEXT_YN
             , DATA_FORMAT
             , USER_DATA_FORMAT
             , FONT_COLOR_YN
             , FONT_COLOR_R
             , FONT_COLOR_B
             , FONT_COLOR_G
          FROM TB_REPORTSTYLE
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
    </select>
    
    <select id="ReportComm.selectReportHeaderList" parameterClass="Map" resultClass="egovMap" >
        /*ReportComm.selectReportHeaderList*/
        SELECT ROW_SEQ AS ROW_SEQ
             , CELL_SEQ AS CELL_SEQ
             , NVL(HEADER_CONT, '') AS HEADER_CONT
          FROM TB_REPORTHEADER
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
         ORDER BY ROW_SEQ
                , CELL_SEQ
    </select>
    
    <select id="ReportComm.selectReportMergeList" parameterClass="Map" resultClass="egovMap" >
        /*ReportComm.selectReportMergeList*/
        SELECT NVL(MERGE_VAL, '') AS MERGE_VAL
          FROM TB_REPORTMERGE
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
         ORDER BY MERGE_SEQ
    </select>
    
    <select id="ReportComm.selectReportContList" parameterClass="Map" resultClass="egovMap" >
        /*ReportComm.selectReportContList*/
        SELECT REPORT_CD
             , REPORT_DETL_CD
             , CONT_SEQ
             , CONT
          FROM TB_REPORTCONT
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
         ORDER BY CONT_SEQ
    </select>
    
    <select id="ReportComm.selectDgrcompoChildIdList" parameterClass="Map" resultClass="egovMap" >
        /*ReportComm.selectDgrcompoChildIdList*/
        SELECT #reportCd# AS REPORT_CD
             , #reportDetlCd# AS REPORT_DETL_CD
             , FIS_YEAR AS FIS_YEAR
             , BGT_DGR AS BGT_DGR
             , TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
             , #srchVal# AS SRCH_VAL
          FROM TB_DGRCOMPO
         WHERE 1 = 1
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND UP_TE_BGT_COMPO_ID = #teBgtCompoId#
    </select>
    
    <!-- TB_REPORT010 -->
    <insert id="ReportComm.insertReport010" parameterClass="Map" >
        /*ReportComm.insertReport010*/
        INSERT 
          INTO TB_REPORT010(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , TE_BGT_COMPO_ID
             , TE_BGT_COMPO_SEQ
             , REFLECT_FG
             , DEMAND_CONT
             , EXAM_CONT
             , INVEST_PLAN
             , REPORT_MSTR
             , GOV_SUB
             , INDI_ATTR
             , ADVNC_PROC
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        VALUES (#reportCd#
             , #reportDetlCd#
             , #fisYear#
             , #bgtDgr#
             , #teBgtCompoId#
             , #teBgtCompoSeq#
             , NVL(#reflectFg#, '')
             , NVL(#demandCont#, '')
             , NVL(#examCont#, '')
             , NVL(#investPlan#, '')
             , NVL(#reportMstr#, '')
             , NVL(#govSub#, '')
             , NVL(#indiAttr#, '')
             , NVL(#advncProc#, '')
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP)
    </insert>
    
    <delete id="ReportComm.deleteReport010" parameterClass="Map" >
        /*ReportComm.deleteReport010*/
        DELETE
          FROM TB_REPORT010
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </delete>
    
    <update id="ReportComm.copyReport010" parameterClass="Map" >
        /*ReportComm.copyReport010*/
        UPDATE TB_REPORT010
           SET (REFLECT_FG, DEMAND_CONT, EXAM_CONT, INVEST_PLAN)
             = (SELECT REFLECT_FG, DEMAND_CONT, EXAM_CONT, INVEST_PLAN
                  FROM TB_REPORT010
                 WHERE 1 = 1
                   AND REPORT_CD = #srcReportCd#
                   AND REPORT_DETL_CD = #srcReportDetlCd#
                   AND FIS_YEAR = #srcFisYear#
                   AND BGT_DGR = #srcBgtDgr#
                   AND TE_BGT_COMPO_ID = #srcTeBgtCompoId#
                 )
             , MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
    
    <update id="ReportComm.updateSrchValReport010" parameterClass="Map" >
        /*ReportComm.updateSrchValReport010*/
        UPDATE TB_REPORT010
           SET SRCH_VAL = #srchVal#
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
    
    
    <!-- TB_REPORT020 -->
    <insert id="ReportComm.insertReport020" parameterClass="Map" >
        /*ReportComm.insertReport020*/
        INSERT 
          INTO TB_REPORT020(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , TE_BGT_COMPO_ID
             , TE_BGT_COMPO_SEQ
             , REFLECT_FG
             , DEMAND_CONT
             , EXAM_CONT
             , REPORT_SORT_SEQ
             , TOT_FRSC_AMT1
             , TOT_FRSC_AMT2
             , TOT_FRSC_AMT3
             , TOT_FRSC_AMT4
             , TOT_FRSC_AMT5
             , TOT_FRSC_AMT6
             , TOT_CHAR_AMT1
             , TOT_CHAR_AMT2
             , TOT_CHAR_AMT3
             , PRE_INV_FRSC_AMT1
             , PRE_INV_FRSC_AMT2
             , PRE_INV_FRSC_AMT3
             , PRE_INV_FRSC_AMT4
             , PRE_INV_FRSC_AMT5
             , PRE_INV_FRSC_AMT6
             , PRE_INV_CHAR_AMT1
             , PRE_INV_CHAR_AMT2
             , PRE_INV_CHAR_AMT3
             , MAYOR_REPORT_YN
             , REPORT_MSTR
             , GOV_SUB
             , INDI_ATTR
             , ADVNC_PROC
             , INVEST_PLAN
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        VALUES (#reportCd#
             , #reportDetlCd#
             , #fisYear#
             , #bgtDgr#
             , #teBgtCompoId#
             , #teBgtCompoSeq#
             , NVL(#reflectFg#, '')
             , NVL(#demandCont#, '')
             , NVL(#examCont#, '')
             , NVL(#reportSortSeq#, '')
             , NVL(#totFrscAmt1#, 0)
             , NVL(#totFrscAmt2#, 0)
             , NVL(#totFrscAmt3#, 0)
             , NVL(#totFrscAmt4#, 0)
             , NVL(#totFrscAmt5#, 0)
             , NVL(#totFrscAmt6#, 0)
             , NVL(#totCharAmt1#, 0)
             , NVL(#totCharAmt2#, 0)
             , NVL(#totCharAmt3#, 0)
             , NVL(#preInvFrscAmt1#, 0)
             , NVL(#preInvFrscAmt2#, 0)
             , NVL(#preInvFrscAmt3#, 0)
             , NVL(#preInvFrscAmt4#, 0)
             , NVL(#preInvFrscAmt5#, 0)
             , NVL(#preInvFrscAmt6#, 0)
             , NVL(#preInvCharAmt1#, 0)
             , NVL(#preInvCharAmt2#, 0)
             , NVL(#preInvCharAmt3#, 0)
             , NVL(#mayorReportYn#, 'Y')
             , NVL(#reportMstr#, '')
             , NVL(#govSub#, '')
             , NVL(#indiAttr#, '')
             , NVL(#advncProc#, '')
             , NVL(#investPlan#, '')
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP)
    </insert>
    
    <delete id="ReportComm.deleteReport020" parameterClass="Map" >
        /*ReportComm.deleteReport020*/
        DELETE
          FROM TB_REPORT020
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </delete>
    
    <update id="ReportComm.copyReport020" parameterClass="Map" >
        /*ReportComm.copyReport020*/
        UPDATE TB_REPORT020
           SET (REFLECT_FG
             , DEMAND_CONT
             , EXAM_CONT
             , TOT_FRSC_AMT1
             , TOT_FRSC_AMT2
             , TOT_FRSC_AMT3
             , TOT_FRSC_AMT4
             , TOT_FRSC_AMT5
             , TOT_FRSC_AMT6
             , TOT_CHAR_AMT1
             , TOT_CHAR_AMT2
             , TOT_CHAR_AMT3
             , PRE_INV_FRSC_AMT1
             , PRE_INV_FRSC_AMT2
             , PRE_INV_FRSC_AMT3
             , PRE_INV_FRSC_AMT4
             , PRE_INV_FRSC_AMT5
             , PRE_INV_FRSC_AMT6
             , PRE_INV_CHAR_AMT1
             , PRE_INV_CHAR_AMT2
             , PRE_INV_CHAR_AMT3
             , MAYOR_REPORT_YN
             , INVEST_PLAN)
             = (SELECT REFLECT_FG
                     , DEMAND_CONT
                     , EXAM_CONT
                     , TOT_FRSC_AMT1
                     , TOT_FRSC_AMT2
                     , TOT_FRSC_AMT3
                     , TOT_FRSC_AMT4
                     , TOT_FRSC_AMT5
                     , TOT_FRSC_AMT6
                     , TOT_CHAR_AMT1
                     , TOT_CHAR_AMT2
                     , TOT_CHAR_AMT3
                     , PRE_INV_FRSC_AMT1
                     , PRE_INV_FRSC_AMT2
                     , PRE_INV_FRSC_AMT3
                     , PRE_INV_FRSC_AMT4
                     , PRE_INV_FRSC_AMT5
                     , PRE_INV_FRSC_AMT6
                     , PRE_INV_CHAR_AMT1
                     , PRE_INV_CHAR_AMT2
                     , PRE_INV_CHAR_AMT3
                     , MAYOR_REPORT_YN
                     , INVEST_PLAN
                  FROM TB_REPORT020
                 WHERE 1 = 1
                   AND REPORT_CD = #srcReportCd#
                   AND REPORT_DETL_CD = #srcReportDetlCd#
                   AND FIS_YEAR = #srcFisYear#
                   AND BGT_DGR = #srcBgtDgr#
                   AND TE_BGT_COMPO_ID = #srcTeBgtCompoId#
                 )
             , MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
    
    <update id="ReportComm.updateSrchValReport020" parameterClass="Map" >
        /*ReportComm.updateSrchValReport020*/
        UPDATE TB_REPORT020
           SET SRCH_VAL = #srchVal#
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
    
    <update id="ReportComm.updateReportSortSeqReport020" parameterClass="Map" >
        /*ReportComm.updateReportSortSeqReport020*/
        UPDATE TB_REPORT020
           SET REPORT_SORT_SEQ = NVL(#reportSortSeq#, 'N')
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
    
    <update id="ReportComm.updateMayorReportYnReport020" parameterClass="Map" >
        /*ReportComm.updateMayorReportYnReport020*/
        UPDATE TB_REPORT020
           SET MAYOR_REPORT_YN = NVL(#mayorReportYn#, 'Y')
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
    </update>
    
    <!-- TB_REPORT020D -->
    <insert id="ReportComm.insertReport020D" parameterClass="Map" >
        /*ReportComm.insertReport020D*/
        INSERT 
          INTO TB_REPORT020_D(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , TE_BGT_COMPO_ID
             , LOCAL_GOV_CD
             , CHECK_YN
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        SELECT A.REPORT_CD
             , A.REPORT_DETL_CD
             , A.FIS_YEAR
             , A.BGT_DGR
             , A.TE_BGT_COMPO_ID
             , B.LOCAL_GOV_CD
             , 'N'
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP
          FROM TB_REPORT020 A
             , TB_LOCALGOV B
         WHERE 1 =1
           AND B.UP_LOCAL_GOV_CD = '6260000'
           AND A.REPORT_CD = #reportCd#
           AND A.REPORT_DETL_CD = #reportDetlCd#
           AND A.FIS_YEAR = #fisYear#
           AND A.BGT_DGR = #bgtDgr#
           AND A.TE_BGT_COMPO_ID = #teBgtCompoId#
    </insert>
    
    <delete id="ReportComm.deleteReport020D" parameterClass="Map" >
        /*ReportComm.deleteReport020D*/
        DELETE
          FROM TB_REPORT020_D
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
         <isNotEmpty prepend="" property="localGovCd">
           AND LOCAL_GOV_CD = #localGovCd# 
         </isNotEmpty>
    </delete>
    
    <update id="ReportComm.copyReport020D" parameterClass="Map" >
        /*ReportComm.copyReport020D*/
        UPDATE TB_REPORT020_D
           SET (CHECK_YN)
             = (SELECT CHECK_YN
                  FROM TB_REPORT020_D
                 WHERE 1 = 1
                   AND REPORT_CD = #srcReportCd#
                   AND REPORT_DETL_CD = #srcReportDetlCd#
                   AND FIS_YEAR = #srcFisYear#
                   AND BGT_DGR = #srcBgtDgr#
                   AND TE_BGT_COMPO_ID = #srcTeBgtCompoId#
                 <isNotEmpty prepend="" property="srcLocalGovCd">
                   AND LOCAL_GOV_CD = #srcLocalGovCd# 
                 </isNotEmpty>
                 )
             , MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
         <isNotEmpty prepend="" property="localGovCd">
           AND LOCAL_GOV_CD = #localGovCd# 
         </isNotEmpty>
    </update>
    
    <update id="ReportComm.updateReport020D" parameterClass="Map" >
        /*ReportComm.updateReport020D*/
        UPDATE TB_REPORT020_D
           SET CHECK_YN = NVL(#checkYn#, 'N')
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
         <isNotEmpty prepend="" property="localGovCd">
           AND LOCAL_GOV_CD = #localGovCd# 
         </isNotEmpty>
    </update>
    
    
    
    <!-- TB_REPORT030 -->
    <insert id="ReportComm.insertReport030" parameterClass="Map" >
        /*ReportComm.insertReport030*/
        INSERT 
          INTO TB_REPORT030(
               REPORT_CD
             , REPORT_DETL_CD
             , FIS_YEAR
             , BGT_DGR
             , DEPT_CD
             , DBIZ_CD
             , REFLECT_FG
             , DEMAND_CONT
             , EXAM_CONT
             , REPORT_MSTR
             , GOV_SUB
             , INDI_ATTR
             , ADVNC_PROC
             , REGI_ID
             , REGI_DATE
             , MODI_ID
             , MODI_DATE)
        SELECT #reportCd#
             , #reportDetlCd#
             , FIS_YEAR
             , BGT_DGR
             , DEPT_CD
             , DBIZ_CD
             , NVL(#reflectFg#, '')
             , NVL(#demandCont#, '')
             , NVL(#examCont#, '')
             , NVL(#reportMstr#, '')
             , NVL(#govSub#, '')
             , NVL(#indiAttr#, '')
             , NVL(#advncProc#, '')
             , #userId#
             , SYSTIMESTAMP
             , #userId#
             , SYSTIMESTAMP
          FROM TB_DGRCOMPO A
         WHERE 1 = 1
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
           AND NOT EXISTS (SELECT 1
                             FROM TB_REPORT030 Z
                            WHERE 1 = 1
                              AND Z.REPORT_CD = #reportCd#
                              AND Z.REPORT_DETL_CD = #reportDetlCd#
                              AND Z.FIS_YEAR = A.FIS_YEAR
                              AND Z.BGT_DGR = A.BGT_DGR
                              AND Z.DEPT_CD = A.DEPT_CD
                              AND Z.DBIZ_CD = A.DBIZ_CD
                          ) 
         GROUP BY FIS_YEAR
                , BGT_DGR
                , DEPT_CD
                , DBIZ_CD
    </insert>
    
    <delete id="ReportComm.deleteReport030" parameterClass="Map" >
        /*ReportComm.deleteReport030*/
        DELETE
          FROM TB_REPORT030 A
         WHERE 1 = 1
           AND A.REPORT_CD = #reportCd#
           AND A.REPORT_DETL_CD = #reportDetlCd#
           AND EXISTS (SELECT 1
                         FROM TB_DGRCOMPO Z
                        WHERE 1 = 1
                          AND Z.FIS_YEAR = A.FIS_YEAR
                          AND Z.BGT_DGR = A.BGT_DGR
                          AND Z.DEPT_CD = A.DEPT_CD
                          AND Z.DBIZ_CD = A.DBIZ_CD
                          AND Z.FIS_YEAR = #fisYear#
                          AND Z.BGT_DGR = #bgtDgr#
                          AND Z.TE_BGT_COMPO_ID = #teBgtCompoId#
                      )
           AND NOT EXISTS (SELECT 1
                             FROM TB_DGRCOMPO Z1
                                , TB_DGRCOMPO Z2
                                , TB_REPORT Z3
                            WHERE 1 = 1
                              AND Z3.REPORT_CD = #reportCd#
                              AND Z3.REPORT_DETL_CD = #reportDetlCd#
                              AND Z3.FIS_YEAR = Z2.FIS_YEAR
                              AND Z3.BGT_DGR = Z2.BGT_DGR
                              AND Z3.TE_BGT_COMPO_ID = Z2.TE_BGT_COMPO_ID
                              AND Z2.FIS_YEAR = Z1.FIS_YEAR
                              AND Z2.BGT_DGR = Z1.BGT_DGR
                              AND Z2.DEPT_CD = Z1.DEPT_CD
                              AND Z2.DBIZ_CD = Z1.DBIZ_CD
                              AND Z1.FIS_YEAR = #fisYear#
                              AND Z1.BGT_DGR = #bgtDgr#
                              AND Z1.TE_BGT_COMPO_ID = #teBgtCompoId#
                          )    
    </delete>
    
    <update id="ReportComm.copyReport030" parameterClass="Map" >
        /*ReportComm.copyReport030*/
        UPDATE TB_REPORT030
           SET (REFLECT_FG, DEMAND_CONT, EXAM_CONT)
             = (SELECT REFLECT_FG, DEMAND_CONT, EXAM_CONT
                  FROM TB_REPORT030
                 WHERE 1 = 1
                   AND REPORT_CD = #srcReportCd#
                   AND REPORT_DETL_CD = #srcReportDetlCd#
                   AND FIS_YEAR = #srcFisYear#
                   AND BGT_DGR = #srcBgtDgr#
                   AND DEPT_CD = #srcDeptCd#
                   AND DBIZ_CD = #srcDbizCd#
                 )
             , MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND DEPT_CD = #deptCd#
           AND DBIZ_CD = #dbizCd#
    </update>
    
    <update id="ReportComm.updateSrchValReport030" parameterClass="Map" >
        /*ReportComm.updateSrchValReport030*/
        UPDATE TB_REPORT030
           SET SRCH_VAL = #srchVal#
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND DEPT_CD = #deptCd#
           AND DBIZ_CD = #dbizCd#
    </update>
    
    
