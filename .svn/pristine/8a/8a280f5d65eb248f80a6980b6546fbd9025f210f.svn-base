    public Map rtnReportData(int rowSeq, int cellSeq, String headerCont, String formula, String type){
    	Map map = new HashMap<String, String>();
    	
    	map.put("rowSeq", rowSeq);
    	map.put("cellSeq", cellSeq);
    	map.put("headerCont", headerCont);
    	map.put("formula", formula);
    	map.put("type", type);
    	
    	return map;
    }
    
    public List getMergeDataReport(){
    	List merge = new ArrayList();
    	Map map = new HashMap<String, String>();
    	merge.add(rtnMergeData("$B$7:$B$12"));
    	
    	return merge;
    }
