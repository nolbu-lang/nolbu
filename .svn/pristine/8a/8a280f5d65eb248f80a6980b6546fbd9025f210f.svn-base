    public void makeReport(Map model, XSSFWorkbook wb, Map reportInfo) throws Exception {
    	int rowNum = 0;
    	XSSFSheet sheet = null;
    	
    	sheet = wb.createSheet("보고");
    	ReportFormulaUtil reportFormulaUtil = new ReportFormulaUtil(sheet);
    	Map tmpModel = new HashMap();
        tmpModel.put("reportCd", "0003");
        tmpModel.put("reportDetlCd", "0003");
        tmpModel.put("fisYear", "2019");
        tmpModel.put("bgtDgr", "3");
        
        Map<String, CellStyle> styles = reportCommDAO.getReportStyleMap(tmpModel, wb);
    	
    	rowNum = writeReport(model, sheet, rowNum, styles);
    	
    	if (sheet != null) {
    		tmpModel = new HashMap();
        	tmpModel.put("reportCd", "0003");
        	tmpModel.put("reportDetlCd", "0003");
        	tmpModel.put("fisYear", "2019");
        	tmpModel.put("bgtDgr", "3");
        	model = tmpModel;
    		ReportSaveUtil.writeLastSheet(reportCommDAO, model, wb, sheet, rowNum, styles, reportInfo, 8);
    		reportFormulaUtil.writeCellFormula();
    		
    		sheet = null;
    	}
    }
    
    public int writeReport(Map model, XSSFSheet sheet, int rowNum, Map<String, CellStyle> styles) throws Exception {
    	Row row = null;
    	Cell cell = null;
    	
    	List list = null;
    	Map map = null;
    	
    	int unitPos = 8;
    	int repeatingStartRow = 0;
    	
    	//타이틀 세팅
    	row = sheet.createRow(rowNum);
    	rowNum++;
    	row.setHeightInPoints(21f);
    	
    	Cell titleCell = row.createCell(1);
    	titleCell.setCellStyle(styles.get("title"));
    	titleCell.setCellValue("□ 2019년도 당초예산 집계표(보고서식)");
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$" + rowNum + ":$I$" + rowNum));
    	
    	float rowHeight = 18f;

		
		//두번째 행 세팅(빈칸)
		row = sheet.createRow(rowNum);
		rowNum++;
		
		//세번째 행 세팅 (보조 title)
		row = sheet.createRow(rowNum);
		rowNum++;
    	cell = row.createCell(1);
    	cell.setCellValue("(총괄)");
    	
    	cell = row.createCell(unitPos);
    	cell.setCellStyle(styles.get("unit"));
    	cell.setCellValue("(단위:백만원)");
    	
    	
    	repeatingStartRow = rowNum;
    	
    	int preRowSeq = -1;
    	int rowSeq = -1;
    	int cellSeq = -1;
    	String headerCont = "";
    	
    	String fisYear = (String)model.get("fisYear");		//회계년도
    	String bgtDgr = (String)model.get("bgtDgr");		//예산차수 코드
    	String bgtDgrNm = (String)model.get("bgtDgrNm");	//예산차수 명칭
    	
    	list = getReportData(fisYear, bgtDgr, bgtDgrNm);
    	while (!list.isEmpty()) {
    		map = (Map) list.remove(0);
    		
    		rowSeq = ReportSaveUtil.getIntValue(map.get("rowSeq"));
    		cellSeq = ReportSaveUtil.getIntValue(map.get("cellSeq"));
    		headerCont = ReportSaveUtil.getStringValue(map.get("headerCont"));
    		if (rowSeq < 0) {
    			throw new Exception("보고서 Header 정보 오류입니다.");
    		}
    		
    		if (preRowSeq == -1 || preRowSeq != rowSeq) {
    			row = sheet.createRow(rowNum);
    			rowNum++;
    			row.setHeightInPoints(13.5f);
    		}
    		
    		preRowSeq = rowSeq;
    		
    		cell = row.createCell(cellSeq);
    		
    		String type = ReportSaveUtil.getStringValue(map.get("type"));
    		
    		if("header".equals(type)){
    			if(cellSeq != 0){
    				cell.setCellStyle(styles.get("header"));
    			}
    			
    			if (BcjisCommUtil.isNullString(headerCont) == false) {
        			cell.setCellValue(headerCont);
        		}
    		}else if("title".equals(type)){
    			if(cellSeq != 0){
    				cell.setCellStyle(styles.get("title"));
    			}
    			
    			if (BcjisCommUtil.isNullString(headerCont) == false) {
        			cell.setCellValue(headerCont);
        		}
    		}else if("unit".equals(type)){
    			if(cellSeq != 0){
    				cell.setCellStyle(styles.get("unit"));
    			}
    			
    			if (BcjisCommUtil.isNullString(headerCont) == false) {
    				cell.setCellValue(headerCont);
    			}
    		}else if("formula".equals(type)){
    			if(cellSeq != 0){
    				cell.setCellStyle(styles.get("depth"));
    			}
    			String formula = ReportSaveUtil.getStringValue(map.get("formula"));
    			if(BcjisCommUtil.isNullString(formula) == false){
    				cell.setCellFormula(formula);
    			}
    			
    		}else if("depth".equals(type)){
    			if(cellSeq != 0){
    				cell.setCellStyle(styles.get("depth"));
    			}
    			
    			if (BcjisCommUtil.isNullString(headerCont) == false) {
        			cell.setCellValue(headerCont);
        		}
    		}
    		
    		
    	}
    	
    	//타이틀
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$3:$D$3"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$4:$D$5"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$E$4:$E$5"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$F$4:$F$5"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$G$4:$H$4"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$I$4:$I$5"));
    	
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$6:$D$6"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$7:$B$12"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$7:$D$7"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$8:$D$8"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$9:$D$9"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$10:$C$12"));
    	
    	//타이틀
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$14:$D$14"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$15:$D$16"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$E$15:$E$16"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$F$15:$F$16"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$G$15:$H$15"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$I$15:$I$16"));
    	
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$17:$D$17"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$18:$B$20"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$18:$D$18"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$19:$D$19"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$20:$D$20"));
    	
    	//타이틀
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$22:$D$22"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$23:$D$24"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$E$23:$E$24"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$F$23:$F$24"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$G$23:$H$23"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$I$23:$I$24"));
    	
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$25:$D$25"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$26:$B$36"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$26:$D$26"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$27:$D$27"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$28:$D$28"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$29:$C$31"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$32:$D$32"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$33:$D$33"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$34:$D$34"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$35:$D$35"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$36:$D$36"));
    	
    	//타이틀
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$38:$D$38"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$39:$D$40"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$E$39:$E$40"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$F$39:$F$40"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$G$39:$H$39"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$I$39:$I$40"));
    	
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$41:$D$41"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$B$42:$B$48"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$42:$D$42"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$43:$D$43"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$44:$C$45"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$46:$D$46"));
    	sheet.addMergedRegion(CellRangeAddress.valueOf("$C$47:$C$48")); 
    	
    	XSSFPrintSetup printSetup = sheet.getPrintSetup();
    	printSetup.setPaperSize(BcjisCommUtil.getShortValue(12));
    	printSetup.setScale(BcjisCommUtil.getShortValue(100));
    	printSetup.setLandscape(true);
    	printSetup.setPageOrder(PageOrder.OVER_THEN_DOWN);
    	
    	sheet.setMargin(XSSFSheet.LeftMargin, 0.36);
    	sheet.setMargin(XSSFSheet.RightMargin, 0.36);
    	sheet.setMargin(XSSFSheet.TopMargin, 0.60);
    	sheet.setMargin(XSSFSheet.BottomMargin, 0.40);
    	sheet.setMargin(XSSFSheet.HeaderMargin, 0.00);
    	sheet.setMargin(XSSFSheet.FooterMargin, 0.00);
    	
    	sheet.setHorizontallyCenter(true);
    	
    	//sheet.setRepeatingRows(CellRangeAddress.valueOf(repeatingStartRow + ":" + rowNum));
    	//sheet.setRepeatingColumns(CellRangeAddress.valueOf("A:B"));
    	
    	//sheet.createFreezePane(3, 8);
    	sheet.setZoom(100);
    	
    	Footer footer = sheet.getFooter();
    	
    	footer.setCenter("" + HeaderFooter.page());
    	
    	CTSheetView view = sheet.getCTWorksheet().getSheetViews().getSheetViewArray(0);
    	view.setView(STSheetViewType.PAGE_BREAK_PREVIEW);
    	
    	return rowNum;
    }
    
