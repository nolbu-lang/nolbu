    var getGridHeight = function (){
        return $("#mainCenter", tabObj).height() - 110 > 250 ? $("#mainCenter", tabObj).height() - 110 : 250;
    };
    
    bcjisCommMainObj["mainBodyResize_"+tabId] = mainBodyResize;
    
    var mainBodyResize = function(){
        if(isEmpty($("#REPORT_WRITE040_GRD", $("#"+tabId))) == false){
            $("#REPORT_WRITE040_GRD", $("#"+tabId)).setGridHeight(getGridHeight());
            $("#REPORT_WRITE040_GRD", $("#"+tabId)).setGridWidth($("#mainCenter", tabObj).width());
        }
    };
    
    $("#mainBody", tabObj).layout({
        north__size : 225,
        center__onresize: mainBodyResize
    });
    
    var setCompoAmt = function(amtObj){
        var objId = amtObj.attr("id");
        
        if(isEmpty(objId) == true){
            return;
        }
        
        var idIndex = objId.indexOf("_");
        if(idIndex < 1){
            return;
        }
        
        var preId = objId.substring(0, idIndex);
        var dgrcompoId = objId.substring(idIndex + 1);
        
        if(isEmpty(preId) == true || isEmpty(dgrcompoId) == true){
            return;
        }
        
        var exceptCnt = Number($("#driverCnt_"+dgrcompoId).val().replaceAll(",", "")) 
                        + Number($("#etcCnt_"+dgrcompoId).val().replaceAll(",", ""));
        var compoCnt = Number($("#staffCnt_"+dgrcompoId).val().replaceAll(",", "")) - exceptCnt;
        
        $("#exceptCnt_"+dgrcompoId).val(addCommaStr(exceptCnt));
        $("#compoCnt_"+dgrcompoId).val(addCommaStr(compoCnt));
    };
    
    var reportWrite040Grid = $("#REPORT_WRITE040_GRD", tabObj);
    
    var doSearchCallBack = function(data){
        if (isEmpty(data) == true || data[BCJIS_RETURN_CODE] != "SUCC") {
            $.csAlert({
                msg : data.bcjisMessage
            });
            
            return;
        }
        
