    budgetModifyDialogDgrcompoRegiCallBackFunction = function(param){
        doSearch();
    };
    
    function getData(data){
    	if(data){
    		return data;
    	}else{
    		return '';
    	}
    }
    
    var getSelectedData = function(gridObject, gridRows){
        var selectedDatas = [];
        var selectedData = {};
        var rowId;
        var rowData;
        var cnt = 0;
        for(var i = 0; i < gridRows.length; i++) {
            rowId = gridRows[i].id;
            rowData = gridObject.getRowData(rowId);
            
            if(rowData.selYn == "Y" && rowData.teBgtCompoSeq != 0){
                selectedData = {};
                selectedData["fisYear"] = rowData.fisYear;
                selectedData["bgtDgr"] = rowData.bgtDgr;
                selectedData["teBgtCompoSeq"] = rowData.teBgtCompoSeq;
                selectedData["teBgtCompoId"] = rowData.teBgtCompoId;
                selectedData["dgrLevel"] = rowData.dgrLevel;
                selectedData["rowId"]	= rowId;	//rowId 추가 2019-06-07
                selectedData["dgrcompoNm"]	= rowData.dgrcompoNm;	//구분값 추가
                selectedData["cngType"]	= getData(rowData.cngType);	//구분값 추가
                selectedData["grpId"]	= getData(rowData.grpId);	//구분값 추가
                selectedData["grpLvl"]	= getData(rowData.grpLvl);	//구분값 추가
                selectedDatas.push(selectedData);
                cnt++;
            }
        }
        
        return selectedDatas;
    };
    
    var doSaveDgrcompoDatasCallBack = function(data){
        if(isEmpty(data) == true || data[BCJIS_RETURN_CODE] != "SUCC"){
            $.csAlert({
                msg : data.bcjisMessage
            });
            
            return;
        }
        
        $.csAlert({
            msg : data.bcjisMessage,
            callBack : function() {
                doSearchRlk();
                doSearch();
            }
        });
    };
    
    var doSaveDgrcompoDatas = function(params){
        if(params.confirmData != "Y"){
            return;
        }
        
        var selectedDatas = getSelectedData(budgetApplyRlkGrid, $("#BUDGET_APPLY_RLK_GRD", tabObj)[0].rows);
        if(isEmpty(selectedDatas) == true || selectedDatas.length < 1){
            $.csAlert({
                msg : "적용할 자료를 선택하여 주십시오."
            });
            
            return;
        }
        
        console.log(selectedDatas);
        $.csAjaxCall({
            url : "/budget/ajaxBudgetApplySaveDgrcompoDatas.do",
            data : {dgrCompoDatas: selectedDatas},
            async : true,
            callBack : doSaveDgrcompoDatasCallBack
        });
    };
    
