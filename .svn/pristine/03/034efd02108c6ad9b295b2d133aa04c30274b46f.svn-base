        center__onresize: subMainBodyResize
    });
    

    var saveReportParam = null;
    
    var budgetApplyRlkGrid = $("#BUDGET_APPLY_RLK_GRD", tabObj);
    var budgetApplyGrid = $("#BUDGET_APPLY_GRD", tabObj);
    
    var doSearchRlkCallBack = function(data){
        if (isEmpty(data) == true || data[BCJIS_RETURN_CODE] != "SUCC") {
            $.csAlert({
                msg : data.bcjisMessage
            });
            
            return;
        }

        $("#BUDGET_APPLY_RLK_GRD", tabObj).GridUnload();
        budgetApplyRlkGrid = $("#BUDGET_APPLY_RLK_GRD", tabObj);
        budgetApplyRlkGrid.csTreeGrid({
            datastr : data,
            height : getGridHeight(),
            colNames : leftColNames,
            colModel : leftColModel,
            ExpandColumn : "dgrcompoNm",
            jsonReader : {
                repeatitems : false,
                root : "dataList"
            },
            onSelectRow: function(rowId){
            },
            loadComplete: function() {
                var iColSelYn = getColumnIndexByName ($(this), 'selYn');
                var rows = this.rows;
                for(var i = 0; i < rows.length; i++) {
                    
                    $(rows[i].cells[iColSelYn]).click(function (e) {
                        var checkedRowId = $(e.target).closest('tr')[0].id;
                        
                        setTreeGridChecked(e, budgetApplyRlkGrid, $("#BUDGET_APPLY_RLK_GRD", tabObj)[0].rows, 'dgrLevel');
                        setUpTreeGridCheck(budgetApplyRlkGrid, checkedRowId, 'upDgrcompoId');
                    });
                }
            }
        });
        
        budgetApplyRlkGrid.jqGrid('setGroupHeaders', {
            useColSpanStyle : true,
            groupHeaders : [ 
               /*{startColumnName : 'demandCompFormular',numberOfColumns : 3, titleText : '요구'},
               {startColumnName : 'compFormular', numberOfColumns : 3, titleText : '조정'}*/
               {startColumnName : 'demandDiffAmt',numberOfColumns : 2, titleText : '요구'},
               {startColumnName : 'diffAmt', numberOfColumns : 2, titleText : '조정'}
            ]
        });
        
        $("#saveDgrcompoDatasBtn", tabObj).btnChangeState(true);
        $("#selectAllRlkBtn", tabObj).btnChangeState(true);
        $("#unSelectAllRlkBtn", tabObj).btnChangeState(true);
        $("#selectAllRlkBtn", tabObj).show();
        $("#unSelectAllRlkBtn", tabObj).hide();
        
        data = null;
    };
    
    var doSearchCallBack = function(data){
        if (isEmpty(data) == true || data[BCJIS_RETURN_CODE] != "SUCC") {
            $.csAlert({
                msg : data.bcjisMessage
            });
            
            return;
        }

        $("#BUDGET_APPLY_GRD", tabObj).jqGrid('GridUnload');
        budgetApplyGrid = $("#BUDGET_APPLY_GRD", tabObj);
        budgetApplyGrid.csTreeGrid({
            datastr : data,
            height : getGridHeight(),
            colNames : rightColNames,
            colModel : rightColModel,
            ExpandColumn : "dgrcompoNm",
            jsonReader : {
                repeatitems : false,
                root : "dataList"
            },
            onSelectRow: function(rowId){
            },
            loadComplete: function() {
                var iColSelYn = getColumnIndexByName ($(this), 'selYn');
                var rows = this.rows;
                for(var i = 0; i < rows.length; i++) {
                    $(rows[i].cells[iColSelYn]).click(function (e) {
                        setTreeGridChecked(e, budgetApplyGrid, $("#BUDGET_APPLY_GRD", tabObj)[0].rows, 'dgrLevel');
                    });
                }
            }
        });

        budgetApplyGrid.jqGrid('setGroupHeaders', {
            useColSpanStyle : true,
            groupHeaders : [ 
               /*{startColumnName : 'demandCompFormular',numberOfColumns : 3, titleText : '요구'},
               {startColumnName : 'compFormular', numberOfColumns : 3, titleText : '조정'}*/ 
               {startColumnName : 'demandDiffAmt',numberOfColumns : 2, titleText : '요구'},
               {startColumnName : 'diffAmt', numberOfColumns : 2, titleText : '조정'}
            ]
        });
        
        var gridRows = budgetApplyGrid[0].rows;
        
        for(var i = 0; i < gridRows.length; i++) {
            rowId = gridRows[i].id;
            rowData = budgetApplyGrid.getRowData(rowId);
            var cngType = rowData.cngType;
            var grpId = rowData.grpId;
            var grpLvl = rowData.grpLvl;
            
            if(cngType == 'CH01' && grpLvl == '2'){
            	var obj = $('#'+rowId).find('input[type=checkbox]').attr('disabled', true);
            }
            
        }
        
        $("#deltDgrcompoDatasBtn", tabObj).btnChangeState(true);
        $("#selectAllBtn", tabObj).btnChangeState(true);
        $("#unSelectAllBtn", tabObj).btnChangeState(true);
        $("#selectAllBtn", tabObj).show();
        $("#unSelectAllBtn", tabObj).hide();

        //버튼추가 2019-06-07
        $("#regiBtn", tabObj).btnChangeState(true);
        $("#modifyBtn", tabObj).btnChangeState(true);
        $("#sortBtn", tabObj).btnChangeState(true);
        $("#mergeBtn", tabObj).btnChangeState(true);
        $("#sepBtn", tabObj).btnChangeState(true);
        $("#cngHistoryBtn", tabObj).btnChangeState(true);
        
        data = null;
    };
    
    //disabled된 체크박스 제외(병합)
    function setTreeGridChecked(checkedEvent, gridObjeck, gridRows, rowLevelNm){
        var checkedRowId = $(checkedEvent.target).closest('tr')[0].id;
        var isChecked = $(checkedEvent.target).is(':checked');
        
        var rowLevel = Number(gridObjeck.jqGrid('getCell', checkedRowId, rowLevelNm));

        var tempId;
        var startFlag = false;
        var tempRowLevel = 0;
        for(var k = 0; k < gridRows.length; k++) {
            tempId = gridRows[k].id;
            
            if(checkedRowId === tempId){
                startFlag = true;
                continue;
            }
            
            if(startFlag != true){
                continue;
            }
            
            tempRowLevel = Number(gridObjeck.jqGrid('getCell', tempId, rowLevelNm));
            if(rowLevel < tempRowLevel){
            	var disabled = $('#'+tempId).find('input[type=checkbox]').attr('disabled');
                
                if(isEmpty(disabled) == true){
                	gridObjeck.jqGrid('setCell', tempId, 'selYn', isChecked);
                }
            }else{
                break;
            }
        }
    }
    
    var doSearchRlk = function(){
        var fisYear = $("#condFisYear option:selected", tabObj).val();
        var bgtDgr = $("#condBgtDgr option:selected", tabObj).val();
        var fisFgMstCd = $("#condFisFgMstCd option:selected", tabObj).val();
        var fisFgCd = $("#condFisFgCd option:selected", tabObj).val();
        var officeCd = $("#condOfficeCd option:selected", tabObj).val();
        var deptRankFr = $("#condDeptRankFr", tabObj).val();
        var deptRankTo = $("#condDeptRankTo", tabObj).val();
        var teMngMokCdFr = $("#condTeMngMokCdFr", tabObj).val();
        var teMngMokCdTo = $("#condTeMngMokCdTo", tabObj).val();
        var frscFgCdFr = $("#condFrscFgCdFr", tabObj).val();
        var frscFgCdTo = $("#condFrscFgCdTo", tabObj).val();
        var frscFrCdYn = "N";
        if(isEmpty(frscFgCdFr) == false || isEmpty(frscFgCdTo) == false){
            frscFrCdYn = "Y";
        }
        var amtUnit = $("#condAmtUnit", tabObj).val();
        
        $.csAjaxCall({
            url : "/budget/ajaxBudgetApplyDgrCompoRlkList.do",
            data: {fisYear : fisYear,
                   bgtDgr : bgtDgr,
                   fisFgMstCd : fisFgMstCd,
                   fisFgCd : fisFgCd,
                   officeCd : officeCd,
                   deptRankFr : deptRankFr,
                   deptRankTo : deptRankTo,
                   teMngMokCdFr : teMngMokCdFr,
                   teMngMokCdTo : teMngMokCdTo,
                   frscFgCdFr : frscFgCdFr,
                   frscFgCdTo : frscFgCdTo,
                   frscFrCdYn : frscFrCdYn,
                   amtUnit : amtUnit
            },
            async : true,
            callBack : doSearchRlkCallBack
        });
    };
    
    var doSearch = function(){
        var fisYear = $("#condFisYear option:selected", tabObj).val();
        var bgtDgr = $("#condBgtDgr option:selected", tabObj).val();
        var fisFgMstCd = $("#condFisFgMstCd option:selected", tabObj).val();
        var fisFgCd = $("#condFisFgCd option:selected", tabObj).val();
        var officeCd = $("#condOfficeCd option:selected", tabObj).val();
        var deptRankFr = $("#condDeptRankFr", tabObj).val();
        var deptRankTo = $("#condDeptRankTo", tabObj).val();
        var teMngMokCdFr = $("#condTeMngMokCdFr", tabObj).val();
        var teMngMokCdTo = $("#condTeMngMokCdTo", tabObj).val();
        var frscFgCdFr = $("#condFrscFgCdFr", tabObj).val();
        var frscFgCdTo = $("#condFrscFgCdTo", tabObj).val();
        var frscFrCdYn = "N";
