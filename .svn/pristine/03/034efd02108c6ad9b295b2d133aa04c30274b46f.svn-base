    reportWriteOpenDialogDgrcompoModify = function(rowId){  
        var rowData = budgetApplyGrid.getRowData(rowId);
        
        /*$("#dialogDgrcompoModifyCallBackFunction", $("#dialogDgrcompoModifyDiv")).val("reportWirte010DialogDgrcompoModifyCallBackFunction");
        $("#dialogDgrcompoModifyDgrcompoId", $("#dialogDgrcompoModifyDiv")).val(rowData.dgrcompoId);
        $("#dialogDgrcompoModifyFisYear", $("#dialogDgrcompoModifyDiv")).val(rowData.fisYear);
        $("#dialogDgrcompoModifyBgtDgr", $("#dialogDgrcompoModifyDiv")).val(rowData.bgtDgr);
        $("#dialogDgrcompoModifyTeBgtCompoId", $("#dialogDgrcompoModifyDiv")).val(rowData.teBgtCompoId);
        $("#dialogDgrcompoModifyIsLeaf", $("#dialogDgrcompoModifyDiv")).val(rowData.isLeaf);
        $("#dialogDgrcompoModifyAmtUnit", $("#dialogDgrcompoModifyDiv")).val($("#condAmtUnit", tabObj).val());*/
        
        $("#dialogDgrcompoModifyReportCallBackFunction", $("#dialogDgrcompoModifyReportDiv")).val("reportWirte010DialogDgrcompoModifyCallBackFunction");
        $("#dialogDgrcompoModifyReportFisYear", $("#dialogDgrcompoModifyReportDiv")).val(rowData.fisYear);
        $("#dialogDgrcompoModifyReportBgtDgr", $("#dialogDgrcompoModifyReportDiv")).val(rowData.bgtDgr);
        $("#dialogDgrcompoModifyReportTeBgtCompoId", $("#dialogDgrcompoModifyReportDiv")).val(rowData.teBgtCompoId);
        
        $("#dialogDgrcompoModifyReportDiv").dialog('open');
    };
    
    var editFormatter = function(cellValue, options, rowObject){
        if(isEmpty(cellValue) == true){
            cellValue = "";
        }
        
        if(_mainNorthPowGrCd == "BC002"){
            return cellValue;
        }
        
        if(rowObject.teBgtCompoId == "00000000000"){
            return cellValue;
        }
        
        //리포트가 하나 이상일 경우 버튼 노출(국고보조 제외)
        if(rowObject.reportCnt < 1){
        	return cellValue;
        }
        
        //병합 원본은 제외
        if(rowObject.cngType == 'CH01' && rowObject.grpLvl == '2'){
        	return cellValue;
        }
        
        var rVal = '<a href="javascript:reportWriteOpenDialogDgrcompoModify(\''+options.rowId+'\');"><span class="ui-icon ui-icon-pencil"></span></a>';
        
        return rVal;
    };
    
