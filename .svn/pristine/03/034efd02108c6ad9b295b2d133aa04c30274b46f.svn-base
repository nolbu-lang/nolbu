    var getGridHeight = function (){
        return $("#subMainCenter", tabObj).height() - 110 > 200 ? $("#subMainCenter", tabObj).height() - 110 : 200;
    };
    
    var mainBodyResize = function(){
        $("#subMainBody", tabObj).width($("#mainCenter", tabObj).width());
        $("#subMainBody", tabObj).layout().resizeAll();
    };

    var subMainBodyResize = function () {
        if(isEmpty($("#BUDGET_APPLY_RLK_GRD", tabObj)) == false){
            $("#BUDGET_APPLY_RLK_GRD", tabObj).setGridHeight(getGridHeight());
            $("#BUDGET_APPLY_RLK_GRD", tabObj).setGridWidth($("#subMainWest", tabObj).width());
        }
        
        if(isEmpty($("#BUDGET_APPLY_GRD", tabObj)) == false){
