            sheet.addMergedRegion(CellRangeAddress.valueOf("$A$" + startRowNum + ":$A$" + (rowNum - 2)));
            sheet.addMergedRegion(CellRangeAddress.valueOf("$A$" + (rowNum - 1) + ":$A$" + rowNum));
        } else {
            sheet.addMergedRegion(CellRangeAddress.valueOf("$A$" + startRowNum + ":$A$" + rowNum));
        }

        sheet.addMergedRegion(CellRangeAddress.valueOf("$B$" + startRowNum + ":$B$" + rowNum));
        if ("data".equals(preStyleNm) == true) {
            sheet.addMergedRegion(CellRangeAddress.valueOf("$C$" + startRowNum + ":$C$" + (startRowNum + 2)));
        } else {
            sheet.addMergedRegion(CellRangeAddress.valueOf("$C$" + startRowNum + ":$C$" + rowNum));
        }

        sheet.addMergedRegion(CellRangeAddress.valueOf("$D$" + (startRowNum + 1) + ":$D$" + (startRowNum + 1 + 5)));
        sheet.addMergedRegion(CellRangeAddress.valueOf("$D$" + (startRowNum + 1 + 5 + 1) + ":$D$" + (startRowNum + 1 + 5 + 1 + 2)));
        sheet.addMergedRegion(CellRangeAddress.valueOf("$K$" + (startRowNum + 1) + ":$K$" + rowNum));

        if("Y".equals(teMngCdYn) == true){
            sheet.addMergedRegion(CellRangeAddress.valueOf("$L$" + startRowNum + ":$L$" + rowNum));
        }

        writeCont(sheet, startRowNum, ReportSaveUtil.getStringValue(category.get("demandCont")), styles);

        if (sheetDataCnt % 6 == 5) {
            sheet.setRowBreak(rowNum - 1);
        }

        return rowNum;
    }

    public int writeBizlistData(XSSFSheet sheet, int rowNum, JSONObject category, Map<String, CellStyle> styles, boolean bgtCompoFlag, int totDataCnt, int dataCnt, int subCnt, ReportFormulaUtil reportFormulaUtil) {
        float rowHeight = 34.50f;
        Row row = null;
        Cell cell = null;

        int dgrLevel = 0;
        try {
            dgrLevel = Integer.parseInt(String.valueOf(category.get("dgrLevel")));
        } catch (NumberFormatException nfe) {
            throw nfe;
        }

        String dgrcompoId = ReportSaveUtil.getStringValue(category.get("dgrcompoId"));
        String upDgrcompoId = ReportSaveUtil.getStringValue(category.get("upDgrcompoId"));
        String mayorReportYnParam = ReportSaveUtil.getStringValue(category.get("mayorReportYnParam"));

        boolean formulaFlag = true;

        String preStyleNm = "";
        if (dgrLevel == 0) {
            preStyleNm = "fismst";
            if ("Y".equals(mayorReportYnParam) == true) {
                formulaFlag = false;
            }
        } else if (dgrLevel == 1) {
            preStyleNm = "office";
            if ("Y".equals(mayorReportYnParam) == true) {
                formulaFlag = false;
            }
        } else if (dgrLevel == 2) {
            preStyleNm = "data0";
            formulaFlag = false;
        } else {
            preStyleNm = "data1";
            formulaFlag = false;
        }

        row = sheet.createRow(rowNum);
        rowNum++;
        row.setHeightInPoints(rowHeight);

        cell = row.createCell(0);
        cell.setCellStyle(styles.get(preStyleNm + "Col0"));
        if (dgrLevel == 2) {
            cell.setCellValue(totDataCnt);
        }

        cell = row.createCell(1);
        cell.setCellStyle(styles.get(preStyleNm + "Col1"));
        if (dgrLevel == 2) {
            cell.setCellValue(dataCnt);
        } else if (dgrLevel > 2) {
            cell.setCellValue(dataCnt + "-" + subCnt);
        }

        cell = row.createCell(2);
        cell.setCellStyle(styles.get(preStyleNm + "Col2"));
        cell.setCellValue(ReportSaveUtil.getStringValue(category.get("dgrcompoNm")));

        cell = row.createCell(3);
        cell.setCellStyle(styles.get(preStyleNm + "Col3"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("totFrscAmt0")));
        }

        cell = row.createCell(4);
        cell.setCellStyle(styles.get(preStyleNm + "Col4"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("preInvFrscAmt0")));
        }

        cell = row.createCell(5);
        cell.setCellStyle(styles.get(preStyleNm + "Col5"));
        if (formulaFlag == false) {
            if (bgtCompoFlag == false) {
                cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("preDefFrscAmt0")));
            } else {
                cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("preFrscAmt0")));
            }
        }

        cell = row.createCell(6);
        cell.setCellStyle(styles.get(preStyleNm + "Col6"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("dmnFrscAmt0")));
        }

        cell = row.createCell(7);
        cell.setCellStyle(styles.get(preStyleNm + "Col7"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("frscAmt0")));
        }

        cell = row.createCell(8);
        cell.setCellStyle(styles.get(preStyleNm + "Col8"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getBizListRemark(category));
        }

        cell = row.createCell(9);
        cell.setCellStyle(styles.get(preStyleNm + "Col9"));
        cell.setCellFormula("K" + rowNum + "+" + "L" + rowNum + "+" + "M" + rowNum + "+" + "N" + rowNum + "+" + "O" + rowNum + "+" + "P" + rowNum);

        cell = row.createCell(10);
        cell.setCellStyle(styles.get(preStyleNm + "Col10"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("frscAmt1")));
        }

        cell = row.createCell(11);
        cell.setCellStyle(styles.get(preStyleNm + "Col11"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("frscAmt2")));
        }

        cell = row.createCell(12);
        cell.setCellStyle(styles.get(preStyleNm + "Col12"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("frscAmt3")));
        }

        cell = row.createCell(13);
        cell.setCellStyle(styles.get(preStyleNm + "Col13"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("frscAmt4")));
        }

        cell = row.createCell(14);
        cell.setCellStyle(styles.get(preStyleNm + "Col14"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("frscAmt5")));
        }

        cell = row.createCell(15);
        cell.setCellStyle(styles.get(preStyleNm + "Col15"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("frscAmt6")));
        }

        cell = row.createCell(16);
        cell.setCellStyle(styles.get(preStyleNm + "Col16"));
        if (formulaFlag == false) {
            cell.setCellValue(ReportSaveUtil.getStringValue(category.get("reportDetlNm")));
        }

        addBizDataFormulaValue(reportFormulaUtil, upDgrcompoId, rowNum);
        if (formulaFlag == true) {
            addBizDataFormulaCell(reportFormulaUtil, dgrcompoId, rowNum);
        }

        return rowNum;
    }

    @SuppressWarnings("rawtypes")
    public void reportMerge(Map model, XSSFSheet sheet) throws Exception {
        String mergeVal = "";
        List list = null;
        Map map = null;

        list = reportCommDAO.selectReportMergeList(model);
        while (!list.isEmpty()) {
            map = (Map) list.remove(0);

            mergeVal = ReportSaveUtil.getStringValue(map.get("mergeVal"));
            if (BcjisCommUtil.isNullString(mergeVal) == false) {
                sheet.addMergedRegion(CellRangeAddress.valueOf(mergeVal));
            }
        }
    }

    public int writeCont(XSSFSheet sheet, int rowNum, String demandCont, Map<String, CellStyle> styles) {
        if (BcjisCommUtil.isNullString(demandCont) == true) {
            return rowNum;
        }

        String[] demandContArray = getContArray(demandCont, 7);

        Row row = null;
        Cell cell = null;
        for (int i = 0; i < 7; i++) {
            row = sheet.getRow(rowNum + i + 2);

            if (i < demandContArray.length) {
                cell = row.getCell(2);
                cell.setCellValue(demandContArray[i]);
            }
        }

        return rowNum;
    }

    public String[] getContArray(String cont, int maxArrLength) {
        String[] srcArr = cont.split("\n");
        int arrLength = srcArr.length < maxArrLength ? srcArr.length : maxArrLength;
        String[] tarArr = new String[arrLength];

        for (int i = 0; i < arrLength; i++) {
            tarArr[i] = srcArr[i];
        }

        StringBuffer sBuf = new StringBuffer();
        String preStr = "";
        for (int i = arrLength; i < srcArr.length; i++) {
            sBuf.append(preStr + srcArr[i]);
            preStr = " ";
        }

        if (BcjisCommUtil.isNullString(sBuf.toString()) == false) {
            tarArr[arrLength - 1] = tarArr[arrLength - 1] + " " + sBuf.toString();
        }

        return tarArr;
    }

    public void addDataFormulaValue(ReportFormulaUtil reportFormulaUtil, String keyStr, int rowNum) {
        reportFormulaUtil.addFormulaValue(keyStr + "_F", "F" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_G", "G" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_H", "H" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_I", "I" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_J", "J" + rowNum);
    }

    public void addDataFormulaCell(ReportFormulaUtil reportFormulaUtil, String keyStr, int rowNum) {
        reportFormulaUtil.addFormulaCell(keyStr + "_F", rowNum - 1, 5);
        reportFormulaUtil.addFormulaCell(keyStr + "_G", rowNum - 1, 6);
        reportFormulaUtil.addFormulaCell(keyStr + "_H", rowNum - 1, 7);
        reportFormulaUtil.addFormulaCell(keyStr + "_I", rowNum - 1, 8);
        reportFormulaUtil.addFormulaCell(keyStr + "_J", rowNum - 1, 9);
    }

