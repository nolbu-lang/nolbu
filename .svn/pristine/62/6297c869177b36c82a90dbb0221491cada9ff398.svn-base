            reportFormulaUtil.addFormulaCell(dgrcompoId + "_L", rowNum - 1, 11);
            reportFormulaUtil.addFormulaCell(dgrcompoId + "_M", rowNum - 1, 12);
        }

        if (dgrLevel == 0) {
            sheet.addMergedRegion(CellRangeAddress.valueOf("$A$" + rowNum + ":$B$" + rowNum));
        }

        return rowNum;
    }

    public int writeTotData(XSSFSheet sheet, int rowNum, JSONObject category, Map<String, CellStyle> styles, boolean bgtCompoFlag, ReportFormulaUtil reportFormulaUtil) {
        int startRowNum = rowNum + 1;

