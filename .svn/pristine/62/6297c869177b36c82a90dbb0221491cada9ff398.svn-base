                cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("preDefFrscAmt1")));
            } else {
                cell.setCellValue(ReportSaveUtil.getAmtValue(category.get("preFrscAmt1")));
            }
        }

        cell = row.createCell(8);
