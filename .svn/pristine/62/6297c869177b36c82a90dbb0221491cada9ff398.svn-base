        totData(model, wb, (List<Object>) model.get("totList"));

        bizList(model, wb, (List<Object>) model.get("bizList"));
        
        bizListTot(model, wb, (List<Object>) model.get("bizListTot"));

        data(model, wb, (List<Object>) model.get("dataList"));

        data027(model, wb, (List<Object>) model.get("dataList027"));
        
        dataTot(model, wb, (List<Object>) model.get("dataListTot"));

        if (wb.getNumberOfSheets() < 1) {
            wb.createSheet("Sheet1");
        }

        String storePathString = ReportSaveUtil.getStorePathString(config, storePath, KeyStr);
        model.put("fileName", fileNm + ".xlsx");
        model.put("realFileName", ReportSaveUtil.writeExcelFile(wb, storePathString));
    }

    @SuppressWarnings({ "rawtypes", "unchecked" })
    public void officeData(Map model, XSSFWorkbook wb, List<Object> categories) throws Exception {
        int officeDataCnt = 0;
        int officeCnt = 0;
        int officeTotDataCnt = 1;

        int rowNum = 0;
        int dgrLevel = 0;
        String preStyleNm = "";
        XSSFSheet sheet = null;

        JSONObject category = null;

        model.put("reportDetlCd", "002");
        Map reportInfo = reportCommDAO.selectReportInfo(model);

        String reportNm = String.valueOf(reportInfo.get("reportNm"));
        if (BcjisCommUtil.isNullString(reportNm) == true) {
            reportNm = "";
        }

        String sheetName = String.valueOf(reportInfo.get("sheetNm"));
        if (BcjisCommUtil.isNullString(sheetName) == true) {
            sheetName = "new sheet(office)";
        }

        sheet = wb.createSheet(sheetName);
        ReportFormulaUtil reportFormulaUtil = new ReportFormulaUtil(sheet);
        boolean bgtCompoFlag = "10".equals(ReportSaveUtil.getStringValue(reportInfo.get("bgtCompoFg"))) ? true : false;

        Map<String, CellStyle> styles = reportCommDAO.getReportStyleMap(model, wb);

        rowNum = writeOfficeHeader(model, sheet, rowNum, styles, reportInfo, reportNm);

        categories = (List<Object>) model.get("officeList");
        category = null;
        while (!categories.isEmpty()) {
            category = (JSONObject) categories.remove(0);

            dgrLevel = 0;
            try {
                dgrLevel = Integer.parseInt(String.valueOf(category.get("dgrLevel")));
            } catch (NumberFormatException nfe) {
                throw nfe;
            }

            if (dgrLevel == 0) {
                preStyleNm = "tot";
            } else {
                if (officeDataCnt < 1) {
                    preStyleNm = "data0";
                } else {
                    preStyleNm = "data1";
                }
                officeDataCnt++;
            }

            officeCnt = 0;
            try {
                officeCnt = Integer.parseInt(String.valueOf(category.get("officeCnt")));
            } catch (NumberFormatException nfe) {
                officeCnt = 0;
            }

            rowNum = writeOfficeData(sheet, rowNum, category, styles, bgtCompoFlag, officeTotDataCnt, officeCnt, officeDataCnt, preStyleNm, reportFormulaUtil);
            if (dgrLevel > 0) {
                officeTotDataCnt = officeTotDataCnt + officeCnt;
            }
        }

        writeLastSheet(model, wb, sheet, rowNum, styles, reportInfo, 10);
        reportFormulaUtil.writeCellFormula();
    }

