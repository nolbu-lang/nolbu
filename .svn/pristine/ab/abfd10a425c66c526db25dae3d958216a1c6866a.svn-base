<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://www.ibatis.com/dtd/sql-map-2.dtd">

<sqlMap namespace="DialogManageCommcdModify">

    <typeAlias alias="egovMap" type="egovframework.rte.psl.dataaccess.util.EgovMap"/>    
       
    <update id="DialogManageCommcdModify.updateDialogManageCommcd" parameterClass="Map" >
        /*DialogManageCommcdModify.updateDialogManageCommcd*/
        UPDATE TB_COMMCDDETL
           SET DETL_CD_NM = #detlCdNm#
         WHERE 1=1
           AND CL_CD = #clCd#
           AND DETL_CD = #detlCd#
    </update>

</sqlMap>
