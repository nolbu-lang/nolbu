        cell.setCellValue(ReportSaveUtil.getStringValue(category.get("srchVal")));

        addListDataFormulaValue(reportFormulaUtil, "sum" + startRow, rowNum, bgtCompoFlag); //부서별 합계에 컬럼명 더하기
        
        return rowNum;
    }

    public void addListDataFormulaValue(ReportFormulaUtil reportFormulaUtil, String keyStr, int rowNum, boolean bgtCompoFlag) {
        reportFormulaUtil.addFormulaValue(keyStr + "_C", "C" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_D", "D" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_E", "E" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_F", "F" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_G", "G" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_J", "J" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_K", "K" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_L", "L" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_M", "M" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_N", "N" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_O", "O" + rowNum);
    }

    public void addListDataFormulaCell(ReportFormulaUtil reportFormulaUtil, String keyStr, int rowNum, boolean bgtCompoFlag) {
        reportFormulaUtil.addFormulaCell(keyStr + "_C", rowNum - 1, 2);
        reportFormulaUtil.addFormulaCell(keyStr + "_D", rowNum - 1, 3);
        reportFormulaUtil.addFormulaCell(keyStr + "_E", rowNum - 1, 4);
        reportFormulaUtil.addFormulaCell(keyStr + "_F", rowNum - 1, 5);
        reportFormulaUtil.addFormulaCell(keyStr + "_G", rowNum - 1, 6);
        reportFormulaUtil.addFormulaCell(keyStr + "_J", rowNum - 1, 9);
        reportFormulaUtil.addFormulaCell(keyStr + "_K", rowNum - 1, 10);
        reportFormulaUtil.addFormulaCell(keyStr + "_L", rowNum - 1, 11);
        reportFormulaUtil.addFormulaCell(keyStr + "_M", rowNum - 1, 12);
        reportFormulaUtil.addFormulaCell(keyStr + "_N", rowNum - 1, 13);
        reportFormulaUtil.addFormulaCell(keyStr + "_O", rowNum - 1, 14);
    }
    
    public void addBizDataFormulaValue(ReportFormulaUtil reportFormulaUtil, String keyStr, int rowNum, boolean bgtCompoFlag) {
        reportFormulaUtil.addFormulaValue(keyStr + "_D", "D" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_E", "E" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_F", "F" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_G", "G" + rowNum);
        reportFormulaUtil.addFormulaValue(keyStr + "_H", "H" + rowNum);
    }

    public void addBizDataFormulaCell(ReportFormulaUtil reportFormulaUtil, String keyStr, int rowNum, boolean bgtCompoFlag) {
        reportFormulaUtil.addFormulaCell(keyStr + "_D", rowNum - 1, 3);
        reportFormulaUtil.addFormulaCell(keyStr + "_E", rowNum - 1, 4);
        reportFormulaUtil.addFormulaCell(keyStr + "_F", rowNum - 1, 5);
        reportFormulaUtil.addFormulaCell(keyStr + "_G", rowNum - 1, 6);
        reportFormulaUtil.addFormulaCell(keyStr + "_H", rowNum - 1, 7);
    }

    public List<Report0F0SaveFrscAmtsVO> getFrscAmts(JSONObject category, boolean bgtCompoFlag) {
        List<Report0F0SaveFrscAmtsVO> list = new ArrayList<Report0F0SaveFrscAmtsVO>();

        //최종예산, 증감액, 요구액, 조정액
        long dmnFrscAmt1 = ReportSaveUtil.getAmtValue(category.get("dmnFrscAmt1")); //최종예산
        long preFrscAmt1 = ReportSaveUtil.getAmtValue(category.get("preFrscAmt1")); //증감액
        long preDefFrscAmt1 = ReportSaveUtil.getAmtValue(category.get("preDefFrscAmt1")); //요구액
        long frscAmt1 = ReportSaveUtil.getAmtValue(category.get("frscAmt1")); //조정액

        long dmnFrscAmt2 = ReportSaveUtil.getAmtValue(category.get("dmnFrscAmt2"));
        long preFrscAmt2 = ReportSaveUtil.getAmtValue(category.get("preFrscAmt2"));
        long preDefFrscAmt2 = ReportSaveUtil.getAmtValue(category.get("preDefFrscAmt2"));
        long frscAmt2 = ReportSaveUtil.getAmtValue(category.get("frscAmt2"));

        long dmnFrscAmt3 = ReportSaveUtil.getAmtValue(category.get("dmnFrscAmt3"));
        long preFrscAmt3 = ReportSaveUtil.getAmtValue(category.get("preFrscAmt3"));
        long preDefFrscAmt3 = ReportSaveUtil.getAmtValue(category.get("preDefFrscAmt3"));
        long frscAmt3 = ReportSaveUtil.getAmtValue(category.get("frscAmt3"));

        long dmnFrscAmt4 = ReportSaveUtil.getAmtValue(category.get("dmnFrscAmt4"));
        long preFrscAmt4 = ReportSaveUtil.getAmtValue(category.get("preFrscAmt4"));
        long preDefFrscAmt4 = ReportSaveUtil.getAmtValue(category.get("preDefFrscAmt4"));
        long frscAmt4 = ReportSaveUtil.getAmtValue(category.get("frscAmt4"));

        long dmnFrscAmt6 = ReportSaveUtil.getAmtValue(category.get("dmnFrscAmt6"));
        long preFrscAmt6 = ReportSaveUtil.getAmtValue(category.get("preFrscAmt6"));
        long preDefFrscAmt6 = ReportSaveUtil.getAmtValue(category.get("preDefFrscAmt6"));
        long frscAmt6 = ReportSaveUtil.getAmtValue(category.get("frscAmt6"));
        
        long dmnFrscAmt7 = ReportSaveUtil.getAmtValue(category.get("dmnFrscAmt7"));
        long preFrscAmt7 = ReportSaveUtil.getAmtValue(category.get("preFrscAmt7"));
        long preDefFrscAmt7 = ReportSaveUtil.getAmtValue(category.get("preDefFrscAmt7"));
        long frscAmt7 = ReportSaveUtil.getAmtValue(category.get("frscAmt7"));
        
        dmnFrscAmt6 = dmnFrscAmt6 + dmnFrscAmt7;
        preFrscAmt6 = preFrscAmt6 + preFrscAmt7;
        preDefFrscAmt6 = preDefFrscAmt6 + preDefFrscAmt7;
        frscAmt6 = frscAmt6 + frscAmt7;
        
        //총사업비, 기투자
        long totFrscAmt1 = ReportSaveUtil.getAmtValue(category.get("totFrscAmt1"));
        long preInvFrscAmt1 = ReportSaveUtil.getAmtValue(category.get("preInvFrscAmt1"));
        
        long totFrscAmt2 = ReportSaveUtil.getAmtValue(category.get("totFrscAmt2"));
        long preInvFrscAmt2 = ReportSaveUtil.getAmtValue(category.get("preInvFrscAmt2"));
        
        long totFrscAmt3 = ReportSaveUtil.getAmtValue(category.get("totFrscAmt3"));
        long preInvFrscAmt3 = ReportSaveUtil.getAmtValue(category.get("preInvFrscAmt3"));
        
        long totFrscAmt4 = ReportSaveUtil.getAmtValue(category.get("totFrscAmt4"));
        long preInvFrscAmt4 = ReportSaveUtil.getAmtValue(category.get("preInvFrscAmt4"));
        
        long totFrscAmt5 = ReportSaveUtil.getAmtValue(category.get("totFrscAmt5"));
        long preInvFrscAmt5 = ReportSaveUtil.getAmtValue(category.get("preInvFrscAmt5"));
        
        long totFrscAmt6 = ReportSaveUtil.getAmtValue(category.get("totFrscAmt6"));
        long preInvFrscAmt6 = ReportSaveUtil.getAmtValue(category.get("preInvFrscAmt6"));
        
        long totCharAmt1 = ReportSaveUtil.getAmtValue(category.get("totCharAmt1"));
        long preInvCharAmt1 = ReportSaveUtil.getAmtValue(category.get("preInvCharAmt1"));
        
        long totCharAmt2 = ReportSaveUtil.getAmtValue(category.get("totCharAmt2"));
        long preInvCharAmt2 = ReportSaveUtil.getAmtValue(category.get("preInvCharAmt2"));
        
        long totCharAmt3 = ReportSaveUtil.getAmtValue(category.get("totCharAmt3"));
        long preInvCharAmt3 = ReportSaveUtil.getAmtValue(category.get("preInvCharAmt3"));
        /*
        System.out.println("시 : " + totFrscAmt1 + "  " + preInvFrscAmt1);
        System.out.println("국 : " + totFrscAmt2 + "  " + preInvFrscAmt2);
        System.out.println("교 : " + totFrscAmt3 + "  " + preInvFrscAmt3);
        System.out.println("지 : " + totFrscAmt4 + "  " + preInvFrscAmt4);
        System.out.println("채 : " + totFrscAmt5 + "  " + preInvFrscAmt5);
        System.out.println("기 : " + totFrscAmt6 + "  " + preInvFrscAmt6);
        */
        
        if (totFrscAmt1 == 0 && preInvFrscAmt1 == 0 && totFrscAmt2 == 0 && preInvFrscAmt2 == 0 && totFrscAmt3 == 0 && preInvFrscAmt3 == 0 && totFrscAmt4 == 0 && preInvFrscAmt4 == 0 && totFrscAmt5 == 0 && preInvFrscAmt5 == 0 && totFrscAmt6 == 0 && preInvFrscAmt6 == 0 && totCharAmt1 == 0 && preInvCharAmt1 == 0 && totCharAmt2 == 0 && preInvCharAmt2 == 0 && totCharAmt3 == 0 && preInvCharAmt3 == 0
        		&& dmnFrscAmt1 == 0 && preFrscAmt1 == 0 && preDefFrscAmt1 == 0 && frscAmt1 == 0 
        		&& dmnFrscAmt2 == 0 && preFrscAmt2 == 0 && preDefFrscAmt2 == 0 && frscAmt2 == 0 
        		&& dmnFrscAmt3 == 0 && preFrscAmt3 == 0 && preDefFrscAmt3 == 0 && frscAmt3 == 0 
        		&& dmnFrscAmt4 == 0 && preFrscAmt4 == 0 && preDefFrscAmt4 == 0 && frscAmt4 == 0 
        		&& dmnFrscAmt6 == 0 && preFrscAmt6 == 0 && preDefFrscAmt6 == 0 && frscAmt6 == 0 
        		) {
            return list;
        }

        //if (dmnFrscAmt1 != 0 || preFrscAmt1 != 0 || preDefFrscAmt1 != 0 || frscAmt1 != 0) {
        if (totFrscAmt1 != 0 || preInvFrscAmt1 != 0 || dmnFrscAmt1 != 0 || preFrscAmt1 != 0 || preDefFrscAmt1 != 0 || frscAmt1 != 0) {
            list.add(new Report0F0SaveFrscAmtsVO("시", totFrscAmt1, preInvFrscAmt1, dmnFrscAmt1, preFrscAmt1, preDefFrscAmt1, frscAmt1));
        }
        
        //if (dmnFrscAmt2 != 0 || preFrscAmt2 != 0 || preDefFrscAmt2 != 0 || frscAmt2 != 0) {
        if (totFrscAmt2 != 0 || preInvFrscAmt2 != 0 || dmnFrscAmt2 != 0 || preFrscAmt2 != 0 || preDefFrscAmt2 != 0 || frscAmt2 != 0) {
        	list.add(new Report0F0SaveFrscAmtsVO("국", totFrscAmt2, preInvFrscAmt2, dmnFrscAmt2, preFrscAmt2, preDefFrscAmt2, frscAmt2));
        }
        
        //if (dmnFrscAmt3 != 0 || preFrscAmt3 != 0 || preDefFrscAmt3 != 0 || frscAmt3 != 0) {
        if (totFrscAmt3 != 0 || preInvFrscAmt3 != 0 || dmnFrscAmt3 != 0 || preFrscAmt3 != 0 || preDefFrscAmt3 != 0 || frscAmt3 != 0) {
        	list.add(new Report0F0SaveFrscAmtsVO("교", totFrscAmt3, preInvFrscAmt3, dmnFrscAmt3, preFrscAmt3, preDefFrscAmt3, frscAmt3));
        }
        
        //if (dmnFrscAmt4 != 0 || preFrscAmt4 != 0 || preDefFrscAmt4 != 0 || frscAmt4 != 0) {
        if (totFrscAmt4 != 0 || preInvFrscAmt4 != 0 || dmnFrscAmt4 != 0 || preFrscAmt4 != 0 || preDefFrscAmt4 != 0 || frscAmt4 != 0) {
        	list.add(new Report0F0SaveFrscAmtsVO("지", totFrscAmt4, preInvFrscAmt4, dmnFrscAmt4, preFrscAmt4, preDefFrscAmt4, frscAmt4));
        }
        
        if (totFrscAmt5 != 0 || preInvFrscAmt5 != 0) {
        	//list.add(new Report0F0SaveFrscAmtsVO("채", totFrscAmt5, preInvFrscAmt5, 0L, 0L, 0L, 0L));
        }
        
        //if (dmnFrscAmt6 != 0 || preFrscAmt6 != 0 || preDefFrscAmt6 != 0 || frscAmt6 != 0) {
        if (totFrscAmt6 != 0 || preInvFrscAmt6 != 0 || dmnFrscAmt6 != 0 || preFrscAmt6 != 0 || preDefFrscAmt6 != 0 || frscAmt6 != 0) {
        	list.add(new Report0F0SaveFrscAmtsVO("기", totFrscAmt6, preInvFrscAmt6, dmnFrscAmt6, preFrscAmt6, preDefFrscAmt6, frscAmt6));
        }
        
        if (totCharAmt1 != 0 || preInvCharAmt1 != 0) {
        	list.add(new Report0F0SaveFrscAmtsVO("공", totCharAmt1, preInvCharAmt1, 0L, 0L, 0L, 0L));
        }
        
        if (totCharAmt2 != 0 || preInvCharAmt2 != 0) {
        	list.add(new Report0F0SaveFrscAmtsVO("보", totCharAmt2, preInvCharAmt2, 0L, 0L, 0L, 0L));
        }
        
        if (totCharAmt3 != 0 || preInvCharAmt3 != 0) {
        	list.add(new Report0F0SaveFrscAmtsVO("기", totCharAmt3, preInvCharAmt3, 0L, 0L, 0L, 0L));
        }

        return list;
    }
    
    public static String getBizListRemarkList(JSONObject category, int unit) {
        StringBuffer sBuf = new StringBuffer();

        Long amtL = ReportSaveUtil.getAmtValue(category.get("totFrscAmt2"));
        if(amtL != 0){
        	amtL = amtL / unit;
        }
        String amt = ReportSaveUtil.getAmtStrValue(amtL);
        String preStr = "";

        if ("0".equals(amt) == false) {
            sBuf.append("· 국비 " + amt);
            preStr = "\n";
        }

        amtL = ReportSaveUtil.getAmtValue(category.get("totFrscAmt3"));
        if(amtL != 0){
        	amtL = amtL / unit;
        }
        amt = ReportSaveUtil.getAmtStrValue(amtL);
        if ("0".equals(amt) == false) {
            sBuf.append(preStr + "· 교부세 " + amt);
            preStr = "\n";
        }

        amtL = ReportSaveUtil.getAmtValue(category.get("totFrscAmt5"));
        if(amtL != 0){
        	amtL = amtL / unit;
        }
        amt = ReportSaveUtil.getAmtStrValue(amtL);
        if ("0".equals(amt) == false) {
            sBuf.append(preStr + "· 채무 " + amt + " 별도");
            preStr = "\n";
        }

        amtL = ReportSaveUtil.getAmtValue(category.get("totFrscAmt6"));
        if(amtL != 0){
        	amtL = amtL / unit;
        }
        amt = ReportSaveUtil.getAmtStrValue(amtL);
        if ("0".equals(amt) == false) {
            sBuf.append(preStr + "· 기타 " + amt + " 별도");
            preStr = "\n";
        }

        return sBuf.toString();
    }
}
