<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN" "http://www.ibatis.com/dtd/sql-map-2.dtd">

<sqlMap namespace="ReportWrite070">

    <typeAlias alias="egovMap" type="egovframework.rte.psl.dataaccess.util.EgovMap"/>
    
    <select id="ReportWrite070.selectReport070List" parameterClass="Map" resultClass="egovMap" >
        /*ReportWrite070.selectReport070List*/
        SELECT T.DGRCOMPO_ID AS DGRCOMPO_ID
             , T.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
             , T.DGR_LEVEL AS DGR_LEVEL
             , T.FIS_YEAR AS FIS_YEAR
             , T.BGT_DGR AS BGT_DGR
             , T.ORDER_YMD_SEQ AS ORDER_YMD_SEQ
             , T.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
             , T.REPORT_CD AS REPORT_CD
             , T.REPORT_DETL_CD AS REPORT_DETL_CD
             , T.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
             , T.DEMAND_COMP_FORMULAR AS DEMAND_COMP_FORMULAR
             , T.COMP_FORMULAR AS COMP_FORMULAR
             , T.COMPO_LEVEL AS COMPO_LEVEL
             , T.REFLECT_FG AS REFLECT_FG
             , T.DEMAND_CONT AS DEMAND_CONT
             , T.EXAM_CONT AS EXAM_CONT
             , T.EXAM_CONT AS EXAM_CONT_VIEW
             , T.SRCH_VAL AS SRCH_VAL
             , T.SRCH_VAL AS SRCH_VAL_VIEW
             , T.REPORT_SORT_SEQ AS REPORT_SORT_SEQ
             , T.REPORT_SORT_SEQ AS REPORT_SORT_SEQ_VIEW
             , CAST((T.CONSIDER_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT0
             , CAST((T.CONSIDER_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT1
             , CAST((T.CONSIDER_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT2
             , CAST((T.CONSIDER_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT3
             , CAST((T.CONSIDER_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT4
             , CAST((T.CONSIDER_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT5
             , CAST((T.CONSIDER_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT6
             , CAST((T.DIFF_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT0
             , CAST((T.DIFF_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT1
             , CAST((T.DIFF_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT2
             , CAST((T.DIFF_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT3
             , CAST((T.DIFF_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT4
             , CAST((T.DIFF_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT5
             , CAST((T.DIFF_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DIFF_AMT6
             , CAST((T.FRSC_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT0
             , CAST((T.FRSC_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT1
             , CAST((T.FRSC_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT2
             , CAST((T.FRSC_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT3
             , CAST((T.FRSC_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT4
             , CAST((T.FRSC_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT5
             , CAST((T.FRSC_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT6
             , CAST((T.DMN_FRSC_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT0
             , CAST((T.DMN_FRSC_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT1
             , CAST((T.DMN_FRSC_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT2
             , CAST((T.DMN_FRSC_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT3
             , CAST((T.DMN_FRSC_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT4
             , CAST((T.DMN_FRSC_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT5
             , CAST((T.DMN_FRSC_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT6
             , TRIM(CASE WHEN T.DGR_LEVEL = 0 THEN '합계'
                         WHEN T.DGR_LEVEL > 0 THEN T.LAVEL_SYMBOL || T.COMP_GROUND
                         ELSE ''
                    END) AS DGRCOMPO_NM
             , T.UP_DGRCOMPO_ID AS PARENT
             , CASE WHEN T.CHILD_CNT > 0  THEN 'false'
                    ELSE 'true'
               END AS IS_LEAF
             , 'true' AS EXPANDED
             , 'true' AS LOADED
             , T.DGR_LEVEL AS "LEVEL"
          FROM (SELECT A.DGRCOMPO_ID AS DGRCOMPO_ID
                     , A.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
                     , A.DGR_LEVEL AS DGR_LEVEL
                     , A.FIS_YEAR AS FIS_YEAR
                     , A.BGT_DGR AS BGT_DGR
                     , A.ORDER_YMD_SEQ AS ORDER_YMD_SEQ
                     , A.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
                     , A.REPORT_CD AS REPORT_CD
                     , A.REPORT_DETL_CD AS REPORT_DETL_CD
                     , A.FIS_FG_CD AS FIS_FG_CD
                     , A.OFFICE_CD AS OFFICE_CD
                     , A.DEPT_CD AS DEPT_CD
                     , A.DBIZ_CD AS DBIZ_CD
                     , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                     , A.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
                     , A.DEMAND_COMP_FORMULAR AS DEMAND_COMP_FORMULAR
                     , A.COMP_FORMULAR AS COMP_FORMULAR
                     , A.COMPO_LEVEL AS COMPO_LEVEL
                     , A.COMP_GROUND AS COMP_GROUND
                     , A.SORT_SEQ AS SORT_SEQ
                     , A.CONSIDER_AMT1 + A.CONSIDER_AMT2 + A.CONSIDER_AMT3 + A.CONSIDER_AMT4 + A.CONSIDER_AMT5 + A.CONSIDER_AMT6 AS CONSIDER_AMT0
                     , A.CONSIDER_AMT1 AS CONSIDER_AMT1
                     , A.CONSIDER_AMT2 AS CONSIDER_AMT2
                     , A.CONSIDER_AMT3 AS CONSIDER_AMT3
                     , A.CONSIDER_AMT4 AS CONSIDER_AMT4
                     , A.CONSIDER_AMT5 AS CONSIDER_AMT5
                     , A.CONSIDER_AMT6 AS CONSIDER_AMT6
                     , A.FRSC_AMT1 + A.FRSC_AMT2 + A.FRSC_AMT3 + A.FRSC_AMT4 + A.FRSC_AMT5 + A.FRSC_AMT6 AS FRSC_AMT0
                     , A.FRSC_AMT1 AS FRSC_AMT1
                     , A.FRSC_AMT2 AS FRSC_AMT2
                     , A.FRSC_AMT3 AS FRSC_AMT3
                     , A.FRSC_AMT4 AS FRSC_AMT4
                     , A.FRSC_AMT5 AS FRSC_AMT5
                     , A.FRSC_AMT6 AS FRSC_AMT6
                     , A.DMN_FRSC_AMT1 + A.DMN_FRSC_AMT2 + A.DMN_FRSC_AMT3 + A.DMN_FRSC_AMT4 + A.DMN_FRSC_AMT5 + A.DMN_FRSC_AMT6 AS DMN_FRSC_AMT0
                     , A.DMN_FRSC_AMT1 AS DMN_FRSC_AMT1
                     , A.DMN_FRSC_AMT2 AS DMN_FRSC_AMT2
                     , A.DMN_FRSC_AMT3 AS DMN_FRSC_AMT3
                     , A.DMN_FRSC_AMT4 AS DMN_FRSC_AMT4
                     , A.DMN_FRSC_AMT5 AS DMN_FRSC_AMT5
                     , A.DMN_FRSC_AMT6 AS DMN_FRSC_AMT6
                     , A.FRSC_AMT1 - A.CONSIDER_AMT1
                       + A.FRSC_AMT2 - A.CONSIDER_AMT2
                       + A.FRSC_AMT3 - A.CONSIDER_AMT3
                       + A.FRSC_AMT4 - A.CONSIDER_AMT4
                       + A.FRSC_AMT5 - A.CONSIDER_AMT5
                       + A.FRSC_AMT6 - A.CONSIDER_AMT6 AS DIFF_AMT0
                     , A.FRSC_AMT1 - A.CONSIDER_AMT1 AS DIFF_AMT1
                     , A.FRSC_AMT2 - A.CONSIDER_AMT2 AS DIFF_AMT2
                     , A.FRSC_AMT3 - A.CONSIDER_AMT3 AS DIFF_AMT3
                     , A.FRSC_AMT4 - A.CONSIDER_AMT4 AS DIFF_AMT4
                     , A.FRSC_AMT5 - A.CONSIDER_AMT5 AS DIFF_AMT5
                     , A.FRSC_AMT6 - A.CONSIDER_AMT6 AS DIFF_AMT6
                     , A.REFLECT_FG AS REFLECT_FG
                     , A.DEMAND_CONT AS DEMAND_CONT
                     , A.EXAM_CONT AS EXAM_CONT
                     , A.SRCH_VAL AS SRCH_VAL
                     , A.REPORT_SORT_SEQ AS REPORT_SORT_SEQ
                     , NVL((SELECT Z.OFFICE_RANK FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.OFFICE_CD = A.OFFICE_CD AND ROWNUM = 1), 0) AS OFFICE_RANK
                     , NVL((SELECT Z.OFFICE_NM FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.OFFICE_CD = A.OFFICE_CD AND ROWNUM = 1), '') AS OFFICE_NM
                     , NVL((SELECT Z.DEPT_RANK FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DEPT_CD = A.DEPT_CD AND ROWNUM = 1), 0) AS DEPT_RANK
                     , NVL((SELECT Z.DEPT_NM FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DEPT_CD = A.DEPT_CD AND ROWNUM = 1), '') AS DEPT_NM
                     , NVL((SELECT Z.PBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS PBIZ_RANK
                     , NVL((SELECT Z.PBIZ_CD FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), '0000000000000000') AS PBIZ_CD
                     , NVL((SELECT Z.UBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS UBIZ_RANK
                     , NVL((SELECT Z.UBIZ_CD FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), '0000000000000000') AS UBIZ_CD
                     , NVL((SELECT Z.DBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS DBIZ_RANK
                     , NVL((SELECT Z.DBIZ_NM FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), '') AS DBIZ_NM
                     , DECODE(A.TE_MNG_MOK_CD, NULL, '', '00000', '', SUBSTR(A.TE_MNG_MOK_CD, 1, 3) || '-' || SUBSTR(A.TE_MNG_MOK_CD, 4)) ||' ' || 
                       NVL((SELECT Z.TE_MNG_MOK_NM FROM TB_DGRTEMNGMOK Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.TE_MNG_MOK_CD = A.TE_MNG_MOK_CD AND ROWNUM = 1), '') AS TE_MNG_MOK_NM
                     , NVL((SELECT COUNT(*) FROM TB_DGRCOMPO Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.UP_TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID), 0) AS CHILD_CNT
                     , NVL((SELECT Z.SYMBOL FROM TB_DGRCOMPOSYMBOL Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.COMPO_LEVEL = A.COMPO_LEVEL AND SYMBOL_LENGTH > 0), '') AS LAVEL_SYMBOL
                  FROM (SELECT T.*
                          FROM (SELECT DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_DETL_CD || '_' || '00000000000'
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_DETL_CD || '_' || A.TE_BGT_COMPO_ID) AS DGRCOMPO_ID
                                     , DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_CD || '_' || '00000000000'
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_DETL_CD || '_' || A.UP_TE_BGT_COMPO_ID) AS UP_DGRCOMPO_ID
                                     , DECODE(H.CT, 1, 0, 2, A.COMPO_LEVEL) AS DGR_LEVEL
                                     , A.FIS_YEAR AS FIS_YEAR
                                     , A.BGT_DGR AS BGT_DGR
                                     , A.ORDER_YMD_SEQ AS ORDER_YMD_SEQ
                                     , A.REPORT_CD AS REPORT_CD
                                     , A.REPORT_DETL_CD AS REPORT_DETL_CD
                                     , DECODE(H.CT, 1, '00000000000', A.TE_BGT_COMPO_ID) AS TE_BGT_COMPO_ID 
                                     , DECODE(H.CT, 1, '0000', A.FIS_FG_CD) AS FIS_FG_CD
                                     , DECODE(H.CT, 1, '0000', A.OFFICE_CD) AS OFFICE_CD
                                     , DECODE(H.CT, 1, '0000', A.DEPT_CD) AS DEPT_CD
                                     , DECODE(H.CT, 1, '0000000000000000', A.DBIZ_CD) AS DBIZ_CD 
                                     , DECODE(H.CT, 1, '00000', A.TE_MNG_MOK_CD) AS TE_MNG_MOK_CD 
                                     , DECODE(H.CT, 1, 0, A.TE_BGT_COMPO_SEQ) AS TE_BGT_COMPO_SEQ 
                                     , DECODE(H.CT, 1, '', A.DEMAND_COMP_FORMULAR) AS DEMAND_COMP_FORMULAR 
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DEMAND_DIFF_AMT, 0), A.DEMAND_DIFF_AMT)) AS DEMAND_DIFF_AMT
                                     , DECODE(H.CT, 1, '0', A.COMPO_LEVEL) AS COMPO_LEVEL 
                                     , DECODE(H.CT, 1, '', A.COMP_GROUND) AS COMP_GROUND 
                                     , DECODE(H.CT, 1, '', A.COMP_FORMULAR) AS COMP_FORMULAR 
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DIFF_AMT, 0), A.DIFF_AMT)) AS DIFF_AMT
                                     , DECODE(H.CT, 1, 0, A.SORT_SEQ) AS SORT_SEQ 
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT1, 0), A.CONSIDER_AMT1)) AS CONSIDER_AMT1
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT2, 0), A.CONSIDER_AMT2)) AS CONSIDER_AMT2
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT3, 0), A.CONSIDER_AMT3)) AS CONSIDER_AMT3
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT4, 0), A.CONSIDER_AMT4)) AS CONSIDER_AMT4
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT5, 0), A.CONSIDER_AMT5)) AS CONSIDER_AMT5
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT6, 0), A.CONSIDER_AMT6)) AS CONSIDER_AMT6
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT1, 0), A.FRSC_AMT1)) AS FRSC_AMT1
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT2, 0), A.FRSC_AMT2)) AS FRSC_AMT2
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT3, 0), A.FRSC_AMT3)) AS FRSC_AMT3
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT4, 0), A.FRSC_AMT4)) AS FRSC_AMT4
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT5, 0), A.FRSC_AMT5)) AS FRSC_AMT5
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT6, 0), A.FRSC_AMT6)) AS FRSC_AMT6
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT1, 0), A.DMN_FRSC_AMT1)) AS DMN_FRSC_AMT1
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT2, 0), A.DMN_FRSC_AMT2)) AS DMN_FRSC_AMT2
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT3, 0), A.DMN_FRSC_AMT3)) AS DMN_FRSC_AMT3
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT4, 0), A.DMN_FRSC_AMT4)) AS DMN_FRSC_AMT4
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT5, 0), A.DMN_FRSC_AMT5)) AS DMN_FRSC_AMT5
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT6, 0), A.DMN_FRSC_AMT6)) AS DMN_FRSC_AMT6
                                     , DECODE(H.CT, 1, '', A.REFLECT_FG) AS REFLECT_FG 
                                     , DECODE(H.CT, 1, '', A.DEMAND_CONT) AS DEMAND_CONT 
                                     , DECODE(H.CT, 1, '', A.EXAM_CONT) AS EXAM_CONT 
                                     , DECODE(H.CT, 1, '', A.SRCH_VAL) AS SRCH_VAL
                                     , DECODE(H.CT, 1, '', A.REPORT_SORT_SEQ) AS REPORT_SORT_SEQ
                                  FROM (SELECT A.FIS_YEAR AS FIS_YEAR
                                             , A.BGT_DGR AS BGT_DGR
                                             , A.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID 
                                             , A.UP_TE_BGT_COMPO_ID AS UP_TE_BGT_COMPO_ID
                                             , A.DEPT_CD AS DEPT_CD
                                             , A.DBIZ_CD AS DBIZ_CD 
                                             , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD 
                                             , A.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ 
                                             , A.DEMAND_COMP_FORMULAR AS DEMAND_COMP_FORMULAR 
                                             , A.DEMAND_DIFF_AMT AS DEMAND_DIFF_AMT
                                             , A.COMPO_LEVEL AS COMPO_LEVEL 
                                             , A.COMP_GROUND AS COMP_GROUND 
                                             , A.COMP_FORMULAR AS COMP_FORMULAR 
                                             , A.DIFF_AMT AS DIFF_AMT
                                             , A.SORT_SEQ AS SORT_SEQ 
                                             , B.OFFICE_CD AS OFFICE_CD
                                             , C.FIS_FG_CD AS FIS_FG_CD
                                             , E.ORDER_YMD_SEQ AS ORDER_YMD_SEQ
                                             , E.REPORT_CD AS REPORT_CD
                                             , E.REPORT_DETL_CD AS REPORT_DETL_CD
                                             , E.REFLECT_FG AS REFLECT_FG 
                                             , E.DEMAND_CONT AS DEMAND_CONT 
                                             , E.EXAM_CONT AS EXAM_CONT 
                                             , E.SRCH_VAL AS SRCH_VAL
                                             , E.REPORT_SORT_SEQ AS REPORT_SORT_SEQ
                                             , E.CONSIDER_AMT1 AS CONSIDER_AMT1
                                             , E.CONSIDER_AMT2 AS CONSIDER_AMT2
                                             , E.CONSIDER_AMT3 AS CONSIDER_AMT3
                                             , E.CONSIDER_AMT4 AS CONSIDER_AMT4
                                             , E.CONSIDER_AMT5 AS CONSIDER_AMT5
                                             , E.CONSIDER_AMT6 AS CONSIDER_AMT6
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '160', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT1
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '110', BB.ADJ_DEF_FRSC_AMT, '120', BB.ADJ_DEF_FRSC_AMT, '130', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT2
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '140', BB.ADJ_DEF_FRSC_AMT, '150', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT3
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '180', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT4
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '190', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT5
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '170', BB.ADJ_DEF_FRSC_AMT, '200', BB.ADJ_DEF_FRSC_AMT, '210', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT6
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '160', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT1
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '110', BB.DMN_DEF_FRSC_AMT, '120', BB.DMN_DEF_FRSC_AMT, '130', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT2
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '140', BB.DMN_DEF_FRSC_AMT, '150', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT3
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '180', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT4
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '190', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT5
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '170', BB.DMN_DEF_FRSC_AMT, '200', BB.DMN_DEF_FRSC_AMT, '210', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT6
                                          FROM TB_DGRCOMPO A
                                             , TB_DGRDEPT B
                                             , TB_DGRBIZ C
                                             , TB_YEARFISFG D
                                             , TB_REPORT070 E
                                         WHERE 1 = 1
                                         <isEqual prepend="" property="userDeptYn" compareValue="Y">
                                           AND EXISTS (SELECT 1
                                                         FROM TB_USERDEPT Z
                                                        WHERE Z.USER_ID = #userId#
                                                          AND Z.DEPT_CD = B.DEPT_CD
                                                          AND Z.USE_YN = 'Y'
                                                          AND ROWNUM = 1
                                                      )
                                         </isEqual>
                                           AND D.FIS_YEAR = C.FIS_YEAR
                                           AND D.FIS_FG_CD = C.FIS_FG_CD
                                           AND C.FIS_YEAR = A.FIS_YEAR
                                           AND C.BGT_DGR = A.BGT_DGR
                                           AND C.DBIZ_CD = A.DBIZ_CD
                                           AND B.FIS_YEAR = A.FIS_YEAR
                                           AND B.BGT_DGR = A.BGT_DGR
                                           AND B.DEPT_CD = A.DEPT_CD
                                           AND A.FIS_YEAR = E.FIS_YEAR
                                           AND A.BGT_DGR = E.BGT_DGR
                                           AND A.TE_BGT_COMPO_ID = E.TE_BGT_COMPO_ID
                                           AND E.REPORT_CD = #reportCd#
                                           AND E.REPORT_DETL_CD = #reportDetlCd#
                                           AND E.FIS_YEAR = #fisYear#
                                           AND E.BGT_DGR = #bgtDgr#
                                         <isNotEmpty prepend="" property="fisFgMstCd">
                                           AND D.FIS_FG_MST_CD = #fisFgMstCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="fisFgCd">
                                           AND D.FIS_FG_CD = #fisFgCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="orderYmdSeq">
                                           AND E.ORDER_YMD_SEQ = #orderYmdSeq#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="srchVal">
                                           AND E.SRCH_VAL LIKE '%' || #srchVal# || '%'
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="officeCd">
                                           AND B.OFFICE_CD = #officeCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="deptRankFr">
                                           AND B.DEPT_RANK <![CDATA[>=]]> #deptRankFr#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="deptRankTo">
                                           AND B.DEPT_RANK <![CDATA[<=]]> #deptRankTo#
                                         </isNotEmpty>
                                         <isEqual prepend="" property="frscFrCdYn" compareValue="Y">
                                           AND EXISTS (SELECT 1
                                                         FROM TB_DGRCOMPOFRSC Z
                                                        WHERE 1 = 1
                                                          AND Z.FIS_YEAR = A.FIS_YEAR
                                                          AND Z.BGT_DGR = A.BGT_DGR
                                                          AND Z.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID
                                                          AND Z.ADJ_DEF_FRSC_AMT <![CDATA[<>]]> 0                                                      
                                                        <isNotEmpty prepend="" property="frscFgCdFr">
                                                          AND Z.FRSC_FG_CD <![CDATA[>=]]> #frscFgCdFr#
                                                        </isNotEmpty>                                                      
                                                        <isNotEmpty prepend="" property="frscFgCdTo">
                                                          AND Z.FRSC_FG_CD <![CDATA[<=]]> #frscFgCdTo#
                                                        </isNotEmpty>
                                                      )
                                         </isEqual>
                                       ) A
                                     , (SELECT ROWNUM AS CT FROM TB_COMMCD WHERE ROWNUM BETWEEN 1 AND 2) H
                                 WHERE 1 = 1
                                 GROUP BY DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_DETL_CD || '_' || '00000000000'
                                                     , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_DETL_CD || '_' || A.TE_BGT_COMPO_ID)
                               ) T
                       ) A
               ) T
         WHERE 1 = 1
         ORDER BY T.FIS_YEAR
                , NVL(T.BGT_DGR, 0)
                , NVL(T.ORDER_YMD_SEQ, '000')
                , CASE WHEN NVL(T.REPORT_SORT_SEQ, '') = '' THEN NVL(T.FIS_FG_CD, '000') ||
                                                                 NVL(T.OFFICE_RANK, 0) || '_' || NVL(T.OFFICE_CD, '0000000') || '_' || 
                                                                 NVL(T.DEPT_RANK, 0) || '_' || NVL(T.DEPT_CD, '0000000') || '_' || 
                                                                 NVL(T.PBIZ_RANK, 0) || '_' || NVL(T.PBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.UBIZ_RANK, 0) || '_' || NVL(T.UBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.DBIZ_RANK, 0) || '_' || NVL(T.DBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.TE_MNG_MOK_CD, '00000')
                       ELSE '000_0_0000_0_0000000_0_0000000000000000_0_0000000000000000_0_0000000000000000_00000'
                  END
                , CASE WHEN NVL(T.REPORT_SORT_SEQ, '') = '' THEN NVL(T.SORT_SEQ, 0)
                       ELSE TO_NUMBER(NVL(T.REPORT_SORT_SEQ, ''))
                  END
    </select>
    
    <select id="ReportWrite070.selectReport070ExcelList" parameterClass="Map" resultClass="egovMap" >
        /*ReportWrite070.selectReport070ExcelList*/
        SELECT T.DGRCOMPO_ID AS DGRCOMPO_ID
             , T.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
             , CAST(T.DGR_LEVEL AS NUMERIC(5, 0)) AS DGR_LEVEL
             , T.REPORT_DETL_CD AS REPORT_DETL_CD
             , TRIM(CASE WHEN T.DGR_LEVEL = 0 THEN '합계'
                         WHEN T.DGR_LEVEL > 0 THEN T.LAVEL_SYMBOL || T.COMP_GROUND
                         ELSE ''
                    END) AS DGRCOMPO_NM
             , CAST((T.CONSIDER_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT1
             , CAST((T.CONSIDER_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT2
             , CAST((T.CONSIDER_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT3
             , CAST((T.CONSIDER_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT4
             , CAST((T.CONSIDER_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT5
             , CAST((T.CONSIDER_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT6
             , CAST((T.FRSC_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT1
             , CAST((T.FRSC_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT2
             , CAST((T.FRSC_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT3
             , CAST((T.FRSC_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT4
             , CAST((T.FRSC_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT5
             , CAST((T.FRSC_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT6
             , CAST((T.DMN_FRSC_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT1
             , CAST((T.DMN_FRSC_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT2
             , CAST((T.DMN_FRSC_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT3
             , CAST((T.DMN_FRSC_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT4
             , CAST((T.DMN_FRSC_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT5
             , CAST((T.DMN_FRSC_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT6
             , NVL(T.EXAM_CONT, '') AS EXAM_CONT
             , NVL(T.DEMAND_CONT, '') AS DEMAND_CONT
             , NVL(T.REFLECT_FG_NM, '') AS REFLECT_FG_NM
             , T.ORDER_YMD AS ORDER_YMD
          FROM (SELECT A.DGRCOMPO_ID AS DGRCOMPO_ID
                     , A.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
                     , A.DGR_LEVEL AS DGR_LEVEL
                     , A.FIS_YEAR AS FIS_YEAR
                     , A.BGT_DGR AS BGT_DGR
                     , A.ORDER_YMD_SEQ
                     , A.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID
                     , A.REPORT_CD AS REPORT_CD
                     , A.REPORT_DETL_CD AS REPORT_DETL_CD
                     , A.FIS_FG_CD AS FIS_FG_CD
                     , A.OFFICE_CD AS OFFICE_CD
                     , A.DEPT_CD AS DEPT_CD
                     , A.DBIZ_CD AS DBIZ_CD
                     , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                     , A.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ
                     , A.DEMAND_COMP_FORMULAR AS DEMAND_COMP_FORMULAR
                     , A.COMP_FORMULAR AS COMP_FORMULAR
                     , A.COMPO_LEVEL AS COMPO_LEVEL
                     , A.COMP_GROUND AS COMP_GROUND
                     , A.SORT_SEQ AS SORT_SEQ
                     , A.CONSIDER_AMT1 AS CONSIDER_AMT1
                     , A.CONSIDER_AMT2 AS CONSIDER_AMT2
                     , A.CONSIDER_AMT3 AS CONSIDER_AMT3
                     , A.CONSIDER_AMT4 AS CONSIDER_AMT4
                     , A.CONSIDER_AMT5 AS CONSIDER_AMT5
                     , A.CONSIDER_AMT6 AS CONSIDER_AMT6
                     , A.FRSC_AMT1 AS FRSC_AMT1
                     , A.FRSC_AMT2 AS FRSC_AMT2
                     , A.FRSC_AMT3 AS FRSC_AMT3
                     , A.FRSC_AMT4 AS FRSC_AMT4
                     , A.FRSC_AMT5 AS FRSC_AMT5
                     , A.FRSC_AMT6 AS FRSC_AMT6
                     , A.DMN_FRSC_AMT1 AS DMN_FRSC_AMT1
                     , A.DMN_FRSC_AMT2 AS DMN_FRSC_AMT2
                     , A.DMN_FRSC_AMT3 AS DMN_FRSC_AMT3
                     , A.DMN_FRSC_AMT4 AS DMN_FRSC_AMT4
                     , A.DMN_FRSC_AMT5 AS DMN_FRSC_AMT5
                     , A.DMN_FRSC_AMT6 AS DMN_FRSC_AMT6
                     , A.REFLECT_FG AS REFLECT_FG
                     , A.DEMAND_CONT AS DEMAND_CONT
                     , A.EXAM_CONT AS EXAM_CONT
                     , A.REPORT_SORT_SEQ AS REPORT_SORT_SEQ
                     , NVL((SELECT Z.ORDER_YMD FROM TB_REPORT070_O Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.ORDER_YMD_SEQ = A.ORDER_YMD_SEQ AND ROWNUM = 1), '') AS ORDER_YMD
                     , NVL((SELECT Z.DETL_CD_NM FROM TB_COMMCDDETL Z WHERE Z.CL_CD = 'RP003' AND Z.DETL_CD = A.REFLECT_FG AND ROWNUM = 1), '') AS REFLECT_FG_NM
                     , NVL((SELECT Z.OFFICE_RANK FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.OFFICE_CD = A.OFFICE_CD AND ROWNUM = 1), 0) AS OFFICE_RANK
                     , NVL((SELECT Z.DEPT_RANK FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DEPT_CD = A.DEPT_CD AND ROWNUM = 1), 0) AS DEPT_RANK
                     , NVL((SELECT Z.PBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS PBIZ_RANK
                     , NVL((SELECT Z.PBIZ_CD FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), '0000000000000000') AS PBIZ_CD
                     , NVL((SELECT Z.UBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS UBIZ_RANK
                     , NVL((SELECT Z.UBIZ_CD FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), '0000000000000000') AS UBIZ_CD
                     , NVL((SELECT Z.DBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS DBIZ_RANK
                     , NVL((SELECT Z.SYMBOL FROM TB_DGRCOMPOSYMBOL Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.COMPO_LEVEL = A.COMPO_LEVEL AND SYMBOL_LENGTH > 0), '') AS LAVEL_SYMBOL
                  FROM (SELECT T.*
                          FROM (SELECT DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_DETL_CD || '_' || '00000000000'
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_DETL_CD || '_' || A.TE_BGT_COMPO_ID) AS DGRCOMPO_ID
                                     , DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_CD || '_' || '00000000000'
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_DETL_CD || '_' || A.UP_TE_BGT_COMPO_ID) AS UP_DGRCOMPO_ID
                                     , DECODE(H.CT, 1, 0, 2, A.COMPO_LEVEL) AS DGR_LEVEL
                                     , A.FIS_YEAR AS FIS_YEAR
                                     , A.BGT_DGR AS BGT_DGR
                                     , A.ORDER_YMD_SEQ AS ORDER_YMD_SEQ
                                     , A.REPORT_CD AS REPORT_CD
                                     , A.REPORT_DETL_CD AS REPORT_DETL_CD
                                     , DECODE(H.CT, 1, '00000000000', A.TE_BGT_COMPO_ID) AS TE_BGT_COMPO_ID 
                                     , DECODE(H.CT, 1, '0000', A.FIS_FG_CD) AS FIS_FG_CD
                                     , DECODE(H.CT, 1, '0000', A.OFFICE_CD) AS OFFICE_CD
                                     , DECODE(H.CT, 1, '0000', A.DEPT_CD) AS DEPT_CD
                                     , DECODE(H.CT, 1, '0000000000000000', A.DBIZ_CD) AS DBIZ_CD 
                                     , DECODE(H.CT, 1, '00000', A.TE_MNG_MOK_CD) AS TE_MNG_MOK_CD 
                                     , DECODE(H.CT, 1, 0, A.TE_BGT_COMPO_SEQ) AS TE_BGT_COMPO_SEQ 
                                     , DECODE(H.CT, 1, '', A.DEMAND_COMP_FORMULAR) AS DEMAND_COMP_FORMULAR 
                                     , DECODE(H.CT, 1, '0', A.COMPO_LEVEL) AS COMPO_LEVEL 
                                     , DECODE(H.CT, 1, '', A.COMP_GROUND) AS COMP_GROUND 
                                     , DECODE(H.CT, 1, '', A.COMP_FORMULAR) AS COMP_FORMULAR 
                                     , DECODE(H.CT, 1, 0, A.SORT_SEQ) AS SORT_SEQ 
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT1, 0), A.CONSIDER_AMT1)) AS CONSIDER_AMT1
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT2, 0), A.CONSIDER_AMT2)) AS CONSIDER_AMT2
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT3, 0), A.CONSIDER_AMT3)) AS CONSIDER_AMT3
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT4, 0), A.CONSIDER_AMT4)) AS CONSIDER_AMT4
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT5, 0), A.CONSIDER_AMT5)) AS CONSIDER_AMT5
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT6, 0), A.CONSIDER_AMT6)) AS CONSIDER_AMT6
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT1, 0), A.FRSC_AMT1)) AS FRSC_AMT1
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT2, 0), A.FRSC_AMT2)) AS FRSC_AMT2
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT3, 0), A.FRSC_AMT3)) AS FRSC_AMT3
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT4, 0), A.FRSC_AMT4)) AS FRSC_AMT4
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT5, 0), A.FRSC_AMT5)) AS FRSC_AMT5
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT6, 0), A.FRSC_AMT6)) AS FRSC_AMT6
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT1, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT1, 0), A.DMN_FRSC_AMT1)) AS DMN_FRSC_AMT1
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT2, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT2, 0), A.DMN_FRSC_AMT2)) AS DMN_FRSC_AMT2
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT3, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT3, 0), A.DMN_FRSC_AMT3)) AS DMN_FRSC_AMT3
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT4, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT4, 0), A.DMN_FRSC_AMT4)) AS DMN_FRSC_AMT4
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT5, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT5, 0), A.DMN_FRSC_AMT5)) AS DMN_FRSC_AMT5
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT6, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT6, 0), A.DMN_FRSC_AMT6)) AS DMN_FRSC_AMT6
                                     , DECODE(H.CT, 1, '', A.REFLECT_FG) AS REFLECT_FG 
                                     , DECODE(H.CT, 1, '', A.DEMAND_CONT) AS DEMAND_CONT 
                                     , DECODE(H.CT, 1, '', A.EXAM_CONT) AS EXAM_CONT 
                                     , DECODE(H.CT, 1, '', A.SRCH_VAL) AS SRCH_VAL
                                     , DECODE(H.CT, 1, '', A.REPORT_SORT_SEQ) AS REPORT_SORT_SEQ
                                  FROM (SELECT A.FIS_YEAR AS FIS_YEAR
                                             , A.BGT_DGR AS BGT_DGR
                                             , A.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID 
                                             , A.UP_TE_BGT_COMPO_ID AS UP_TE_BGT_COMPO_ID
                                             , A.DEPT_CD AS DEPT_CD
                                             , A.DBIZ_CD AS DBIZ_CD 
                                             , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD 
                                             , A.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ 
                                             , A.DEMAND_COMP_FORMULAR AS DEMAND_COMP_FORMULAR 
                                             , A.DEMAND_DIFF_AMT AS DEMAND_DIFF_AMT
                                             , A.COMPO_LEVEL AS COMPO_LEVEL 
                                             , A.COMP_GROUND AS COMP_GROUND 
                                             , A.COMP_FORMULAR AS COMP_FORMULAR 
                                             , A.DIFF_AMT AS DIFF_AMT
                                             , A.SORT_SEQ AS SORT_SEQ 
                                             , B.OFFICE_CD AS OFFICE_CD
                                             , C.FIS_FG_CD AS FIS_FG_CD
                                             , E.ORDER_YMD_SEQ AS ORDER_YMD_SEQ
                                             , E.REPORT_CD AS REPORT_CD
                                             , E.REPORT_DETL_CD AS REPORT_DETL_CD
                                             , E.REFLECT_FG AS REFLECT_FG 
                                             , E.DEMAND_CONT AS DEMAND_CONT 
                                             , E.EXAM_CONT AS EXAM_CONT 
                                             , E.SRCH_VAL AS SRCH_VAL
                                             , E.REPORT_SORT_SEQ AS REPORT_SORT_SEQ
                                             , E.CONSIDER_AMT1 AS CONSIDER_AMT1
                                             , E.CONSIDER_AMT2 AS CONSIDER_AMT2
                                             , E.CONSIDER_AMT3 AS CONSIDER_AMT3
                                             , E.CONSIDER_AMT4 AS CONSIDER_AMT4
                                             , E.CONSIDER_AMT5 AS CONSIDER_AMT5
                                             , E.CONSIDER_AMT6 AS CONSIDER_AMT6
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '160', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT1
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '110', BB.ADJ_DEF_FRSC_AMT, '120', BB.ADJ_DEF_FRSC_AMT, '130', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT2
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '140', BB.ADJ_DEF_FRSC_AMT, '150', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT3
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '180', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT4
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '190', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT5
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '170', BB.ADJ_DEF_FRSC_AMT, '200', BB.ADJ_DEF_FRSC_AMT, '210', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT6
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '160', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT1
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '110', BB.DMN_DEF_FRSC_AMT, '120', BB.DMN_DEF_FRSC_AMT, '130', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT2
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '140', BB.DMN_DEF_FRSC_AMT, '150', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT3
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '180', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT4
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '190', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT5
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '170', BB.DMN_DEF_FRSC_AMT, '200', BB.DMN_DEF_FRSC_AMT, '210', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT6
                                          FROM TB_DGRCOMPO A
                                             , TB_DGRDEPT B
                                             , TB_DGRBIZ C
                                             , TB_YEARFISFG D
                                             , TB_REPORT070 E
                                         WHERE 1 = 1
                                         <isEqual prepend="" property="userDeptYn" compareValue="Y">
                                           AND EXISTS (SELECT 1
                                                         FROM TB_USERDEPT Z
                                                        WHERE Z.USER_ID = #userId#
                                                          AND Z.DEPT_CD = B.DEPT_CD
                                                          AND Z.USE_YN = 'Y'
                                                          AND ROWNUM = 1
                                                      )
                                         </isEqual>
                                           AND D.FIS_YEAR = C.FIS_YEAR
                                           AND D.FIS_FG_CD = C.FIS_FG_CD
                                           AND C.FIS_YEAR = A.FIS_YEAR
                                           AND C.BGT_DGR = A.BGT_DGR
                                           AND C.DBIZ_CD = A.DBIZ_CD
                                           AND B.FIS_YEAR = A.FIS_YEAR
                                           AND B.BGT_DGR = A.BGT_DGR
                                           AND B.DEPT_CD = A.DEPT_CD
                                           AND A.FIS_YEAR = E.FIS_YEAR
                                           AND A.BGT_DGR = E.BGT_DGR
                                           AND A.TE_BGT_COMPO_ID = E.TE_BGT_COMPO_ID
                                           AND E.REPORT_CD = #reportCd#
                                         <isNotEmpty prepend="" property="orderYmdSeq">
                                           AND E.ORDER_YMD_SEQ = #orderYmdSeq#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="reportDetlCd">
                                           AND E.REPORT_DETL_CD = #reportDetlCd#
                                         </isNotEmpty>
                                           AND E.FIS_YEAR = #fisYear#
                                           AND E.BGT_DGR = #bgtDgr#
                                         <isNotEmpty prepend="" property="fisFgMstCd">
                                           AND D.FIS_FG_MST_CD = #fisFgMstCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="fisFgCd">
                                           AND D.FIS_FG_CD = #fisFgCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="srchVal">
                                           AND E.SRCH_VAL LIKE '%' || #srchVal# || '%'
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="officeCd">
                                           AND B.OFFICE_CD = #officeCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="deptRankFr">
                                           AND B.DEPT_RANK <![CDATA[>=]]> #deptRankFr#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="deptRankTo">
                                           AND B.DEPT_RANK <![CDATA[<=]]> #deptRankTo#
                                         </isNotEmpty>
                                         <isEqual prepend="" property="frscFrCdYn" compareValue="Y">
                                           AND EXISTS (SELECT 1
                                                         FROM TB_DGRCOMPOFRSC Z
                                                        WHERE 1 = 1
                                                          AND Z.FIS_YEAR = A.FIS_YEAR
                                                          AND Z.BGT_DGR = A.BGT_DGR
                                                          AND Z.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID
                                                          AND Z.ADJ_DEF_FRSC_AMT <![CDATA[<>]]> 0                                                      
                                                        <isNotEmpty prepend="" property="frscFgCdFr">
                                                          AND Z.FRSC_FG_CD <![CDATA[>=]]> #frscFgCdFr#
                                                        </isNotEmpty>                                                      
                                                        <isNotEmpty prepend="" property="frscFgCdTo">
                                                          AND Z.FRSC_FG_CD <![CDATA[<=]]> #frscFgCdTo#
                                                        </isNotEmpty>
                                                      )
                                         </isEqual>
                                       ) A
                                     , (SELECT ROWNUM AS CT FROM TB_COMMCD WHERE ROWNUM BETWEEN 1 AND 2) H
                                 WHERE 1 = 1
                                 GROUP BY DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_DETL_CD || '_' || '00000000000'
                                                     , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.REPORT_DETL_CD || '_' || A.TE_BGT_COMPO_ID)
                               ) T
                       ) A
               ) T
         WHERE 1 = 1
         ORDER BY T.FIS_YEAR
                , NVL(T.BGT_DGR, 0)
                , NVL(T.ORDER_YMD, '00000000')
                , NVL(T.ORDER_YMD_SEQ, '000') 
                , CASE WHEN NVL(T.REPORT_SORT_SEQ, '') = '' THEN NVL(T.FIS_FG_CD, '000') ||
                                                                 NVL(T.OFFICE_RANK, 0) || '_' || NVL(T.OFFICE_CD, '0000000') || '_' || 
                                                                 NVL(T.DEPT_RANK, 0) || '_' || NVL(T.DEPT_CD, '0000000') || '_' || 
                                                                 NVL(T.PBIZ_RANK, 0) || '_' || NVL(T.PBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.UBIZ_RANK, 0) || '_' || NVL(T.UBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.DBIZ_RANK, 0) || '_' || NVL(T.DBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.TE_MNG_MOK_CD, '00000')
                       ELSE '000_0_0000_0_0000000_0_0000000000000000_0_0000000000000000_0_0000000000000000_00000'
                  END
                , CASE WHEN NVL(T.REPORT_SORT_SEQ, '') = '' THEN NVL(T.SORT_SEQ, 0)
                       ELSE TO_NUMBER(NVL(T.REPORT_SORT_SEQ, ''))
                  END
    </select>
    
    <select id="ReportWrite070.selectReportBizExcelList" parameterClass="Map" resultClass="egovMap" >
        /*ReportWrite070.selectReportBizExcelList*/
        SELECT T.DGRCOMPO_ID AS DGRCOMPO_ID
             , T.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
             , CAST(T.DGR_LEVEL AS NUMERIC(5, 0)) AS DGR_LEVEL
             , TRIM(CASE WHEN T.DGR_LEVEL = 0 THEN '합 계'
                         WHEN T.DGR_LEVEL = 1 THEN T.ORDER_YMD
                         ELSE NVL(T.COMP_GROUND, '')
                    END) AS DGRCOMPO_NM
             , T.OFFICE_CD AS OFFICE_CD
             , T.DEPT_NM AS DEPT_NM
             , CAST((T.CONSIDER_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS CONSIDER_AMT0
             , CAST((T.FRSC_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT0
             , CAST((T.FRSC_AMT1/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT1
             , CAST((T.FRSC_AMT2/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT2
             , CAST((T.FRSC_AMT3/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT3
             , CAST((T.FRSC_AMT4/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT4
             , CAST((T.FRSC_AMT5/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT5
             , CAST((T.FRSC_AMT6/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS FRSC_AMT6
             , CAST((T.DMN_FRSC_AMT0/DECODE(#amtUnit#, NULL, 1, '', 1, '0', 1, #amtUnit#)) AS NUMERIC(19,0)) AS DMN_FRSC_AMT0
          FROM (SELECT A.DGRCOMPO_ID AS DGRCOMPO_ID
                     , A.UP_DGRCOMPO_ID AS UP_DGRCOMPO_ID
                     , A.DGR_LEVEL AS DGR_LEVEL
                     , A.ORDER_YMD_SEQ AS ORDER_YMD_SEQ
                     , A.REPORT_DETL_CD AS REPORT_DETL_CD
                     , A.OFFICE_CD AS OFFICE_CD
                     , A.DEPT_CD AS DEPT_CD
                     , A.DBIZ_CD AS DBIZ_CD
                     , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD
                     , A.COMPO_LEVEL AS COMPO_LEVEL
                     , A.COMP_GROUND AS COMP_GROUND
                     , A.SORT_SEQ AS SORT_SEQ
                     , A.REPORT_SORT_SEQ AS REPORT_SORT_SEQ
                     , A.CONSIDER_AMT1 + A.CONSIDER_AMT4 AS CONSIDER_AMT0
                     , A.FRSC_AMT1 + A.FRSC_AMT4 AS FRSC_AMT0
                     , A.FRSC_AMT1 AS FRSC_AMT1
                     , A.FRSC_AMT2 AS FRSC_AMT2
                     , A.FRSC_AMT3 AS FRSC_AMT3
                     , A.FRSC_AMT4 AS FRSC_AMT4
                     , A.FRSC_AMT5 AS FRSC_AMT5
                     , A.FRSC_AMT6 AS FRSC_AMT6
                     , A.DMN_FRSC_AMT1 + A.DMN_FRSC_AMT4 AS DMN_FRSC_AMT0
                     , NVL((SELECT Z.ORDER_YMD FROM TB_REPORT070_O Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.ORDER_YMD_SEQ = A.ORDER_YMD_SEQ AND ROWNUM = 1), '') AS ORDER_YMD <!-- 수정 -->
                     , NVL((SELECT NVL(Z.OFFICE_RANK020, Z.OFFICE_RANK) FROM TB_DGROFFICE020 Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.OFFICE_CD = A.OFFICE_CD AND ROWNUM = 1), 0) AS OFFICE_RANK
                     , NVL((SELECT Z.OFFICE_NM FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.OFFICE_CD = A.OFFICE_CD AND ROWNUM = 1), '') AS OFFICE_NM
                     , NVL((SELECT Z.DEPT_RANK FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DEPT_CD = A.DEPT_CD AND ROWNUM = 1), 0) AS DEPT_RANK
                     , NVL((SELECT Z.DEPT_NM FROM TB_DGRDEPT Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DEPT_CD = A.DEPT_CD AND ROWNUM = 1), 0) AS DEPT_NM
                     , NVL((SELECT Z.PBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS PBIZ_RANK
                     , NVL((SELECT Z.PBIZ_CD FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), '0000000000000000') AS PBIZ_CD
                     , NVL((SELECT Z.UBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS UBIZ_RANK
                     , NVL((SELECT Z.UBIZ_CD FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), '0000000000000000') AS UBIZ_CD
                     , NVL((SELECT Z.DBIZ_RANK FROM TB_DGRBIZ Z WHERE Z.FIS_YEAR = A.FIS_YEAR AND Z.BGT_DGR = A.BGT_DGR AND Z.DBIZ_CD = A.DBIZ_CD AND ROWNUM = 1), 0) AS DBIZ_RANK
                  FROM (SELECT T.*
                          FROM (SELECT DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || A.REPORT_DETL_CD || '_' || '000' || '_' || '00000000000'
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || A.REPORT_DETL_CD || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || '00000000000'
                                                  , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || A.REPORT_DETL_CD || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.TE_BGT_COMPO_ID) AS DGRCOMPO_ID
                                     , DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || '000' || '_' || '000' || '_' || '00000000000'
                                                  , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || A.REPORT_DETL_CD || '_' || '000' || '_' || '00000000000'
                                                  , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || A.REPORT_DETL_CD || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.UP_TE_BGT_COMPO_ID) AS UP_DGRCOMPO_ID
                                     , A.FIS_YEAR AS FIS_YEAR
                                     , A.BGT_DGR AS BGT_DGR
                                     , DECODE(H.CT, 1, 0, 2, 1, 1 + A.COMPO_LEVEL) AS DGR_LEVEL
                                     , A.REPORT_DETL_CD AS REPORT_DETL_CD
                                     , DECODE(H.CT, 1, 0, A.ORDER_YMD_SEQ) AS ORDER_YMD_SEQ
                                     , DECODE(H.CT, 1, '0000', 2, '0000', A.OFFICE_CD) AS OFFICE_CD
                                     , DECODE(H.CT, 1, '0000000', 2, '0000000', A.DEPT_CD) AS DEPT_CD
                                     , DECODE(H.CT, 1, '0000000000000000', 2, '0000000000000000', A.DBIZ_CD) AS DBIZ_CD
                                     , DECODE(H.CT, 1, '00000', 2, '00000', A.TE_MNG_MOK_CD) AS TE_MNG_MOK_CD
                                     , DECODE(H.CT, 1, 0, 2, 0, A.COMPO_LEVEL) AS COMPO_LEVEL
                                     , DECODE(H.CT, 1, '', 2, '', A.COMP_GROUND) AS COMP_GROUND
                                     , DECODE(H.CT, 1, 0, 2, 0, A.SORT_SEQ) AS SORT_SEQ
                                     , DECODE(H.CT, 1, '', 2, '', A.REPORT_SORT_SEQ) AS REPORT_SORT_SEQ
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT1, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT1, 0), A.CONSIDER_AMT1)) AS CONSIDER_AMT1
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT4, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.CONSIDER_AMT4, 0), A.CONSIDER_AMT4)) AS CONSIDER_AMT4
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT1, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT1, 0), A.FRSC_AMT1)) AS FRSC_AMT1
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT2, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT2, 0), A.FRSC_AMT2)) AS FRSC_AMT2
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT3, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT3, 0), A.FRSC_AMT3)) AS FRSC_AMT3
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT4, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT4, 0), A.FRSC_AMT4)) AS FRSC_AMT4
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT5, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT5, 0), A.FRSC_AMT5)) AS FRSC_AMT5
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT6, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.FRSC_AMT6, 0), A.FRSC_AMT6)) AS FRSC_AMT6
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT1, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT1, 0), A.DMN_FRSC_AMT1)) AS DMN_FRSC_AMT1
                                     , SUM(DECODE(H.CT, 1, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT4, 0), 2, DECODE(A.COMPO_LEVEL, '1', A.DMN_FRSC_AMT4, 0), A.DMN_FRSC_AMT4)) AS DMN_FRSC_AMT4
                                  FROM (SELECT A.FIS_YEAR AS FIS_YEAR
                                             , A.BGT_DGR AS BGT_DGR
                                             , A.TE_BGT_COMPO_ID AS TE_BGT_COMPO_ID 
                                             , A.UP_TE_BGT_COMPO_ID AS UP_TE_BGT_COMPO_ID
                                             , A.DEPT_CD AS DEPT_CD
                                             , A.DBIZ_CD AS DBIZ_CD 
                                             , A.TE_MNG_MOK_CD AS TE_MNG_MOK_CD 
                                             , A.TE_BGT_COMPO_SEQ AS TE_BGT_COMPO_SEQ 
                                             , A.DEMAND_COMP_FORMULAR AS DEMAND_COMP_FORMULAR 
                                             , A.DEMAND_DIFF_AMT AS DEMAND_DIFF_AMT
                                             , A.COMPO_LEVEL AS COMPO_LEVEL 
                                             , A.COMP_GROUND AS COMP_GROUND 
                                             , A.COMP_FORMULAR AS COMP_FORMULAR 
                                             , A.DIFF_AMT AS DIFF_AMT
                                             , A.SORT_SEQ AS SORT_SEQ 
                                             , B.OFFICE_CD AS OFFICE_CD
                                             , C.FIS_FG_CD AS FIS_FG_CD
                                             , E.ORDER_YMD_SEQ AS ORDER_YMD_SEQ
                                             , E.REPORT_CD AS REPORT_CD
                                             , E.REPORT_DETL_CD AS REPORT_DETL_CD
                                             , E.REFLECT_FG AS REFLECT_FG 
                                             , E.DEMAND_CONT AS DEMAND_CONT 
                                             , E.EXAM_CONT AS EXAM_CONT 
                                             , E.SRCH_VAL AS SRCH_VAL
                                             , E.REPORT_SORT_SEQ AS REPORT_SORT_SEQ
                                             , E.CONSIDER_AMT1 AS CONSIDER_AMT1
                                             , E.CONSIDER_AMT4 AS CONSIDER_AMT4
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '160', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT1
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '110', BB.ADJ_DEF_FRSC_AMT, '120', BB.ADJ_DEF_FRSC_AMT, '130', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT2
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '140', BB.ADJ_DEF_FRSC_AMT, '150', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT3
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '180', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT4
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '190', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT5
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '170', BB.ADJ_DEF_FRSC_AMT, '200', BB.ADJ_DEF_FRSC_AMT, '210', BB.ADJ_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS FRSC_AMT6
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '160', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT1
                                             , (SELECT NVL(SUM(DECODE(CC.STAND_FRSC_CD, '180', BB.DMN_DEF_FRSC_AMT, 0)), 0) FROM TB_DGRCOMPOFRSC BB, TB_YEARFRSC CC WHERE 1 = 1 AND CC.FIS_YEAR = BB.FIS_YEAR AND CC.FRSC_FG_CD = BB.FRSC_FG_CD AND BB.FIS_YEAR = A.FIS_YEAR AND BB.BGT_DGR = A.BGT_DGR AND BB.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID) AS DMN_FRSC_AMT4
                                          FROM TB_DGRCOMPO A
                                             , TB_DGRDEPT B
                                             , TB_DGRBIZ C
                                             , TB_YEARFISFG D
                                             , TB_REPORT070 E
                                         WHERE 1 = 1
                                         <isEqual prepend="" property="userDeptYn" compareValue="Y">
                                           AND EXISTS (SELECT 1
                                                         FROM TB_USERDEPT Z
                                                        WHERE Z.USER_ID = #userId#
                                                          AND Z.DEPT_CD = B.DEPT_CD
                                                          AND Z.USE_YN = 'Y'
                                                          AND ROWNUM = 1
                                                      )
                                         </isEqual>
                                           AND D.FIS_YEAR = C.FIS_YEAR
                                           AND D.FIS_FG_CD = C.FIS_FG_CD
                                           AND C.FIS_YEAR = A.FIS_YEAR
                                           AND C.BGT_DGR = A.BGT_DGR
                                           AND C.DBIZ_CD = A.DBIZ_CD
                                           AND B.FIS_YEAR = A.FIS_YEAR
                                           AND B.BGT_DGR = A.BGT_DGR
                                           AND B.DEPT_CD = A.DEPT_CD
                                           AND A.FIS_YEAR = E.FIS_YEAR
                                           AND A.BGT_DGR = E.BGT_DGR
                                           AND A.TE_BGT_COMPO_ID = E.TE_BGT_COMPO_ID
                                           AND E.REPORT_CD = #reportCd#
                                         <isNotEmpty prepend="" property="reportDetlCd">
                                           AND E.REPORT_DETL_CD = #reportDetlCd#
                                         </isNotEmpty>
                                           AND E.FIS_YEAR = #fisYear#
                                           AND E.BGT_DGR = #bgtDgr#
                                         <isNotEmpty prepend="" property="fisFgMstCd">
                                           AND D.FIS_FG_MST_CD = #fisFgMstCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="fisFgCd">
                                           AND D.FIS_FG_CD = #fisFgCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="orderYmdSeq">
                                           AND E.ORDER_YMD_SEQ = #orderYmdSeq#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="srchVal">
                                           AND E.SRCH_VAL LIKE '%' || #srchVal# || '%'
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="officeCd">
                                           AND B.OFFICE_CD = #officeCd#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="deptRankFr">
                                           AND B.DEPT_RANK <![CDATA[>=]]> #deptRankFr#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="deptRankTo">
                                           AND B.DEPT_RANK <![CDATA[<=]]> #deptRankTo#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="teMngMokCdFr">
                                           AND A.TE_MNG_MOK_CD <![CDATA[>=]]> #teMngMokCdFr#
                                         </isNotEmpty>
                                         <isNotEmpty prepend="" property="teMngMokCdTo">
                                           AND A.TE_MNG_MOK_CD <![CDATA[<=]]> #teMngMokCdTo#
                                         </isNotEmpty>
                                         <isEqual prepend="" property="frscFrCdYn" compareValue="Y">
                                           AND EXISTS (SELECT 1
                                                         FROM TB_DGRCOMPOFRSC Z
                                                        WHERE 1 = 1
                                                          AND Z.FIS_YEAR = A.FIS_YEAR
                                                          AND Z.BGT_DGR = A.BGT_DGR
                                                          AND Z.TE_BGT_COMPO_ID = A.TE_BGT_COMPO_ID
                                                          AND Z.ADJ_DEF_FRSC_AMT <![CDATA[<>]]> 0                                                      
                                                        <isNotEmpty prepend="" property="frscFgCdFr">
                                                          AND Z.FRSC_FG_CD <![CDATA[>=]]> #frscFgCdFr#
                                                        </isNotEmpty>                                                      
                                                        <isNotEmpty prepend="" property="frscFgCdTo">
                                                          AND Z.FRSC_FG_CD <![CDATA[<=]]> #frscFgCdTo#
                                                        </isNotEmpty>
                                                      )
                                         </isEqual>
                                       ) A
                                     , (SELECT ROWNUM AS CT FROM TB_COMMCD WHERE ROWNUM BETWEEN 1 AND 3) H
                                 WHERE 1 = 1
                                 GROUP BY DECODE(H.CT, 1, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || A.REPORT_DETL_CD || '_' || '000' || '_' || '00000000000'
                                                     , 2, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || A.REPORT_DETL_CD || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || '00000000000'
                                                     , 3, A.FIS_YEAR || '_' || TO_CHAR(A.BGT_DGR, '000') || '_' || A.REPORT_DETL_CD || '_' || TO_CHAR(A.ORDER_YMD_SEQ, '000') || '_' || A.TE_BGT_COMPO_ID)
                               ) T
                       ) A
                 WHERE 1 = 1
               ) T
         WHERE 1 = 1
         ORDER BY NVL(T.ORDER_YMD, '00000000')
                , NVL(T.ORDER_YMD_SEQ, 0)
                , NVL(T.OFFICE_RANK, 0)
                , NVL(T.OFFICE_CD, '0000')
                , NVL(T.REPORT_DETL_CD, '000')
                , CASE WHEN NVL(T.REPORT_SORT_SEQ, '') = '' THEN NVL(T.DEPT_RANK, 0) || '_' || NVL(T.DEPT_CD, '0000000') || '_' || 
                                                                 NVL(T.PBIZ_RANK, 0) || '_' || NVL(T.PBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.UBIZ_RANK, 0) || '_' || NVL(T.UBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.DBIZ_RANK, 0) || '_' || NVL(T.DBIZ_CD, '0000000000000000') || '_' || 
                                                                 NVL(T.TE_MNG_MOK_CD, '00000')
                       ELSE '0_0000000_0_0000000000000000_0_0000000000000000_0_0000000000000000_00000'
                  END
                , CASE WHEN NVL(T.REPORT_SORT_SEQ, '') = '' THEN NVL(T.SORT_SEQ, 0)
                       ELSE TO_NUMBER(NVL(T.REPORT_SORT_SEQ, ''))
                  END
    </select>
    
    <update id="ReportWrite070.updateReport070" parameterClass="Map" >
        /*ReportWrite070.updateReport070*/
        UPDATE TB_REPORT070
           SET REFLECT_FG = #reflectFg#
             , DEMAND_CONT = #demandCont#
             , EXAM_CONT = #examCont#
             , CONSIDER_AMT1 = NVL(#considerAmt1#, 0) * NVL(#amtUnit#, 1)
             , CONSIDER_AMT2 = NVL(#considerAmt2#, 0) * NVL(#amtUnit#, 1)
             , CONSIDER_AMT3 = NVL(#considerAmt3#, 0) * NVL(#amtUnit#, 1)
             , CONSIDER_AMT4 = NVL(#considerAmt4#, 0) * NVL(#amtUnit#, 1)
             , CONSIDER_AMT5 = NVL(#considerAmt5#, 0) * NVL(#amtUnit#, 1)
             , CONSIDER_AMT6 = NVL(#considerAmt6#, 0) * NVL(#amtUnit#, 1)
             , REPORT_SORT_SEQ = NVL(#reportSortSeq#, 0)
             , MODI_ID = #userId#
             , MODI_DATE = SYSTIMESTAMP
         WHERE 1 = 1
           AND REPORT_CD = #reportCd#
           AND REPORT_DETL_CD = #reportDetlCd#
           AND FIS_YEAR = #fisYear#
           AND BGT_DGR = #bgtDgr#
           AND TE_BGT_COMPO_ID = #teBgtCompoId#
           AND ORDER_YMD_SEQ = #orderYmdSeq#
    </update>
</sqlMap>
