                 + '    </tr>'
                 + '    <tr>'
                 + '      <td>국비</td>'
                 + '      <td><input id="totFrscAmt2_'+rowObject.dgrcompoId+'" value="'+addCommaStr(rowObject.totFrscAmt2)+'" '+classStr+' '+readOnlyStr+' /></td>'
                 + '    </tr>'
