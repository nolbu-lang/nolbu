    	var param = getSearchParam();
        param["mayorReportYn"] = "N";
        param["fileNm"] = "보고항목";
        param["indiAttrNm"] = condIndiAttrNm;
        param["amtUnit"] = "1000";
        
        $.bcjisExcelAjaxCall({
            url : "/report/ajaxReportWrite0F0SaveFile.do"
          , data: param
        });
    });
    
