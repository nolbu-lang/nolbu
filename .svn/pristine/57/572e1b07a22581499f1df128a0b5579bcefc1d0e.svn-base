            , ReportWrite010Service reportWrite010Service, Report010SaveFile report010SaveFile
            , ReportWrite020Service reportWrite020Service, Report020SaveFile report020SaveFile
            , ReportWrite030Service reportWrite030Service, Report030SaveFile report030SaveFile
            , ReportWrite040Service reportWrite040Service, Report040SaveFile report040SaveFile
            , ReportWrite050Service reportWrite050Service, Report050SaveFile report050SaveFile
            , ReportWrite055Service reportWrite055Service, Report055SaveFile report055SaveFile
            , ReportWrite060Service reportWrite060Service, Report060SaveFile report060SaveFile
            , ReportWrite090Service reportWrite090Service, Report090SaveFile report090SaveFile
            , BcjisFileMngService bcjisFileMngService
