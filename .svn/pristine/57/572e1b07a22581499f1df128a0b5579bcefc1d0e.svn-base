            jsonParam.put("amtUnit", "1000");
            
            resultList = JSONArray.fromObject(reportWrite055Service.selectReport055ExcelList(jsonParam));
            jsonParam.put("dataList", resultList);
            report055SaveFile.buildExcelDocument(jsonParam, "CL", "");
            insertFileInfo("155");
            
            //공통
            jsonParam.put("fileNm", "공통심사조서");
            jsonParam.put("reportCd", "060");
            jsonParam.put("reportDetlCd", "");
            jsonParam.put("amtUnit", "1000");
            
            resultList = JSONArray.fromObject(reportWrite060Service.selectReport060ExcelList(jsonParam));
            jsonParam.put("dataList", resultList);
            report060SaveFile.buildSheetDocument(jsonParam, "CL", "");
