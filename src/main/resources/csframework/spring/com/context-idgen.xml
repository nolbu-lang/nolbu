<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.springframework.org/schema/beans
	http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <bean name="csFileIdGnrService" class="egovframework.rte.fdl.idgnr.impl.EgovTableIdGnrService" destroy-method="destroy">
        <property name="dataSource" ref="bcjis.dataSource" />
        <property name="strategy" ref="fileIdStrategy" />
        <property name="blockSize" value="10" />
        <property name="table" value="TB_COMM_SEQ" />
        <property name="tableName" value="TB_FILE" />
    </bean>
    
    <bean name="fileIdStrategy" class="egovframework.rte.fdl.idgnr.impl.strategy.EgovIdGnrStrategyImpl">
        <property name="prefix" value="FILE_" />
        <property name="cipers" value="15" />
        <property name="fillChar" value="0" />
    </bean>

    <bean name="csUserIdGnrService" class="egovframework.rte.fdl.idgnr.impl.EgovTableIdGnrService" destroy-method="destroy">
        <property name="dataSource" ref="bcjis.dataSource" />
        <property name="strategy" ref="userIdStrategy" />
        <property name="blockSize" value="10" />
        <property name="table" value="TB_COMM_SEQ" />
        <property name="tableName" value="TB_USER" />
    </bean>

    <bean name="userIdStrategy" class="egovframework.rte.fdl.idgnr.impl.strategy.EgovIdGnrStrategyImpl">
        <property name="prefix" value="USER_" />
        <property name="cipers" value="15" />
        <property name="fillChar" value="0" />
    </bean>

	<bean name="csCngHisGnrService" class="egovframework.rte.fdl.idgnr.impl.EgovTableIdGnrService" destroy-method="destroy">
		<property name="dataSource" ref="bcjis.dataSource" />
		<property name="strategy" ref="cngIdStrategy" />
		<property name="blockSize" value="1" />
		<property name="table" value="TB_COMM_SEQ" />
		<property name="tableName" value="TB_CNG_HISTORY" />
	</bean>

	<bean name="cngIdStrategy" class="egovframework.rte.fdl.idgnr.impl.strategy.EgovIdGnrStrategyImpl">
		<property name="prefix" value="CNG_" />
		<property name="cipers" value="15" />
		<property name="fillChar" value="0" />
	</bean>

    <bean name="csTraceLogIdGnrService" class="egovframework.rte.fdl.idgnr.impl.EgovTableIdGnrService" destroy-method="destroy">
        <property name="dataSource" ref="bcjis.dataSource" />
        <property name="strategy" ref="traceLogIdStrategy" />
        <property name="blockSize" value="10" />
        <property name="table" value="TB_COMM_SEQ" />
        <property name="tableName" value="TB_TRACELOG" />
    </bean>
    
    <bean name="traceLogIdStrategy" class="egovframework.rte.fdl.idgnr.impl.strategy.EgovIdGnrStrategyImpl">
        <property name="prefix" value="LOG_" />
        <property name="cipers" value="16" />
        <property name="fillChar" value="0" />
    </bean>

    <bean name="csPledgeInfoIdGnrService" class="egovframework.rte.fdl.idgnr.impl.EgovTableIdGnrService" destroy-method="destroy">
        <property name="dataSource" ref="bcjis.dataSource" />
        <property name="strategy" ref="pledgeInfoIdStrategy" />
        <property name="blockSize" value="1" />
        <property name="table" value="TB_COMM_SEQ" />
        <property name="tableName" value="TB_PLEDGEINFO" />
    </bean>
    
    <bean name="pledgeInfoIdStrategy" class="egovframework.rte.fdl.idgnr.impl.strategy.EgovIdGnrStrategyImpl">
        <property name="prefix" value="P" />
        <property name="cipers" value="10" />
        <property name="fillChar" value="0" />
    </bean>

    <bean name="csPledgeBizIdGnrService" class="egovframework.rte.fdl.idgnr.impl.EgovTableIdGnrService" destroy-method="destroy">
        <property name="dataSource" ref="bcjis.dataSource" />
        <property name="strategy" ref="pledgeBizIdStrategy" />
        <property name="blockSize" value="1" />
        <property name="table" value="TB_COMM_SEQ" />
        <property name="tableName" value="TB_PLEDGEBIZ" />
    </bean>
    
    <bean name="pledgeBizIdStrategy" class="egovframework.rte.fdl.idgnr.impl.strategy.EgovIdGnrStrategyImpl">
        <property name="prefix" value="B" />
        <property name="cipers" value="10" />
        <property name="fillChar" value="0" />
    </bean>
    
    
</beans>
